---
import '../styles/global.css';
import Footer from '../components/Footer.astro';

interface Props {
	title: string;
	description?: string;
	keywords?: string;
	ogImage?: string;
	canonicalURL?: string;
}

const { 
	title = "BMI Calculator | Real BMI – Most Accurate Body Mass Index Tool", 
	description = "Calculate your Body Mass Index (BMI) with clinical precision. Real BMI Calculator provides instant results for BMI, BMR, and TDEE. Perfect for men, women, and athletes following WHO & CDC standards.",
	keywords = "bmi calculator, real bmi calculator, body mass index calculator, bmi calculator for men, bmi calculator for women, accurate bmi calculator, calculate bmi, bmi chart, health calculator, bmr calculator, tdee calculator, weight loss tracker",
	ogImage = "/seo-dark.png",
	canonicalURL: customCanonicalURL
} = Astro.props;

const canonicalURL = customCanonicalURL || new URL(Astro.url.pathname, 'https://realbmicalculator.com').href;
const ogImageAbsolute = ogImage.startsWith('http') ? ogImage : `https://realbmicalculator.com${ogImage}`;
const { currentLocale } = Astro;

const pagePath = Astro.url.pathname.split('/').filter(Boolean);
const breadcrumbItems: any[] = [];
if (pagePath.length > 0) {
  const segments = pagePath[0] && ['en', 'es', 'fr', 'de', 'ko', 'hi'].includes(pagePath[0]) ? pagePath.slice(1) : pagePath;
  segments.forEach((segment, index) => {
    const name = segment.replace(/-/g, ' ').replace(/\b\w/g, (char) => char.toUpperCase());
    breadcrumbItems.push({
      '@type': 'ListItem',
      position: index + 2,
      name,
      item: `https://realbmicalculator.com${Astro.url.pathname.split('/').slice(0, index + 1 + (pagePath[0] && ['en', 'es', 'fr', 'de', 'ko', 'hi'].includes(pagePath[0]) ? 1 : 0)).join('/')}`
    });
  });
}

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How is BMI calculated?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "BMI compares your weight and height using a simple formula, and the Real BMI Calculator can process metric or imperial units instantly."
      }
    },
    {
      "@type": "Question",
      "name": "What is a healthy BMI range?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "For most adults, a healthy BMI range is 18.5 to 24.9, while some health professionals use a lower threshold for Asian and Indian populations."
      }
    },
    {
      "@type": "Question",
      "name": "Is BMI accurate for athletes or muscular people?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "BMI is a useful screening tool, but it can overestimate body fat in muscular individuals and should be paired with waist circumference and other measurements."
      }
    }
  ]
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://realbmicalculator.com"
    },
    ...breadcrumbItems
  ]
};

// HowTo Schema for BMI Calculation
const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "How to Calculate BMI",
  "description": "Step-by-step guide on how to calculate your Body Mass Index (BMI).",
  "step": [
    {
      "@type": "HowToStep",
      "text": "Measure your weight in kilograms or pounds.",
      "name": "Measure Weight"
    },
    {
      "@type": "HowToStep",
      "text": "Measure your height in centimeters or inches.",
      "name": "Measure Height"
    },
    {
      "@type": "HowToStep",
      "text": "Input the data into the Real BMI Calculator to get instant results.",
      "name": "Calculate"
    }
  ],
  "totalTime": "PT1M"
};
---

<!doctype html>
<html lang={currentLocale} class="scroll-smooth">
	<head>
		<!-- Google tag (gtag.js) -->
		<script async src="https://www.googletagmanager.com/gtag/js?id=G-9D3TJCYP4R"></script>
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}
			gtag('js', new Date());

			gtag('config', 'G-9D3TJCYP4R');
		</script>

		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta http-equiv="X-UA-Compatible" content="IE=edge" />
		
		<!-- Favicons -->
		<link rel="icon" href="/favicon.ico" sizes="any" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<meta name="apple-mobile-web-app-title" content="Real BMI" />
		<meta name="theme-color" content="#E8674A" />
		<link rel="manifest" href="/site.webmanifest" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- SEO Meta Tags -->
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="keywords" content={keywords} />
		<link rel="canonical" href={canonicalURL} />
		<meta name="author" content="Real BMI" />
		<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />

		<!-- Hreflang Tags (Dynamic Multi-language Indexing) -->
		{['en', 'es', 'fr', 'de', 'ko', 'hi'].map((l) => {
			const currentPath = Astro.url.pathname;
			const cleanPath = currentPath.replace(/^\/(en|es|fr|de|ko|hi)(\/|$)/, '/');
			const targetPath = cleanPath === '/' ? `/${l}/` : `/${l}${cleanPath.startsWith('/') ? cleanPath : '/' + cleanPath}`;
			return <link rel="alternate" hreflang={l} href={`https://realbmicalculator.com${targetPath}`} />;
		})}
		<link rel="alternate" hreflang="x-default" href="https://realbmicalculator.com/en/" />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="Real BMI Calculator" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImageAbsolute} />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={canonicalURL} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={ogImageAbsolute} />
		
		<!-- Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Cabin+Condensed:wght@400;500;600;700&family=Outfit:wght@300;400;500;600;700&family=Inter:wght@400;500;600;700&display=swap" />
		<link href="https://fonts.googleapis.com/css2?family=Cabin+Condensed:wght@400;500;600;700&family=Outfit:wght@300;400;500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
		<noscript>
			<link href="https://fonts.googleapis.com/css2?family=Cabin+Condensed:wght@400;500;600;700&family=Outfit:wght@300;400;500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
		</noscript>

		<!-- JSON-LD Structured Data -->
		<script is:inline type="application/ld+json">
			{
				"@context": "https://schema.org",
				"@type": "WebSite",
				"name": "Real BMI Calculator",
				"url": "https://realbmicalculator.com",
				"potentialAction": {
					"@type": "SearchAction",
					"target": "https://realbmicalculator.com/search?q={search_term_string}",
					"query-input": "required name=search_term_string"
				}
			}
		</script>
		<script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
		<script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
		<script is:inline type="application/ld+json" set:html={JSON.stringify(howToSchema)} />
		<script is:inline type="application/ld+json">
			{
				"@context": "https://schema.org",
				"@type": "SoftwareApplication",
				"name": "Real BMI Calculator",
				"operatingSystem": "All",
				"applicationCategory": "HealthApplication",
				"url": "https://realbmicalculator.com",
				"offers": {
					"@type": "Offer",
					"price": "0",
					"priceCurrency": "USD"
				},
				"aggregateRating": {
					"@type": "AggregateRating",
					"ratingValue": "4.9",
					"ratingCount": "1250"
				}
			}
		</script>
		<script is:inline type="application/ld+json">
			{
				"@context": "https://schema.org",
				"@type": "MedicalWebPage",
				"name": "Body Mass Index (BMI) Clinical Reference & Calculator",
				"url": "https://realbmicalculator.com",
				"aspect": ["Diagnosis", "Prevention", "Overview"],
				"medicalAudience": "Patient",
				"citation": [
					"https://www.who.int/news-room/fact-sheets/detail/obesity-and-overweight",
					"https://www.cdc.gov/healthyweight/assessing/bmi/adult_bmi/index.html"
				],
				"code": {
					"@type": "MedicalCode",
					"code": "Z68",
					"codingSystem": "ICD-10-CM"
				}
			}
		</script>
		<script is:inline type="application/ld+json">
			{
				"@context": "https://schema.org",
				"@type": "Organization",
				"name": "Real BMI Calculator",
				"url": "https://realbmicalculator.com",
				"logo": "https://realbmicalculator.com/favicon.svg",
				"sameAs": [
					"https://www.linkedin.com/in/bhawanshi-dosi"
				]
			}
		</script>

		<slot name="json-ld" />

		<script is:inline>
			const theme = (() => {
				if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
					return localStorage.getItem('theme');
				}
				return 'dark';
			})();

			if (theme === 'light') {
				document.documentElement.classList.remove('dark');
			} else {
				document.documentElement.classList.add('dark');
			}

			if (typeof localStorage !== 'undefined' && !localStorage.getItem('theme')) {
				window.localStorage.setItem('theme', 'dark');
			}
		</script>
		<style is:global>
			.bg-slide {
				opacity: 0;
				filter: blur(1.5px);
				transform: scale(1.02);
				transition: opacity 2.5s ease-in-out;
				will-change: opacity;
			}
			.bg-slide.active {
				opacity: 0.55;
			}
			.dark .bg-slide {
				filter: blur(3px);
			}
			.dark .bg-slide.active {
				opacity: 0.45;
			}
		</style>
	</head>
	<body class="min-h-screen relative">
		<!-- Full-Screen Edge-to-Edge Background Image -->
		<div id="bg-slideshow" class="fixed inset-0 w-screen h-screen pointer-events-none z-[-2] overflow-hidden" style="background-color: var(--background);">
			<div class="bg-slide active absolute inset-0 w-full h-full bg-cover bg-center bg-no-repeat" style="background-image: url('/images/bg/2.webp'); background-size: cover; background-position: center;"></div>
			<div class="bg-slide absolute inset-0 w-full h-full bg-cover bg-center bg-no-repeat" style="background-image: url('/images/bg/4.webp'); background-size: cover; background-position: center;"></div>
			<!-- Subtle tint overlay for theme blending -->
			<div class="absolute inset-0 opacity-10 dark:opacity-30 pointer-events-none z-10" style="background-color: var(--background);"></div>
		</div>

		<slot />
		<Footer />
		
		<!-- Background Slideshow Script -->
		<script is:inline>
			(function() {
				let slideshowTimer = null;
				let currentSlide = 0;

				function initSlideshow() {
					if (slideshowTimer) clearInterval(slideshowTimer);
					const slides = document.querySelectorAll('#bg-slideshow .bg-slide');
					if (!slides || slides.length <= 1) return;

					currentSlide = 0;
					slides.forEach((s, idx) => {
						if (idx === 0) s.classList.add('active');
						else s.classList.remove('active');
					});

					slideshowTimer = setInterval(() => {
						slides[currentSlide].classList.remove('active');
						currentSlide = (currentSlide + 1) % slides.length;
						slides[currentSlide].classList.add('active');
					}, 6000);
				}

				initSlideshow();
				document.addEventListener('astro:after-swap', initSlideshow);
			})();
		</script>

		<!-- AdSense -->
		<script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-9923831868322634" crossorigin="anonymous"></script>
	</body>
</html>
