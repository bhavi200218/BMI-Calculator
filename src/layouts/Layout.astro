---
import '../styles/global.css';
import Footer from '../components/Footer.astro';

interface Props {
	title: string;
	description?: string;
	keywords?: string;
	ogImage?: string;
	canonicalURL?: string;
}

const { 
	title, 
	description = "Free online BMI calculator. Calculate BMI, BMR, and body composition instantly with Real BMI Calculator. The ultimate precision health instrument for data-driven wellness.",
	keywords = "bmi calculator, real bmi, calculate bmi, bmi calculator for women, bmi calculator for men, adult bmi calculator, calculate bmi lbs, bmi chart for age, body mass index calculator, health analytics",
	ogImage = "/seo-dark.png"
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, 'https://realbmicalculator.com').href;
const { currentLocale } = Astro;

// HowTo Schema for BMI Calculation
const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "How to Calculate BMI",
  "description": "Step-by-step guide on how to calculate your Body Mass Index (BMI).",
  "step": [
    {
      "@type": "HowToStep",
      "text": "Measure your weight in kilograms or pounds.",
      "name": "Measure Weight"
    },
    {
      "@type": "HowToStep",
      "text": "Measure your height in centimeters or inches.",
      "name": "Measure Height"
    },
    {
      "@type": "HowToStep",
      "text": "Input the data into the Real BMI Calculator to get instant results.",
      "name": "Calculate"
    }
  ],
  "totalTime": "PT1M"
};
---

<!doctype html>
<html lang={currentLocale} class="scroll-smooth">
	<head>
		<!-- Google tag (gtag.js) -->
		<script async src="https://www.googletagmanager.com/gtag/js?id=G-9D3TJCYP4R"></script>
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}
			gtag('js', new Date());

			gtag('config', 'G-9D3TJCYP4R');
		</script>

		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		
		<!-- Favicons -->
		<link rel="icon" type="image/svg+xml" href="/icon.svg" />
		<link rel="shortcut icon" href="/favicon.svg" />
		<link rel="apple-touch-icon" href="/icon.svg" />
		<link rel="mask-icon" href="/icon.svg" color="#000000" />
		<meta name="apple-mobile-web-app-title" content="Real BMI" />
		<meta name="theme-color" content="#FDFBF8" />
		<link rel="manifest" href="/site.webmanifest" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- SEO Meta Tags -->
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="keywords" content={keywords} />
		<link rel="canonical" href={canonicalURL} />
		<meta name="author" content="Real BMI" />
		<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />

		<!-- Hreflang Tags (Dynamic Multi-language Indexing) -->
		{['en', 'es', 'fr', 'de', 'ko', 'hi'].map((lang) => {
			const path = Astro.url.pathname.replace(/^\/[a-z]{2}\//, `/${lang}/`).replace(/^\/[a-z]{2}$/, `/${lang}/`);
			return <link rel="alternate" hreflang={lang} href={`https://realbmicalculator.com${path}`} />;
		})}
		<link rel="alternate" hreflang="x-default" href={`https://realbmicalculator.com/en/`} />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="Real BMI Calculator" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImage} />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={canonicalURL} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={ogImage} />
		
		<!-- Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Inter:wght@400;500;600;700&display=swap" />
		<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
		<noscript>
			<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
		</noscript>

		<!-- JSON-LD Structured Data -->
		<script is:inline type="application/ld+json">
			{
				"@context": "https://schema.org",
				"@type": "WebSite",
				"name": "Real BMI Calculator",
				"url": "https://realbmicalculator.com",
				"potentialAction": {
					"@type": "SearchAction",
					"target": "https://realbmicalculator.com/search?q={search_term_string}",
					"query-input": "required name=search_term_string"
				}
			}
		</script>
		<script is:inline type="application/ld+json" set:html={JSON.stringify(howToSchema)} />
		<script is:inline type="application/ld+json">
			{
				"@context": "https://schema.org",
				"@type": "SoftwareApplication",
				"name": "Real BMI Calculator",
				"operatingSystem": "All",
				"applicationCategory": "HealthApplication",
				"url": "https://realbmicalculator.com",
				"offers": {
					"@type": "Offer",
					"price": "0",
					"priceCurrency": "USD"
				},
				"aggregateRating": {
					"@type": "AggregateRating",
					"ratingValue": "4.9",
					"ratingCount": "1250"
				}
			}
		</script>
		<script is:inline type="application/ld+json">
			{
				"@context": "https://schema.org",
				"@type": "Organization",
				"name": "Real BMI Calculator",
				"url": "https://realbmicalculator.com",
				"logo": "https://realbmicalculator.com/icon.svg"
			}
		</script>

		<slot name="json-ld" />


		<!-- AdSense Placeholder -->
		<script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-9923831868322634" crossorigin="anonymous"></script>

		<script is:inline>
			const theme = (() => {
				if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
					return localStorage.getItem('theme');
				}
				if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
					return 'dark';
				}
				return 'light';
			})();

			if (theme === 'light') {
				document.documentElement.classList.remove('dark');
			} else {
				document.documentElement.classList.add('dark');
			}

			window.localStorage.setItem('theme', theme);
		</script>
	</head>
	<body class="min-h-screen">
		<slot />
		<Footer />
	</body>
</html>
