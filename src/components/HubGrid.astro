---
import { calculators, type Locale } from '../utils/calculators';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;

const headers = {
  en: { title: 'Quick Tools Directory', desc: 'Browse our complete catalog of professional health calculators.' },
  es: { title: 'Directorio de herramientas', desc: 'Explora nuestro catálogo de calculadoras de salud profesionales.' },
  fr: { title: 'Répertoire des outils de santé', desc: 'Consultez notre catalogue complet de calculateurs de santé professionnels.' },
  de: { title: 'Verzeichnis der Gesundheitsrechner', desc: 'Durchsuchen Sie unser komplettes Sortiment an professionellen Rechnern.' },
  ko: { title: '건강 분석 도구 디렉토리', desc: '프로급 건강 및 신체 측정 계산기 전체 목록을 확인하세요.' },
  hi: { title: 'त्वरित उपकरण निर्देशिका', desc: 'पेशेवर स्वास्थ्य कैलकुलेटर की हमारी पूरी सूची देखें।' }
}[lang] || { title: 'Quick Tools Directory', desc: 'Browse our complete catalog of health calculators.' };
---

<section id="hub-grid" class="py-16 border-t border-[var(--border)] max-w-7xl mx-auto space-y-6">
  <div class="space-y-2 text-center">
    <p class="text-xs font-display font-semibold uppercase tracking-[0.25em] text-[var(--accent)]">
      {lang === 'es' ? 'Acceso Rápido' : lang === 'fr' ? 'Accès Rapide' : lang === 'de' ? 'Schnellzugriff' : lang === 'ko' ? '빠른 도구 액세스' : lang === 'hi' ? 'त्वरित पहुँच' : 'Quick Access'}
    </p>
    <h2 class="text-2xl md:text-3xl font-display font-bold uppercase text-[var(--foreground)]">
      {headers.title}
    </h2>
    <p class="text-xs md:text-sm text-[var(--muted-foreground)] font-medium max-w-xl mx-auto">
      {headers.desc}
    </p>
  </div>

  <div class="flex flex-wrap justify-center gap-3 pt-4">
    {calculators.map(calc => {
      const url = `/${lang}/${calc.slug}`;
      const name = calc.name[lang] || calc.name['en'];
      
      return (
        <a 
          href={url} 
          class="px-4 py-2.5 rounded-full border border-[var(--border)] bg-[var(--card)] hover:border-[var(--accent)] hover:text-[var(--foreground)] text-xs md:text-sm font-display font-bold uppercase tracking-wider text-[var(--muted-foreground)] transition-all duration-300 hover:shadow-[var(--shadow-accent)] cursor-pointer"
        >
          {name}
        </a>
      );
    })}
  </div>
</section>
