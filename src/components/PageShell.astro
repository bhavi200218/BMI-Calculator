---
interface Props {
  title: string;
  eyebrow?: string;
  description?: string;
  returnUrl?: string;
  returnLabel?: string;
}

const {
  title,
  eyebrow,
  description,
  returnUrl = '/en',
  returnLabel = 'Home'
} = Astro.props as Props;
---

<section class="pt-40 pb-20 px-4 md:px-6">
  <div class="max-w-7xl mx-auto">
    <div class="space-y-6 mb-12">
      <a href={returnUrl} class="inline-flex items-center gap-2 text-[10px] font-black uppercase tracking-[0.28em] text-[var(--accent)] hover:text-[var(--foreground)] transition-colors">
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
        {returnLabel}
      </a>
      {eyebrow && <p class="text-xs font-semibold uppercase tracking-[0.32em] text-[var(--accent)]">{eyebrow}</p>}
      <h1 class="text-4xl sm:text-5xl md:text-6xl font-display font-black uppercase tracking-tight leading-tight text-[var(--foreground)]">
        {title}
      </h1>
      {description && <p class="max-w-3xl text-base md:text-lg leading-relaxed text-[var(--muted-foreground)]">{description}</p>}
    </div>

    <div class="grid gap-10 lg:grid-cols-[1.35fr_0.75fr] items-start">
      <div class="space-y-10">
        <slot />
      </div>
      <aside class="rounded-[var(--radius)] border border-[var(--border)] bg-[var(--card)] p-8 shadow-[var(--shadow-soft)]">
        <p class="text-xs uppercase tracking-[0.28em] font-semibold text-[var(--accent)]">Need help?</p>
        <h2 class="mt-4 text-2xl font-black tracking-tight text-[var(--foreground)]">Get in touch</h2>
        <p class="mt-4 text-sm leading-relaxed text-[var(--muted-foreground)]">
          Have questions about our health calculator or want feedback on the tools? Reach our team directly for fast support and professional guidance.
        </p>
        <a href="mailto:vecna312002@gmail.com" class="mt-6 inline-flex items-center justify-center w-full rounded-[1.25rem] border border-[var(--accent)] bg-[var(--accent)]/5 px-5 py-4 text-sm font-semibold uppercase tracking-[0.2em] text-[var(--accent)] transition hover:bg-[var(--accent)]/10">
          Email Support
        </a>
        <div class="mt-8 space-y-4 text-sm text-[var(--muted-foreground)] leading-relaxed">
          <p class="font-semibold text-[var(--foreground)]">Response time</p>
          <p>We aim to respond within 24 hours on business days.</p>
        </div>
      </aside>
    </div>
  </div>
</section>
