---
const { currentLocale } = Astro;
const lang = currentLocale || 'en';

const content: Record<string, any> = {
  en: {
    eyebrow: "Health Insights",
    sections: [
      {
        title: "Why Use the Real BMI Calculator?",
        text: "The Real BMI Calculator provides highly precise measurements by utilizing the latest clinical protocols. Unlike generic tools, our system is optimized for accuracy across global standards, ensuring you get reliable health data instantly."
      },
      {
        title: "Accuracy of the BMI Calculator with Lbs and Inches",
        text: "In the United States, the standard formula for BMI calculation uses pounds and inches: (weight (lb) / [height (in)]² ) x 703. Our professional-grade calculator automates this process, providing results that align with CDC guidelines."
      },
      {
        title: "The Real Limitations of BMI: What to Watch Out For",
        text: "It is essential to understand that BMI is a screening tool rather than a comprehensive diagnostic. Elite athletes may have a higher BMI due to muscle density despite low body fat percentage."
      },
      {
        title: "How to Improve Your BMI Score Safely",
        text: "Transitioning to a healthier BMI score requires consistent habits. Focus on balanced nutrition rich in whole foods and complex carbohydrates, combined with regular aerobic activity."
      },
      {
        title: "Getting the Most Accurate Measurements",
        text: "For accurate results, ensure precise inputs. Stand barefoot with your back against a wall when measuring height, and weigh yourself at a consistent time each day."
      }
    ]
  },
  hi: {
    eyebrow: "स्वास्थ्य अंतर्दृष्टि",
    sections: [
      {
        title: "Lbs और Inches के साथ बीएमआई की गणना",
        text: "संयुक्त राज्य अमेरिका में, बीएमआई गणना के लिए मानक फॉर्मूला पाउंड और इंच का उपयोग करता है। हमारा पेशेवर-ग्रेड कैलकुलेटर इस प्रक्रिया को स्वचालित करता है, जो वयस्क वजन श्रेणियों के लिए सीडीसी दिशानिर्देशों के साथ संरेखित त्वरित परिणाम प्रदान करता है।"
      },
      {
        title: "बीएमआई की सीमाएं: किन बातों का ध्यान रखें",
        text: "यह समझना आवश्यक है कि बीएमआई एक नैदानिक उपकरण नहीं है। एक व्यक्ति का बीएमआई 'उच्च' हो सकता है लेकिन शरीर में वसा का प्रतिशत बहुत कम हो सकता है, जैसे कि एथलीटों के मामले में। क्योंकि मांसपेशियाँ वसा से अधिक घनी होती हैं, इसलिए बीएमआई मांसपेशियों वाले व्यक्तियों में शरीर की वसा को अधिक आंक सकता है।"
      },
      {
        title: "संख्या से परे: कमर की परिधि और स्वास्थ्य",
        text: "जबकि बीएमआई एक व्यापक अवलोकन प्रदान करता है, कई स्वास्थ्य विशेषज्ञ कमर की परिधि को एक माध्यमिक उपाय के रूप में देखने की सलाह देते हैं। पेट की वसा, जिसे अक्सर विसरल वसा कहा जाता है, अधिक चयापचय रूप से सक्रिय होती है और स्वास्थ्य जटिलताओं का उच्च जोखिम उठाती है।"
      },
      {
        title: "अपने बीएमआई स्कोर को सुरक्षित रूप से कैसे सुधारें",
        text: "एक स्वस्थ बीएमआई की ओर बढ़ना निरंतरता की यात्रा है, गति की नहीं। संतुलित आहार पर ध्यान दें जो संपूर्ण खाद्य पदार्थों, दुबले प्रोटीन और जटिल कार्बोहाइड्रेट से भरपूर हो। इसे प्रति सप्ताह कम से कम 150 मिनट की मध्यम तीव्रता वाली एरोबिक गतिविधि के साथ जोड़ें।"
      }
    ]
  },
  es: {
    eyebrow: "Información de Salud",
    sections: [
      {
        title: "Cálculo del IMC con Libras y Pulgadas",
        text: "En los Estados Unidos, la fórmula estándar utiliza libras y pulgadas. Nuestro calculador automatiza este proceso, proporcionando resultados instantáneos alineados con las guías de los CDC."
      },
      {
        title: "Las Limitaciones del IMC: Qué Tener en Cuenta",
        text: "Es esencial entender que el IMC no es una herramienta de diagnóstico. Los atletas pueden tener un IMC alto debido a la masa muscular, ya que el músculo es más denso que la grasa."
      },
      {
        title: "Más Allá del Número: Circunferencia de Cintura",
        text: "La grasa abdominal, a menudo llamada grasa visceral, es más activa metabólicamente y conlleva un mayor riesgo para la salud que la grasa almacenada en otros lugares."
      }
    ]
  },
  fr: {
    eyebrow: "Aperçus Santé",
    sections: [
      {
        title: "Pourquoi Utiliser le Calculateur Real BMI ?",
        text: "Le calculateur Real BMI fournit des mesures hautement précises en utilisant les derniers protocoles cliniques. Notre système est optimisé pour garantir des données de santé fiables instantanément."
      },
      {
        title: "Précision du Calculateur d'IMC en Livres et Pouces",
        text: "Dans le système impérial, la formule standard utilise les livres et les pouces. Notre calculateur automatise ce processus selon les recommandations des CDC."
      },
      {
        title: "Les Limites de l'IMC : Ce Qu'il Faut Savoir",
        text: "Il est essentiel de comprendre que l'IMC est un outil de dépistage. Les athlètes peuvent avoir un IMC plus élevé en raison de leur densité musculaire."
      }
    ]
  },
  de: {
    eyebrow: "Gesundheitseinblicke",
    sections: [
      {
        title: "Warum den Real BMI-Rechner Nutzen?",
        text: "Der Real BMI-Rechner bietet hochpräzise Messungen nach aktuellen klinischen Standards für sofortige und verlässliche Gesundheitsdaten."
      },
      {
        title: "Genauigkeit mit Pfund und Zoll",
        text: "Im US-System basiert die Berechnung auf Pfund und Zoll. Unser professioneller Rechner führt diesen Prozess automatisch aus."
      },
      {
        title: "Grenzen des BMI",
        text: "Der BMI ist ein Erstbeurteilungsinstrument. Bei Leistungssportlern kann Muskelmasse zu einem höheren BMI-Wert führen."
      }
    ]
  },
  ko: {
    eyebrow: "건강 인사이트",
    sections: [
      {
        title: "Real BMI 계산기를 사용하는 이유",
        text: "Real BMI 계산기는 최신 임상 프로토콜을 활용하여 정밀한 측정을 제공하며 글로벌 표준에 맞춰 신뢰할 수 있는 데이터를 제공합니다."
      },
      {
        title: "파운드 및 인치 측정의 정확도",
        text: "미국 표준 공식인 파운드와 인치 계산도 저희 계산기가 자동으로 처리하여 CDC 지침에 부합하는 결과를 산출합니다."
      },
      {
        title: "BMI의 한계점",
        text: "BMI는 단순 선별 도구입니다. 근육량이 많은 운동선수의 경우 체지방률이 낮아도 BMI 점수가 높게 나타날 수 있습니다."
      }
    ]
  }
};

const t = content[lang] || content.en;

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": t.sections[0].title,
  "description": t.sections[0].text,
  "author": {
    "@type": "Organization",
    "name": "Real BMI"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Real BMI",
    "logo": {
      "@type": "ImageObject",
      "url": "https://realbmicalculator.com/icon.svg"
    }
  },
  "datePublished": "2026-01-01",
  "dateModified": new Date().toISOString().split('T')[0]
};
---

<script is:inline type="application/ld+json" set:html={JSON.stringify(articleSchema)} />

<section class="max-w-7xl mx-auto py-16 md:py-24 px-4 sm:px-6 border-t border-[var(--border)]/60 mt-16">
    <div class="space-y-16">
        {t.sections.map((section: any) => (
            <div class="space-y-6 group">
                <div class="space-y-2">
            <div class="flex items-center gap-4">
                <span class="text-[10px] font-black uppercase tracking-[0.3em] text-[var(--accent)]">{t.eyebrow}</span>
            </div>
        </div>
        <h2 class="text-3xl font-black uppercase tracking-tighter text-[var(--foreground)] leading-tight italic">
            {section.title}
        </h2>
                <p class="text-lg text-[var(--muted-foreground)] leading-relaxed font-bold opacity-70" set:html={section.text} />
            </div>
        ))}
    </div>
</section>
