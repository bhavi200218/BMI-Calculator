---
const { currentLocale } = Astro;
const lang = currentLocale || 'en';

const content: Record<string, any> = {
  en: {
    sections: [
      {
        title: "BMI for Women vs. Men: Is There a Difference?",
        text: "While the formula for Body Mass Index remains the same for all adults, the interpretation often requires nuance. Women naturally tend to have a higher body fat percentage than men at the same BMI. For athletes, BMI can be 'high' due to muscle mass. Our premium calculator uses clinical-grade standards to help you understand these metrics in context."
      },
      {
        title: "The Science of Body Composition",
        text: "Health is more than just a number on a scale. Factors like bone density, muscle distribution, and water weight play crucial roles. A 'normal' BMI of 18.5 to 24.9 is a great starting point, but we recommend monitoring trends over time for a holistic view of your wellness journey."
      },
      {
        title: "Why Precision Matters",
        text: "Inaccurate calculations can lead to misleading health assumptions. Real BMI utilizes the latest NIH and WHO protocols to ensure every decimal point is mathematically sound. Whether you're tracking weight loss or muscle gain, precision is the foundation of progress."
      }
    ]
  },
  es: {
    sections: [
      {
        title: "IMC para Mujeres vs. Hombres: ¿Hay Diferencia?",
        text: "Aunque la fórmula del Índice de Masa Corporal sigue siendo la misma para todos los adultos, la interpretación a menudo requiere matices. Las mujeres tienden naturalmente a tener un mayor porcentaje de grasa corporal que los hombres con el mismo IMC. Para los atletas, el IMC puede ser 'alto' debido a la masa muscular."
      },
      {
        title: "La Ciencia de la Composición Corporal",
        text: "La salud es más que un número en una báscula. Factores como la densidad ósea, la distribución muscular y el peso del agua juegan papeles cruciales. Un IMC 'normal' de 18.5 a 24.9 es un excelente punto de partida."
      },
      {
        title: "Por Qué Importa la Precisión",
        text: "Los cálculos inexactos pueden llevar a suposiciones de salud engañosas. Real BMI utiliza los últimos protocolos de la OMS para garantizar que cada punto decimal sea matemáticamente sólido."
      }
    ]
  },
  fr: {
    sections: [
      {
        title: "IMC pour Femmes vs Hommes : Quelle Différence ?",
        text: "Bien que la formule de l'Indice de Masse Corporelle reste la même pour tous les adultes, l'interprétation nécessite souvent de la nuance. Les femmes ont naturellement tendance à avoir un pourcentage de graisse corporelle plus élevé que les hommes à IMC égal."
      },
      {
        title: "La Science de la Composition Corporelle",
        text: "La santé est bien plus qu'un simple chiffre sur une balance. Des facteurs tels que la densité osseuse, la répartition musculaire et le poids de l'eau jouent des rôles cruciaux."
      },
      {
        title: "Pourquoi la Précision est Essentielle",
        text: "Des calculs imprécis peuvent mener à des conclusions erronées sur la santé. Real BMI utilise les derniers protocoles de l'OMS pour garantir une précision mathématique totale."
      }
    ]
  },
  de: {
    sections: [
      {
        title: "BMI für Frauen vs. Männer: Gibt es einen Unterschied?",
        text: "Obwohl die Formel für den Body-Mass-Index für alle Erwachsenen gleich bleibt, erfordert die Interpretation oft Nuancen. Frauen haben bei gleichem BMI von Natur aus tendenziell einen höheren Körperfettanteil als Männer."
      },
      {
        title: "Die Wissenschaft der Körperzusammensetzung",
        text: "Gesundheit ist mehr als nur eine Zahl auf der Waage. Faktoren wie Knochendichte, Muskelverteilung und Wassergewicht spielen eine entscheidende Rolle."
      },
      {
        title: "Warum Präzision wichtig ist",
        text: "Ungenaue Berechnungen können zu irreführenden Gesundheitsannahmen führen. Real BMI nutzt die neuesten WHO-Protokolle, um sicherzustellen, dass jede Dezimalstelle mathematisch fundiert ist."
      }
    ]
  },
  ko: {
    sections: [
      {
        title: "여성 vs 남성 BMI: 차이가 있나요?",
        text: "체질량지수 공식은 모든 성인에게 동일하지만 해석에는 미묘한 차이가 필요합니다. 여성은 동일한 BMI에서 남성보다 체지방률이 높은 경향이 있습니다. 운동선수의 경우 근육량으로 인해 BMI가 '높게' 나올 수 있습니다."
      },
      {
        title: "체성분의 과학",
        text: "건강은 단순히 체중계의 숫자 그 이상입니다. 골밀도, 근육 분포, 수분 무게와 같은 요인들이 중요한 역할을 합니다. 18.5에서 24.9 사이의 '정상' BMI는 좋은 시작점입니다."
      },
      {
        title: "정밀도가 중요한 이유",
        text: "부정확한 계산은 오해의 소지가 있는 건강 가정을 초래할 수 있습니다. Real BMI는 최신 WHO 프로토콜을 사용하여 모든 소수점이 수학적으로 정확하도록 보장합니다."
      }
    ]
  },
  hi: {
    sections: [
      {
        title: "महिलाओं बनाम पुरुषों के लिए बीएमआई: क्या कोई अंतर है?",
        text: "जबकि बॉडी मास इंडेक्स का फॉर्मूला सभी वयस्कों के लिए समान रहता है, व्याख्या में अक्सर सूक्ष्मता की आवश्यकता होती है। महिलाओं में समान बीएमआई पर पुरुषों की तुलना में शरीर में वसा का प्रतिशत अधिक होता है।"
      },
      {
        title: "शरीर की संरचना का विज्ञान",
        text: "स्वास्थ्य केवल तराजू पर एक संख्या से कहीं अधिक है। हड्डियों का घनत्व, मांसपेशियों का वितरण और पानी का वजन जैसे कारक महत्वपूर्ण भूमिका निभाते हैं।"
      },
      {
        title: "सटीकता क्यों मायने रखती है",
        text: "गलत गणना भ्रामक स्वास्थ्य धारणाओं का कारण बन सकती है। Real BMI यह सुनिश्चित करने के लिए नवीनतम WHO प्रोटोकॉल का उपयोग करता है कि प्रत्येक दशमलव बिंदु गणितीय रूप से सही है।"
      }
    ]
  }
};

const t = content[lang] || content.en;

// Article Schema for SEO
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": t.sections[0].title,
  "description": t.sections[0].text,
  "author": {
    "@type": "Organization",
    "name": "Real BMI"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Real BMI",
    "logo": {
      "@type": "ImageObject",
      "url": "https://realbmicalculator.com/icon.svg"
    }
  },
  "datePublished": "2026-01-01",
  "dateModified": new Date().toISOString().split('T')[0]
};
---

<script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />

<section class="max-w-4xl mx-auto py-24 px-6 border-t border-[var(--border)] mt-20">
    <div class="grid gap-16">
        {t.sections.map((section: any) => (
            <div class="space-y-6 group">
                <div class="inline-block w-12 h-1 bg-[var(--accent)] mb-4 transform origin-left group-hover:scale-x-150 transition-transform duration-500"></div>
                <h2 class="text-2xl md:text-3xl font-black uppercase tracking-tighter text-[var(--foreground)] group-hover:text-[var(--accent)] transition-colors">
                    {section.title}
                </h2>
                <p class="text-base md:text-lg text-[var(--muted-foreground)] leading-relaxed font-medium opacity-80">
                    {section.text}
                </p>
            </div>
        ))}
    </div>

    <!-- SEO Strategic Internal Links -->
    <div class="mt-24 pt-12 border-t border-[var(--border)] grid md:grid-cols-3 gap-8">
        <div class="space-y-2">
            <span class="text-[10px] font-black uppercase tracking-[0.3em] opacity-30">Resources</span>
            <ul class="space-y-1">
                <li><a href="#calculator" class="text-xs font-bold hover:text-[var(--accent)] transition-colors">BMI Calculator</a></li>
                <li><a href="#insights" class="text-xs font-bold hover:text-[var(--accent)] transition-colors">Health Insights</a></li>
                <li><a href="#faq" class="text-xs font-bold hover:text-[var(--accent)] transition-colors">Common Questions</a></li>
            </ul>
        </div>
        <div class="space-y-2">
            <span class="text-[10px] font-black uppercase tracking-[0.3em] opacity-30">Global Standars</span>
            <p class="text-[10px] font-bold opacity-50 leading-loose">
                Calculated using NIH (National Institutes of Health) and WHO (World Health Organization) clinical guidelines.
            </p>
        </div>
        <div class="space-y-2">
            <span class="text-[10px] font-black uppercase tracking-[0.3em] opacity-30">Verified</span>
            <div class="flex items-center gap-2">
                <div class="w-2 h-2 rounded-full bg-green-500"></div>
                <span class="text-[10px] font-black uppercase tracking-widest">Clinical Accuracy</span>
            </div>
        </div>
    </div>
</section>

<style>
    /* Premium accents */
    section {
        background: radial-gradient(circle at 0% 0%, rgba(var(--accent-rgb), 0.03) 0%, transparent 50%);
    }
</style>
