---
const { currentLocale } = Astro;
const lang = currentLocale || 'en';

const content: Record<string, any> = {
  en: {
    sections: [
      {
        title: "Calculating BMI with Lbs and Inches",
        text: "In the United States, the standard formula for BMI calculation uses pounds and inches: (weight (lb) / [height (in)]² ) x 703. While the math can be tedious, our professional-grade calculator automates this process, providing instant results that align with CDC guidelines for adult weight categories."
      },
      {
        title: "The Limitations of BMI: What to Watch Out For",
        text: "It is essential to understand that BMI is not a diagnostic tool. A person may have a 'high' BMI but have a very low body fat percentage, such as with elite athletes and bodybuilders. Because muscle is denser than fat, BMI may overestimate body fat in highly muscular individuals. Conversely, it might underestimate body fat in older persons or those who have lost muscle mass (sarcopenia)."
      },
      {
        title: "Beyond the Number: Waist Circumference and Health",
        text: "While BMI provides a broad overview, many health experts recommend looking at waist circumference as a secondary measure. Abdominal fat, often called visceral fat, is more metabolically active and carries a higher risk for health complications than fat stored elsewhere. If your BMI is in the overweight range, but your waist circumference is within healthy limits, your overall risk might be lower."
      },
      {
        title: "How to Improve Your BMI Score Safely",
        text: "Transitioning to a healthier BMI is a journey of consistency, not speed. Focus on a balanced diet rich in whole foods, lean proteins, and complex carbohydrates. Combine this with at least 150 minutes of moderate-intensity aerobic activity per week, such as brisk walking or swimming. Strength training is also vital, as it builds muscle mass, which increases your basal metabolic rate (BMR)."
      },
      {
        title: "BMI in Elderly Populations",
        text: "As we age, our body composition naturally changes. For individuals over the age of 65, a slightly higher BMI (between 23 and 27) may actually be beneficial, as it provides a nutritional reserve during illness and helps protect against bone fractures and osteoporosis. Our adult BMI calculator is designed to provide perspective for all age groups."
      },
      {
        title: "Getting the Most Accurate Measurements",
        text: "To get the most out of Real BMI, accuracy in your input is key. For height, stand barefoot with your back against a wall and heels touching the corner. For weight, measure yourself first thing in the morning after using the bathroom but before eating breakfast. Consistency ensures that the trends you see are reflective of real changes."
      }
    ]
  },
  hi: {
    sections: [
      {
        title: "Lbs और Inches के साथ बीएमआई की गणना",
        text: "संयुक्त राज्य अमेरिका में, बीएमआई गणना के लिए मानक फॉर्मूला पाउंड और इंच का उपयोग करता है। हमारा पेशेवर-ग्रेड कैलकुलेटर इस प्रक्रिया को स्वचालित करता है, जो वयस्क वजन श्रेणियों के लिए सीडीसी दिशानिर्देशों के साथ संरेखित त्वरित परिणाम प्रदान करता है।"
      },
      {
        title: "बीएमआई की सीमाएं: किन बातों का ध्यान रखें",
        text: "यह समझना आवश्यक है कि बीएमआई एक नैदानिक उपकरण नहीं है। एक व्यक्ति का बीएमआई 'उच्च' हो सकता है लेकिन शरीर में वसा का प्रतिशत बहुत कम हो सकता है, जैसे कि एथलीटों के मामले में। क्योंकि मांसपेशियाँ वसा से अधिक घनी होती हैं, इसलिए बीएमआई मांसपेशियों वाले व्यक्तियों में शरीर की वसा को अधिक आंक सकता है।"
      },
      {
        title: "संख्या से परे: कमर की परिधि और स्वास्थ्य",
        text: "जबकि बीएमआई एक व्यापक अवलोकन प्रदान करता है, कई स्वास्थ्य विशेषज्ञ कमर की परिधि को एक माध्यमिक उपाय के रूप में देखने की सलाह देते हैं। पेट की वसा, जिसे अक्सर विसरल वसा कहा जाता है, अधिक चयापचय रूप से सक्रिय होती है और स्वास्थ्य जटिलताओं का उच्च जोखिम उठाती है।"
      },
      {
        title: "अपने बीएमआई स्कोर को सुरक्षित रूप से कैसे सुधारें",
        text: "एक स्वस्थ बीएमआई की ओर बढ़ना निरंतरता की यात्रा है, गति की नहीं। संतुलित आहार पर ध्यान दें जो संपूर्ण खाद्य पदार्थों, दुबले प्रोटीन और जटिल कार्बोहाइड्रेट से भरपूर हो। इसे प्रति सप्ताह कम से कम 150 मिनट की मध्यम तीव्रता वाली एरोबिक गतिविधि के साथ जोड़ें।"
      }
    ]
  },
  es: {
    sections: [
      {
        title: "Cálculo del IMC con Libras y Pulgadas",
        text: "En los Estados Unidos, la fórmula estándar utiliza libras y pulgadas. Nuestro calculador automatiza este proceso, proporcionando resultados instantáneos alineados con las guías de los CDC."
      },
      {
        title: "Las Limitaciones del IMC: Qué Tener en Cuenta",
        text: "Es esencial entender que el IMC no es una herramienta de diagnóstico. Los atletas pueden tener un IMC alto debido a la masa muscular, ya que el músculo es más denso que la grasa."
      },
      {
        title: "Más Allá del Número: Circunferencia de Cintura",
        text: "La grasa abdominal, a menudo llamada grasa visceral, es más activa metabólicamente y conlleva un mayor riesgo para la salud que la grasa almacenada en otros lugares."
      }
    ]
  }
};

// Simplified fallbacks for other languages to keep the code clean
const t = content[lang] || content.en;

// Article Schema for SEO
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": t.sections[0].title,
  "description": t.sections[0].text,
  "author": {
    "@type": "Organization",
    "name": "Real BMI"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Real BMI",
    "logo": {
      "@type": "ImageObject",
      "url": "https://realbmicalculator.com/icon.svg"
    }
  },
  "datePublished": "2026-01-01",
  "dateModified": new Date().toISOString().split('T')[0]
};
---

<script is:inline type="application/ld+json" set:html={JSON.stringify(articleSchema)} />

<section class="max-w-4xl mx-auto py-24 px-6 border-t border-[var(--border)] mt-20 bg-linear-to-b from-[var(--muted)]/30 to-transparent rounded-[3rem]">
    <div class="space-y-16">
        {t.sections.map((section: any) => (
            <div class="space-y-6 group">
                <div class="w-12 h-1 bg-[var(--accent)] mb-6 transform transition-transform group-hover:scale-x-150"></div>
                <h2 class="text-3xl font-black uppercase tracking-tighter text-[var(--foreground)] leading-none italic">
                    {section.title}
                </h2>
                <p class="text-lg text-[var(--muted-foreground)] leading-relaxed font-bold opacity-70">
                    {section.text}
                </p>
            </div>
        ))}
    </div>

    <!-- SEO Strategic Internal Links -->
    <div class="mt-24 pt-12 border-t border-[var(--border)] grid md:grid-cols-3 gap-12">
        <div class="space-y-4">
            <span class="text-[10px] font-black uppercase tracking-[0.4em] text-[var(--accent)]">Navigation</span>
            <ul class="space-y-3">
                <li><a href="#calculator" class="text-xs font-black uppercase tracking-widest hover:translate-x-2 transition-transform inline-block">BMI Calculator</a></li>
                <li><a href="#insights" class="text-xs font-black uppercase tracking-widest hover:translate-x-2 transition-transform inline-block">Health Insights</a></li>
                <li><a href="#faq" class="text-xs font-black uppercase tracking-widest hover:translate-x-2 transition-transform inline-block">FAQ Section</a></li>
            </ul>
        </div>
        <div class="space-y-4">
            <span class="text-[10px] font-black uppercase tracking-[0.4em] text-[var(--accent)]">Standards</span>
            <p class="text-[10px] font-black uppercase leading-loose opacity-40">
                Adhering to WHO and CDC clinical protocols for global health data accuracy.
            </p>
        </div>
        <div class="space-y-4">
            <span class="text-[10px] font-black uppercase tracking-[0.4em] text-[var(--accent)]">Authority</span>
            <div class="flex items-center gap-3">
                <div class="w-3 h-3 rounded-full bg-[var(--accent)] animate-pulse"></div>
                <span class="text-[10px] font-black uppercase tracking-[0.2em]">Verified Methodology</span>
            </div>
        </div>
    </div>
</section>
