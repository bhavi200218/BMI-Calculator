---
const { currentLocale } = Astro;
const lang = currentLocale || 'en';

const content: Record<string, any> = {
  en: {
    sections: [
      {
        title: "Why Use the Real BMI Calculator?",
        text: "The Real BMI Calculator provides highly precise measurements by utilizing the latest clinical protocols. Unlike generic tools, our system is optimized for accuracy across global standards, ensuring you get the most reliable health data instantly. This classification follows the official guidelines established by the <b><u>World Health Organization (WHO)</u></b> and the <b><u>CDC</u></b> for global health assessment."
      },
      {
        title: "Accuracy of the BMI Calculator with Lbs and Inches",
        text: "In the United States, the standard formula for BMI calculation uses pounds and inches: (weight (lb) / [height (in)]² ) x 703. While the math can be tedious, our professional-grade Real BMI Calculator automates this process, providing results that align perfectly with CDC guidelines. This classification follows the official guidelines established by the <b><u>World Health Organization (WHO)</u></b> and the <b><u>CDC</u></b> for global health assessment."
      },
      {
        title: "The Real Limitations of BMI: What to Watch Out For",
        text: "It is essential to understand that BMI is not a diagnostic tool. A person may have a 'high' BMI but have a very low body fat percentage, such as with elite athletes. Because muscle is denser than fat, the Real BMI tool helps provide context alongside other health metrics. This classification follows the official guidelines established by the <b><u>World Health Organization (WHO)</u></b> and the <b><u>CDC</u></b> for global health assessment."
      },
      {
        title: "How to Improve Your BMI Score Safely",
        text: "Transitioning to a healthier BMI is a journey of consistency. Focus on a balanced diet rich in whole foods and complex carbohydrates. Combine this with regular aerobic activity to optimize your health data on the Real BMI Dashboard. This classification follows the official guidelines established by the <b><u>World Health Organization (WHO)</u></b> and the <b><u>CDC</u></b> for global health assessment."
      },
      {
        title: "Getting the Most Accurate Measurements",
        text: "To get the most out of our Real BMI Calculator, accuracy in your input is key. For height, stand barefoot with your back against a wall. Consistency ensures that the trends you see are reflective of real health changes. This classification follows the official guidelines established by the <b><u>World Health Organization (WHO)</u></b> and the <b><u>CDC</u></b> for global health assessment."
      }
    ]
  },
  hi: {
    sections: [
      {
        title: "Lbs और Inches के साथ बीएमआई की गणना",
        text: "संयुक्त राज्य अमेरिका में, बीएमआई गणना के लिए मानक फॉर्मूला पाउंड और इंच का उपयोग करता है। हमारा पेशेवर-ग्रेड कैलकुलेटर इस प्रक्रिया को स्वचालित करता है, जो वयस्क वजन श्रेणियों के लिए सीडीसी दिशानिर्देशों के साथ संरेखित त्वरित परिणाम प्रदान करता है।"
      },
      {
        title: "बीएमआई की सीमाएं: किन बातों का ध्यान रखें",
        text: "यह समझना आवश्यक है कि बीएमआई एक नैदानिक उपकरण नहीं है। एक व्यक्ति का बीएमआई 'उच्च' हो सकता है लेकिन शरीर में वसा का प्रतिशत बहुत कम हो सकता है, जैसे कि एथलीटों के मामले में। क्योंकि मांसपेशियाँ वसा से अधिक घनी होती हैं, इसलिए बीएमआई मांसपेशियों वाले व्यक्तियों में शरीर की वसा को अधिक आंक सकता है।"
      },
      {
        title: "संख्या से परे: कमर की परिधि और स्वास्थ्य",
        text: "जबकि बीएमआई एक व्यापक अवलोकन प्रदान करता है, कई स्वास्थ्य विशेषज्ञ कमर की परिधि को एक माध्यमिक उपाय के रूप में देखने की सलाह देते हैं। पेट की वसा, जिसे अक्सर विसरल वसा कहा जाता है, अधिक चयापचय रूप से सक्रिय होती है और स्वास्थ्य जटिलताओं का उच्च जोखिम उठाती है।"
      },
      {
        title: "अपने बीएमआई स्कोर को सुरक्षित रूप से कैसे सुधारें",
        text: "एक स्वस्थ बीएमआई की ओर बढ़ना निरंतरता की यात्रा है, गति की नहीं। संतुलित आहार पर ध्यान दें जो संपूर्ण खाद्य पदार्थों, दुबले प्रोटीन और जटिल कार्बोहाइड्रेट से भरपूर हो। इसे प्रति सप्ताह कम से कम 150 मिनट की मध्यम तीव्रता वाली एरोबिक गतिविधि के साथ जोड़ें।"
      }
    ]
  },
  es: {
    sections: [
      {
        title: "Cálculo del IMC con Libras y Pulgadas",
        text: "En los Estados Unidos, la fórmula estándar utiliza libras y pulgadas. Nuestro calculador automatiza este proceso, proporcionando resultados instantáneos alineados con las guías de los CDC."
      },
      {
        title: "Las Limitaciones del IMC: Qué Tener en Cuenta",
        text: "Es esencial entender que el IMC no es una herramienta de diagnóstico. Los atletas pueden tener un IMC alto debido a la masa muscular, ya que el músculo es más denso que la grasa."
      },
      {
        title: "Más Allá del Número: Circunferencia de Cintura",
        text: "La grasa abdominal, a menudo llamada grasa visceral, es más activa metabólicamente y conlleva un mayor riesgo para la salud que la grasa almacenada en otros lugares."
      }
    ]
  }
};

const t = content[lang] || content.en;

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": t.sections[0].title,
  "description": t.sections[0].text,
  "author": {
    "@type": "Organization",
    "name": "Real BMI"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Real BMI",
    "logo": {
      "@type": "ImageObject",
      "url": "https://realbmicalculator.com/icon.svg"
    }
  },
  "datePublished": "2026-01-01",
  "dateModified": new Date().toISOString().split('T')[0]
};
---

<script is:inline type="application/ld+json" set:html={JSON.stringify(articleSchema)} />

<section class="max-w-7xl mx-auto py-24 px-6 border-t border-[var(--border)] mt-20 bg-linear-to-b from-[var(--muted)]/30 to-transparent rounded-[3rem]">
    <div class="space-y-16">
        {t.sections.map((section: any) => (
            <div class="space-y-6 group">
                <div class="flex items-center gap-4">
                    <div class="w-12 h-1 bg-[var(--accent)] transform transition-transform group-hover:scale-x-150 origin-left"></div>
                    <span class="text-[10px] font-black uppercase tracking-[0.3em] text-[var(--accent)]">Health Insights</span>
                </div>
                <h2 class="text-3xl font-black uppercase tracking-tighter text-[var(--foreground)] leading-none italic">
                    {section.title}
                </h2>
                <p class="text-lg text-[var(--muted-foreground)] leading-relaxed font-bold opacity-70" set:html={section.text} />
            </div>
        ))}
    </div>
</section>
