---
import type { Locale } from '../utils/calculators';
import { calculators, getCalculatorTranslations } from '../utils/calculators';
import UniversalCalculator from './UniversalCalculator.astro';
import CalculatorResult from './CalculatorResult.astro';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = getCalculatorTranslations(lang);



const categoryLabels = {
  all: { en: 'All Tools', es: 'Todas las Herramientas', fr: 'Tous les Outils', de: 'Alle Tools', ko: '모든 도구', hi: 'सभी उपकरण' },
  weight: { en: 'Weight & Body Composition', es: 'Peso y Composición', fr: 'Poids et Composition', de: 'Gewicht & Körperzusammensetzung', ko: '체중 및 체성분', hi: 'वजन और शरीर रचना' },
  metabolism: { en: 'Metabolism & Energy', es: 'Metabolismo y Energía', fr: 'Métabolisme et Énergie', de: 'Stoffwechsel & Energie', ko: '대사 및 에너지', hi: 'चयापचय और ऊर्जा' },
  fitness: { en: 'Fitness & Performance', es: 'Fitness y Rendimiento', fr: 'Fitness et Performance', de: 'Fitness & Leistung', ko: '피트니스 및 성과', hi: 'फिटनेस और प्रदर्शन' },

};

const getCategory = (slug: string) => {
  if (['bmi-calculator','body-fat-calculator','lean-body-mass-calculator','ideal-weight-calculator','waist-to-hip-ratio-calculator','body-surface-area-calculator'].includes(slug)) return 'weight';
  if (['bmr-calculator','tdee-calculator','calorie-calculator','protein-intake-calculator','water-intake-calculator','macro-calculator'].includes(slug)) return 'metabolism';
  if (['heart-rate-zone-calculator','one-rep-max-calculator'].includes(slug)) return 'fitness';

  return 'weight';
};

type CategoryKey = 'all' | 'weight' | 'metabolism' | 'fitness';
const getIcon = (slug: string): string => {
  return '';
};
const groupTitles: Record<string, Record<string, string>> = {
  core: { en: 'Core Calculators', es: 'Calculadoras Principales', fr: 'Calculateurs Principaux', de: 'Haupt-Rechner', ko: '핵심 계산기', hi: 'मुख्य कैलकुलेटर' },
  performance: { en: 'Performance & Goals', es: 'Rendimiento y Objetivos', fr: 'Performance et Objectifs', de: 'Leistung & Ziele', ko: '성능 및 목표', hi: 'प्रदर्शन और लक्ष्य' },
  specialty: { en: 'Specialty Metrics', es: 'Métricas Especializadas', fr: 'Métriques Spécialisées', de: 'Spezial-Messwerte', ko: '전문 지표', hi: 'विशेषता मेट्रिक्स' }
};

const gTitle = {
  core: groupTitles.core[lang] || groupTitles.core.en,
  performance: groupTitles.performance[lang] || groupTitles.performance.en,
  specialty: groupTitles.specialty[lang] || groupTitles.specialty.en,
};
const selectCalcLabels: Record<string, string> = {
  en: '-- Select a Calculator --',
  es: '-- Selecciona una Calculadora --',
  fr: '-- Choisissez un Calculateur --',
  de: '-- Rechner Auswählen --',
  ko: '-- 계산기 선택 --',
  hi: '-- एक कैलकुलेटर चुनें --',
};
const tSelectCalc = selectCalcLabels[lang] || selectCalcLabels.en;
---

<div class="space-y-6 animate-in" style="animation-delay: 150ms;">
  
    <!-- Mobile Dropdown Selector -->
    <div class="block md:hidden relative">
      <select id="calculatorDropdownSelector" class="matte-input w-full px-4 py-3.5 text-base font-bold rounded-[var(--radius-sm)] cursor-pointer h-[56px] border-[1.5px] border-[var(--border)] bg-[var(--input)] text-[var(--foreground)]">
        <option value="" disabled selected>{tSelectCalc}</option>
        {calculators.map(calc => (
          <option value={calc.slug}>
            {calc.name[lang] || calc.name['en']}
          </option>
        ))}
      </select>
    </div>

    <!-- Horizontal Pill Scrollbar / Grid for Desktops (grouped with icons) -->
    <div class="hidden md:block space-y-5">
      <div class="calc-group space-y-3">
        <div class="text-xs font-display font-bold uppercase tracking-[0.2em] text-[var(--accent)]">{gTitle.core}</div>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-3">
          {calculators.filter(c=>['bmi-calculator','bmr-calculator','tdee-calculator','body-fat-calculator','lean-body-mass-calculator'].includes(c.slug)).map(calc => (
            <button
              data-slug={calc.slug}
              data-category={getCategory(calc.slug)}
              data-search={(calc.name[lang] || calc.name['en']) + ' ' + (calc.description[lang] || calc.description['en'])}
              class="calc-tab-btn flex items-center justify-center h-14 rounded-xl border border-[var(--border)] bg-[var(--card)] text-[var(--muted-foreground)] hover:border-[var(--accent)] hover:bg-[var(--muted)] hover:text-[var(--foreground)] transition-all duration-300 px-4 py-3 cursor-pointer shadow-xs"
            >
              <span class="text-sm md:text-base font-display font-bold uppercase text-center text-[var(--foreground)] tracking-wide">
                {calc.name[lang] || calc.name['en']}
              </span>
            </button>
          ))}
        </div>
      </div>

      <div class="calc-group space-y-3">
        <div class="text-xs font-display font-bold uppercase tracking-[0.2em] text-[var(--accent)]">{gTitle.performance}</div>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-3">
          {calculators.filter(c=>['ideal-weight-calculator','calorie-calculator','protein-intake-calculator','water-intake-calculator','macro-calculator'].includes(c.slug)).map(calc => (
            <button
              data-slug={calc.slug}
              data-category={getCategory(calc.slug)}
              data-search={(calc.name[lang] || calc.name['en']) + ' ' + (calc.description[lang] || calc.description['en'])}
              class="calc-tab-btn flex items-center justify-center h-14 rounded-xl border border-[var(--border)] bg-[var(--card)] text-[var(--muted-foreground)] hover:border-[var(--accent)] hover:bg-[var(--muted)] hover:text-[var(--foreground)] transition-all duration-300 px-4 py-3 cursor-pointer shadow-xs"
            >
              <span class="text-sm md:text-base font-display font-bold uppercase text-center text-[var(--foreground)] tracking-wide">
                {calc.name[lang] || calc.name['en']}
              </span>
            </button>
          ))}
        </div>
      </div>

      <div class="calc-group space-y-3">
        <div class="text-xs font-display font-bold uppercase tracking-[0.2em] text-[var(--accent)]">{gTitle.specialty}</div>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-3">
          {calculators.filter(c=>['waist-to-hip-ratio-calculator','body-surface-area-calculator','heart-rate-zone-calculator','one-rep-max-calculator','pregnancy-weight-gain-calculator'].includes(c.slug)).map(calc => (
            <button
              data-slug={calc.slug}
              data-category={getCategory(calc.slug)}
              data-search={(calc.name[lang] || calc.name['en']) + ' ' + (calc.description[lang] || calc.description['en'])}
              class="calc-tab-btn flex items-center justify-center h-14 rounded-xl border border-[var(--border)] bg-[var(--card)] text-[var(--muted-foreground)] hover:border-[var(--accent)] hover:bg-[var(--muted)] hover:text-[var(--foreground)] transition-all duration-300 px-4 py-3 cursor-pointer shadow-xs"
            >
              <span class="text-sm md:text-base font-display font-bold uppercase text-center text-[var(--foreground)] tracking-wide">
                {calc.name[lang] || calc.name['en']}
              </span>
            </button>
          ))}
        </div>
      </div>
    </div>

  <!-- Main Calculator Form & Result Studio Layout (Hidden by default) -->
  <div id="calculatorFormGrid" class="hidden grid lg:grid-cols-2 gap-6 md:gap-8 items-stretch pt-6 border-t border-[var(--border)]/40 scroll-mt-28">
    <!-- Calculator Forms Container -->
    <div class="relative w-full">
      {calculators.map(calc => (
        <div 
          id={`calc-wrapper-${calc.slug}`} 
          class="calc-wrapper-item w-full hidden"
        >
          <UniversalCalculator calculator={calc} lang={lang} />
        </div>
      ))}
    </div>

    <!-- Result Studio (Unified) -->
    <div class="h-full">
      <CalculatorResult lang={lang} />
    </div>
  </div>

</div>

<style>
  .calc-tab-btn {
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }
</style>

<script is:inline>
  (function() {
    let activeSlug = null;
    let activeCategory = 'all';
    let searchQuery = '';

    function updateToolVisibility() {
      const query = searchQuery.trim().toLowerCase();
      let visibleCount = 0;

      document.querySelectorAll('.calc-group').forEach(group => {
        let groupVisible = 0;
        group.querySelectorAll('.calc-tab-btn').forEach(button => {
          const matchesQuery = !query || (button.getAttribute('data-search') || '').toLowerCase().includes(query);
          const matchesCategory = activeCategory === 'all' || button.getAttribute('data-category') === activeCategory;
          const shouldShow = matchesQuery && matchesCategory;
          button.classList.toggle('hidden', !shouldShow);
          if (shouldShow) groupVisible += 1;
        });
        group.classList.toggle('hidden', groupVisible === 0);
        if (groupVisible > 0) visibleCount += 1;
      });

      const emptyState = document.getElementById('toolFilterEmptyState');
      if (emptyState) emptyState.classList.toggle('hidden', visibleCount > 0);
    }

    function switchCalculator(slug) {
      if (!slug) return;

      const gridContainer = document.getElementById('calculatorFormGrid');
      if (gridContainer) {
        gridContainer.classList.remove('hidden');
      }

      // Hide old one
      if (activeSlug) {
        const oldWrapper = document.getElementById('calc-wrapper-' + activeSlug);
        if (oldWrapper) oldWrapper.classList.add('hidden');
      }

      // Show new one
      const newWrapper = document.getElementById('calc-wrapper-' + slug);
      if (newWrapper) {
        newWrapper.classList.remove('hidden');
      }

      // Update Desktop Tabs visual state
      const tabs = document.querySelectorAll('.calc-tab-btn');
      tabs.forEach(tab => {
        const tabSlug = tab.getAttribute('data-slug');
        if (tabSlug === slug) {
          tab.classList.add('border-[var(--accent)]', 'bg-[var(--accent)]/10', 'text-[var(--foreground)]', 'shadow-[var(--shadow-accent)]');
          tab.classList.remove('border-[var(--border)]', 'bg-[var(--card)]', 'text-[var(--muted-foreground)]');
        } else {
          tab.classList.remove('border-[var(--accent)]', 'bg-[var(--accent)]/10', 'text-[var(--foreground)]', 'shadow-[var(--shadow-accent)]');
          tab.classList.add('border-[var(--border)]', 'bg-[var(--card)]', 'text-[var(--muted-foreground)]');
        }
      });

      // Sync Mobile Dropdown selection
      const dropdown = document.getElementById('calculatorDropdownSelector');
      if (dropdown) {
        dropdown.value = slug;
      }

      // Reset result studio state to waiting if switching tools
      if (slug !== activeSlug) {
        window.dispatchEvent(new CustomEvent('calculationCompleted', { detail: null }));
      }

      activeSlug = slug;

      // Scroll smoothly to form grid if not already in view
      if (gridContainer) {
        setTimeout(() => {
          gridContainer.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }, 80);
      }
    }

    // Set Up Desktop Tab Listeners
    const tabs = document.querySelectorAll('.calc-tab-btn');
    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const slug = tab.getAttribute('data-slug');
        switchCalculator(slug);
      });
    });

    document.querySelectorAll('.category-filter-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        activeCategory = btn.getAttribute('data-category-filter') || 'all';
        document.querySelectorAll('.category-filter-btn').forEach(b => b.classList.remove('border-[var(--accent)]', 'text-[var(--foreground)]'));
        btn.classList.add('border-[var(--accent)]', 'text-[var(--foreground)]');
        updateToolVisibility();
      });
    });

    const searchInput = document.getElementById('calculatorSearch');
    if (searchInput) {
      searchInput.addEventListener('input', (e) => {
        searchQuery = e.target.value;
        updateToolVisibility();
      });
    }

    // Set Up Mobile Dropdown Listener
    const dropdown = document.getElementById('calculatorDropdownSelector');
    if (dropdown) {
      dropdown.addEventListener('change', (e) => {
        switchCalculator(e.target.value);
      });
    }

    updateToolVisibility();
  })();
</script>
