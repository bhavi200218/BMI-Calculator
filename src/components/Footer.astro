const ft = footerTranslations[lang] || footerTranslations.en;
const healthToolsLabel = ft.healthTools || 'Health Tools';
const toolColors = ['bg-[var(--accent)]','bg-blue-500','bg-green-500','bg-purple-500','bg-orange-500','bg-pink-500','bg-sky-500','bg-emerald-500','bg-amber-500','bg-violet-500','bg-cyan-500','bg-fuchsia-500','bg-lime-500','bg-rose-500','bg-indigo-500'];
const healthToolsLinks = calculators.map((calc, index) => ({
  name: calc.name[lang] || calc.name['en'],
  href: `/${lang}/${calc.slug}`,
  color: toolColors[index % toolColors.length]
}));
---

<footer class="bg-[var(--muted)]/40 mt-10">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

    <!-- Top row: brand + links -->
    <div class="grid gap-8 lg:grid-cols-[220px_minmax(320px,1fr)_240px] items-start mb-4">

      <!-- Brand block -->
      <div class="space-y-3">
        <div class="flex items-center gap-2">
          <div class="w-7 h-7 rounded-lg bg-[var(--accent)] flex items-center justify-center">
            <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5v-9l6 4.5-6 4.5z"/>
            </svg>
          </div>
          <span class="font-display font-bold text-sm uppercase tracking-tight text-[var(--foreground)]">Real BMI</span>
        </div>
        <p class="mt-2 text-sm text-[var(--muted-foreground)] leading-snug font-medium max-w-[220px]">
          {ft.tagline}
        </p>
      </div>

      <div class="space-y-3">
        <p class="text-xs sm:text-sm font-display font-bold uppercase tracking-[0.2em] text-[var(--foreground)]">{healthToolsLabel}</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-2">
          {healthToolsLinks.map(link => (
            <a href={link.href} class="text-sm font-semibold text-[var(--muted-foreground)] hover:text-[var(--accent)] transition-colors duration-200 truncate">
              {link.name}
            </a>
          ))}
        </div>
      </div>

      <div class="space-y-3">
        <p class="text-xs sm:text-sm font-display font-bold uppercase tracking-[0.2em] text-[var(--foreground)]">{ft.quickLinks}</p>
        <div class="grid gap-2">
          {ft.links.map(link => (
            <a href={link.href} class="text-sm font-semibold text-[var(--muted-foreground)] hover:text-[var(--accent)] transition-colors duration-200">
              {link.name}
            </a>
          ))}
        </div>
        {ft.legalText ? (
          <div class="space-y-3 pt-4">
            <p class="text-xs sm:text-sm font-display font-bold uppercase tracking-[0.2em] text-[var(--foreground)]">{ft.legalStatus}</p>
            <p class="text-sm sm:text-base text-[var(--muted-foreground)] leading-relaxed font-medium">
              {ft.legalText}
            </p>
          </div>
        ) : null}
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="pt-6 flex flex-col sm:flex-row items-center justify-between gap-3 text-sm text-[var(--muted-foreground)]">
      <p class="font-semibold uppercase tracking-[0.2em]">{ft.copyright}</p>
      <span class="font-medium text-[0.95rem]">Built with privacy-first health analytics.</span>
    </div>
  </div>
</footer>
