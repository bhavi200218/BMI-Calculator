---
const year = new Date().getFullYear();
const { currentLocale } = Astro;
const lang = currentLocale || 'en';

interface FooterTranslation {
  description: string;
  quickLinks: string;
  legalStatus: string;
  legalText: string;
  copyright: string;
  links: { name: string; href: string }[];
}

const footerTranslations: Record<string, FooterTranslation> = {
  en: {
    description: 'The ultimate precision health tool for calculating BMI, BMR, and body composition. Built for accuracy, privacy, and ease of use.',
    quickLinks: 'Quick Links',
    legalStatus: 'Legal Status',
    legalText: 'Results are for informational purposes only. Not a substitute for professional medical advice.',
    copyright: `© ${year} BMI CALCULATOR.`,
    links: [
      { name: 'About Us', href: `/en/about` },
      { name: 'Contact Us', href: `/en/contact` },
      { name: 'Privacy Policy', href: `/en/privacy-policy` },
      { name: 'Terms & Conditions', href: `/en/terms-conditions` },
      { name: 'Medical Disclaimer', href: `/en/disclaimer` },
      { name: 'BMI Calculator', href: `/en#calculator` },
    ]
  },
  es: {
    description: 'La herramienta de salud de precisión definitiva para calcular el IMC, BMR y composición corporal. Construida para la precisión, privacidad y facilidad de uso.',
    quickLinks: 'Enlaces Rápidos',
    legalStatus: 'Aviso Legal',
    legalText: 'Los resultados son solo para fines informativos. No sustituyen el consejo médico profesional.',
    copyright: `© ${year} BMI CALCULATOR.`,
    links: [
      { name: 'Sobre Nosotros', href: `/es/about` },
      { name: 'Contáctanos', href: `/es/contact` },
      { name: 'Política de Privacidad', href: `/es/privacy-policy` },
      { name: 'Términos y Condiciones', href: `/es/terms-conditions` },
      { name: 'Aviso Médico', href: `/es/disclaimer` },
      { name: 'Calculadora IMC', href: `/es#calculator` },
    ]
  },
  fr: {
    description: 'L\'outil de santé de précision ultime pour calculer l\'IMC, le métabolisme de base et la composition corporelle. Conçu pour la précision et la facilité d\'utilisation.',
    quickLinks: 'Liens Rapides',
    legalStatus: 'Mentions Légales',
    legalText: 'Les résultats sont fournis à titre informatif uniquement. Ils ne remplacent pas les conseils médicaux professionnels.',
    copyright: `© ${year} BMI CALCULATOR.`,
    links: [
      { name: 'À Propos', href: `/fr/about` },
      { name: 'Contactez-Nous', href: `/fr/contact` },
      { name: 'Politique de Confidentialité', href: `/fr/privacy-policy` },
      { name: 'Termes et Conditions', href: `/fr/terms-conditions` },
      { name: 'Avertissement Médical', href: `/fr/disclaimer` },
      { name: 'Calculateur IMC', href: `/fr#calculator` },
    ]
  },
  de: {
    description: 'Das ultimative Präzisions-Gesundheitswerkzeug zur Berechnung von BMI, Grundumsatz und Körperzusammensetzung. Entwickelt für Genauigkeit, Datenschutz und einfache Bedienung.',
    quickLinks: 'Schnelllinks',
    legalStatus: 'Rechtlicher Hinweis',
    legalText: 'Die Ergebnisse dienen nur zu Informationszwecken. Kein Ersatz für professionellen medizinischen Rat.',
    copyright: `© ${year} BMI CALCULATOR.`,
    links: [
      { name: 'Über Uns', href: `/de/about` },
      { name: 'Kontakt', href: `/de/contact` },
      { name: 'Datenschutz', href: `/de/privacy-policy` },
      { name: 'Nutzungsbedingungen', href: `/de/terms-conditions` },
      { name: 'Medizinischer Hinweis', href: `/de/disclaimer` },
      { name: 'BMI Rechner', href: `/de#calculator` },
    ]
  },
  ko: {
    description: 'BMI, 기초대사량 및 체성분을 계산하기 위한 궁극의 정밀 건강 도구입니다. 정확성, 개인정보 보호 및 사용 편의성을 위해 제작되었습니다.',
    quickLinks: '빠른 링크',
    legalStatus: '법적 고지',
    legalText: '결과는 정보 제공 목적으로만 사용됩니다. 전문적인 의학적 조언을 대체하지 않습니다.',
    copyright: `© ${year} BMI CALCULATOR.`,
    links: [
      { name: '회사 소개', href: `/ko/about` },
      { name: '문의하기', href: `/ko/contact` },
      { name: '개인정보 처리방침', href: `/ko/privacy-policy` },
      { name: '이용약관', href: `/ko/terms-conditions` },
      { name: '의학적 면책 조항', href: `/ko/disclaimer` },
      { name: 'BMI 계산기', href: `/ko#calculator` },
    ]
  },
  hi: {
    description: 'बीएमआई, बीएमआर और शरीर संरचना की गणना के लिए परम सटीक स्वास्थ्य उपकरण। सटीकता, गोपनीयता और उपयोग में आसानी के लिए बनाया गया।',
    quickLinks: 'त्वरित लिंक',
    legalStatus: 'कानूनी स्थिति',
    legalText: 'परिणाम केवल सूचनात्मक उद्देश्यों के लिए हैं। पेशेवर चिकित्सा सलाह का विकल्प नहीं।',
    copyright: `© ${year} BMI CALCULATOR.`,
    links: [
      { name: 'हमारे बारे में', href: `/hi/about` },
      { name: 'संपर्क करें', href: `/hi/contact` },
      { name: 'गोपनीयता नीति', href: `/hi/privacy-policy` },
      { name: 'नियम और शर्तें', href: `/hi/terms-conditions` },
      { name: 'चिकित्सा अस्वीकरण', href: `/hi/disclaimer` },
      { name: 'बीएमआई कैलकुलेटर', href: `/hi#calculator` },
    ]
  }
};

const ft = footerTranslations[lang] || footerTranslations.en;
---

<footer class="border-t border-[var(--border)] py-16 bg-[var(--muted)]">
  <div class="max-w-7xl mx-auto px-6 grid md:grid-cols-4 gap-16 text-left">
    <div class="space-y-8 col-span-2">
      <div class="flex items-center gap-2">
        <span class="font-black tracking-tighter uppercase text-lg">REAL BMI</span>
      </div>
      <p class="text-base text-[var(--muted-foreground)] max-w-sm leading-relaxed font-bold opacity-60">
        {ft.description}
      </p>
    </div>

    <div class="space-y-8 col-span-2 md:col-span-1">
      <h3 class="text-xs font-black uppercase tracking-[0.3em] text-[var(--foreground)]">{ft.quickLinks}</h3>
      <ul class="grid grid-cols-2 gap-x-8 gap-y-4">
        {ft.links.map(link => (
          <li>
            <a href={link.href} class="text-sm font-bold text-[var(--muted-foreground)] hover:text-[var(--foreground)] transition-colors inline-block group">
              <span class="border-b border-transparent group-hover:border-[var(--foreground)] transition-all pb-0.5">{link.name}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>

    <div class="space-y-8">
      <h3 class="text-xs font-black uppercase tracking-[0.3em] text-[var(--foreground)]">{ft.legalStatus}</h3>
      <p class="text-xs text-[var(--muted-foreground)] leading-relaxed italic font-bold opacity-70">
        {ft.legalText}
        <br/><br/>
        <span class="text-[var(--foreground)] font-black uppercase">{ft.copyright}</span>
      </p>
    </div>
  </div>
</footer>
