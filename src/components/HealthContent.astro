---
const { currentLocale } = Astro;
const lang = currentLocale || 'en';

const content: Record<string, any> = {
  en: {
    faqTitle: 'Frequently Asked Questions',
    faq: [
      { q: 'How is BMI calculated?', a: 'BMI is calculated by dividing weight in kilograms by the square of height in meters. In the US, it is often calculated using the formula: (weight in pounds / height in inches squared) × 703. Our calculator handles both systems instantly.' },
      { q: 'What is a healthy BMI for a woman?', a: 'For adult women, a healthy BMI ranges from 18.5 to 24.9. However, BMI is a screening tool and does not account for muscle mass or distribution, which can be significant during different life stages.' },
      { q: 'What is the BMI for 5\'4" female?', a: 'A BMI score depends on weight. For a 5\'4" female, a healthy weight range (BMI 18.5-24.9) is approximately 108 to 145 lbs. You can use our calculator for your exact weight.' },
      { q: 'Is BMI accurate if you have muscle?', a: 'BMI does not distinguish between muscle and fat. Highly muscular individuals, like athletes, may have a "high" BMI despite having low body fat, which is one of the primary limitations of the metric.' },
      { q: 'Is 25 a good BMI?', a: 'A BMI of 25 is technically the threshold for the "Overweight" category (25.0–29.9). However, it is very close to the healthy range, and factors like waist circumference and physical activity levels should be considered.' }
    ],
    sections: [
      { title: 'Understanding Your Body Mass Index (BMI)', text: 'Body Mass Index (BMI) is a vital metric used by health professionals worldwide to screen for weight-related health risks. By analyzing the relationship between your height and weight, Real BMIvides a baseline understanding of whether you fall within a healthy range.' },
      { title: 'How is BMI Calculated?', text: 'In the metric system, BMI is your weight in kilograms divided by your height in meters squared (kg/m²). Our calculator handles these conversions instantly, providing you with a precise score in seconds.' },
      { title: 'Expert Health Analytics: The Real BMI Guide', text: 'Comprehensive clinical insights and classification data powered by the Real BMI Calculator engine.' }
    ],
    whoTableTitle: 'WHO BMI Classification Table',
    whoTable: [
      { category: 'Underweight', range: '< 18.5', risk: 'Low', status: 'underweight' },
      { category: 'Normal Weight', range: '18.5 – 24.9', risk: 'Minimal', status: 'normal' },
      { category: 'Overweight', range: '25.0 – 29.9', risk: 'Increased', status: 'overweight' },
      { category: 'Obesity Class I', range: '30.0 – 34.9', risk: 'High', status: 'obesity-1' },
      { category: 'Obesity Class II', range: '35.0 – 39.9', risk: 'Very High', status: 'obesity-2' }
    ]
  },
  es: {
    faqTitle: 'Preguntas Frecuentes',
    faq: [
      { q: '¿Qué es el IMC?', a: 'El Índice de Masa Corporal (IMC) es el peso de una persona en kilogramos dividido por el cuadrado de la altura en metros.' },
      { q: '¿Es el IMC preciso para atletas?', a: 'El IMC puede sobreestimar la grasa corporal en atletas porque no distingue entre músculo y grasa.' }
    ],
    sections: [
      { title: 'Entendiendo Tu Índice de Masa Corporal (IMC)', text: 'El IMC es una métrica vital utilizada por profesionales de la salud en todo el mundo para detectar riesgos de salud relacionados con el peso.' },
      { title: '¿Cómo se Calcula el IMC?', text: 'En el sistema métrico, el IMC es tu peso en kilograms dividido por tu altura en metros al cuadrado (kg/m²).' }
    ]
  },
  hi: {
    faqTitle: 'अक्सर पूछे जाने वाले प्रश्न',
    faq: [
      { q: 'बीएमआई (BMI) क्या है?', a: 'बॉडी मास इंडेक्स (बीएमआई) किसी व्यक्ति का वजन किलोग्राम में उसकी ऊंचाई के मीटर वर्ग से विभाजित होता है।' }
    ],
    sections: [
      { title: 'अपने बॉडी मास इंडेक्स (बीएमआई) को समझना', text: 'बीएमआई दुनिया भर में स्वास्थ्य पेशेवरों द्वारा वजन से संबंधित स्वास्थ्य जोखिमों की जांच के लिए उपयोग किया जाने वाला एक महत्वपूर्ण मापदंड है।' }
    ]
  }
};

const t = content[lang] || content.en;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": t.faq.map((item: { q: string; a: string }) => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.a
    }
  }))
};
---

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />


<section id="insights" class="max-w-7xl mx-auto space-y-20 py-20 px-4 md:px-6 scroll-mt-24">
  <div class="space-y-16">
    {t.sections.map((section: { title: string; text: string }) => (
      <div class="space-y-6">
        <h2 class="text-2xl md:text-3xl font-black tracking-tight text-[var(--foreground)] leading-tight uppercase">
          {section.title}
        </h2>
        <p class="text-sm md:text-lg text-[var(--muted-foreground)] leading-relaxed font-bold opacity-60">
          {section.text}
        </p>
      </div>
    ))}
  </div>

  {t.whoTable && (
    <div class="space-y-10 border-t border-[var(--border)] pt-20">
      <h2 class="text-2xl md:text-3xl font-black tracking-tight text-[var(--foreground)] leading-tight uppercase relative inline-block">
        {t.whoTableTitle}
        <div class="absolute -bottom-2 left-0 w-1/3 h-1 bg-[var(--accent)]"></div>
      </h2>
      
      <!-- Responsive Table Container -->
      <div class="glass-card overflow-hidden border-2 border-[var(--border)]">
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse min-w-[500px]">
            <thead>
              <tr class="bg-[var(--muted)] border-b-2 border-[var(--border)]">
                <th class="p-4 md:p-6 text-[10px] md:text-xs font-black uppercase tracking-widest opacity-60">BMI Category</th>
                <th class="p-4 md:p-6 text-[10px] md:text-xs font-black uppercase tracking-widest opacity-60">BMI Range (kg/m²)</th>
                <th class="p-4 md:p-6 text-[10px] md:text-xs font-black uppercase tracking-widest opacity-60">Health Risk Level</th>
              </tr>
            </thead>
            <tbody>
              {t.whoTable.map((row: any, i: number) => (
                <tr class={`border-b border-[var(--border)] last:border-0 ${i % 2 === 1 ? 'bg-[var(--muted)]/50' : ''}`}>
                  <td class="p-4 md:p-6 font-black text-[var(--foreground)] uppercase text-xs md:text-sm">{row.category}</td>
                  <td class="p-4 md:p-6 font-bold text-[var(--muted-foreground)] opacity-80 text-xs md:text-sm">{row.range}</td>
                  <td class="p-4 md:p-6">
                    <span class={`text-[9px] md:text-[10px] font-black uppercase tracking-[0.1em] md:tracking-[0.2em] px-2 py-1 md:px-3 md:py-1 rounded-md border border-current ${
                      row.status === 'normal' ? 'text-emerald-500' : 
                      row.status === 'underweight' ? 'text-sky-500' :
                      row.status === 'overweight' ? 'text-amber-500' :
                      'text-rose-500'
                    }`}>
                      {row.risk}
                    </span>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  )}

  <div id="faq" class="space-y-10 border-t border-[var(--border)] pt-20 scroll-mt-24">
    <h2 class="text-2xl md:text-3xl font-black tracking-tighter text-center uppercase tracking-[0.2em]">{t.faqTitle}</h2>
    <div class="space-y-4 md:space-y-6">
      {t.faq.map((item: { q: string; a: string }) => (
        <details class="group glass-card hover:bg-[var(--muted)] transition-all cursor-pointer overflow-hidden border-2 border-[var(--border)]">
          <summary class="flex justify-between items-center font-black text-sm md:text-lg p-6 md:p-8 select-none list-none uppercase tracking-tight">
            <span class="pr-6 md:pr-8">{item.q}</span>
            <span class="text-zinc-400 group-open:rotate-180 transition-transform flex-shrink-0">
                <svg class="w-5 h-5 md:w-6 md:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </span>
          </summary>
          <div class="px-6 pb-6 md:px-8 md:pb-10 text-[var(--muted-foreground)] leading-relaxed font-bold border-t-2 border-[var(--border)] pt-4 md:pt-6 opacity-70 text-xs md:text-base">
            {item.a}
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  summary::-webkit-details-marker {
    display: none;
  }
</style>
