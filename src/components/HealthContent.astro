    cdcLink: 'CDC BMI 지침',
    helpCenter: '도움말 센터',
    faqTitle: '자주 묻는 질문',
    faqSubtitle: 'BMI 계산, 대사율, 정확도 및 운동 선수 측정에 대해 알아야 할 모든 것.',
    sections: [
      { title: '체질량지수(BMI) 이해하기', text: '체질량지수(BMI)는 전 세계 의료 전문가들이 사용하는 국제적인 스크리닝 표준입니다.' },
      { title: 'BMI, BMR, TDEE의 상호 연관성', text: 'BMI는 체중의 균형 상태를, BMR은 휴식 상태의 기초 대사량을, TDEE는 활동량을 포함한 필요 칼로리를 보여줍니다.' }
    ],
    whoTable: [
      { category: '저체중', range: '< 18.5', risk: '낮음 (영양 위험 증가)', status: 'underweight' },
      { category: '정상 체중', range: '18.5 – 24.9', risk: '최소 (최적의 건강 상태)', status: 'normal' },
      { category: '과체중', range: '25.0 – 29.9', risk: '증가 (주의 필요)', status: 'overweight' },
      { category: '비만 1단계', range: '30.0 – 34.9', risk: '높음 (중등도 위험)', status: 'obesity-1' },
      { category: '비만 2단계', range: '35.0 – 39.9', risk: '매우 높음 (심각한 위험)', status: 'obesity-2' },
      { category: '비만 3단계', range: '≥ 40.0', risk: '극도로 높음 (고위험군)', status: 'obesity-3' }
    ],
    faq: [
      { q: 'BMI는 어떻게 계산되나요?', a: 'BMI는 체중(kg)을 키(m)의 제곱으로 나눈 값입니다.' },
      { q: '여성의 건강한 BMI는 얼마인가요?', a: '일반 성인의 경우 18.5에서 24.9 사이가 건강한 범주입니다.' },
      { q: '근육 질량이 많은 사람에게도 BMI가 정확한가요?', a: '운동선수의 경우 BMI가 실제보다 높게 측정될 수 있습니다.' },
      { q: 'BMI 25는 무엇을 의미하나요?', a: 'BMI 25는 정상 범위와 과체중의 경계선입니다.' },
      { q: 'BMR이란 무엇인가요?', a: 'BMR은 휴식 상태에서 필요한 기초 에너지입니다.' },
      { q: 'TDEE란 무엇인가요?', a: 'TDEE는 하루 총 에너지 소비량입니다.' }
    ]
  }
};

const t = content[lang] || content.en;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": t.faq.map((item: { q: string; a: string }) => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a }
  }))
};
---

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

<section id="insights" class="max-w-7xl mx-auto space-y-20 md:space-y-28 py-12 md:py-20 scroll-mt-28">

  <!-- ═══════════════════  HEALTH INSIGHTS  ═══════════════════ -->
  <div class="grid md:grid-cols-2 gap-8 md:gap-10">
    {t.sections.map((section: { title: string; text: string }, idx: number) => (
      <div class="p-8 md:p-10 rounded-[var(--radius)] border-[1.5px] border-[var(--border)] bg-[var(--card)] hover:border-[var(--accent)] hover:shadow-[var(--shadow-card)] transition-all duration-300 space-y-6 flex flex-col justify-between group relative overflow-hidden">
        
        <div class="space-y-4">
          <div class="flex items-center justify-between">
            <p class="text-xs font-display font-semibold uppercase tracking-[0.3em] text-[var(--accent)]">{t.insightSub} 0{idx + 1}</p>
          </div>
          <h2 class="text-2xl md:text-3xl font-display font-bold uppercase leading-tight text-[var(--foreground)]">
            {section.title}
          </h2>
          <div class="h-1 w-12 bg-[var(--accent)] rounded-full group-hover:w-20 transition-all duration-300"></div>
        </div>
        <p class="text-base text-[var(--muted-foreground)] leading-relaxed font-medium pt-2">
          {section.text}
        </p>
      </div>
    ))}
  </div>

  <!-- ═══════════════════  WHO TABLE & SOURCES  ═══════════════════ -->
  {t.whoTable && (
    <div class="space-y-8 pt-12">
      <div class="space-y-3">
        <p class="text-xs font-display font-semibold uppercase tracking-[0.3em] text-[var(--accent)]">{t.whoSub}</p>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-display font-bold uppercase tracking-tight text-[var(--foreground)]">
          {t.whoTableTitle}
        </h2>
        <p class="text-base text-[var(--muted-foreground)] max-w-2xl font-medium">
          {t.whoDesc}
        </p>
      </div>

      <!-- Mobile Cards Version -->
      <div class="block sm:hidden space-y-4">
        {t.whoTable.map((row: any, i: number) => (
          <div class={`p-5 rounded-xl border border-[var(--border)] bg-[var(--card)] space-y-3 shadow-sm ${i % 2 === 1 ? 'bg-[var(--muted)]/20' : ''}`}>
            <div class="flex justify-between items-center gap-3">
              <span class="font-display font-bold text-[var(--foreground)] uppercase text-sm">{row.category}</span>
              <span class={`text-[10px] font-display font-black uppercase tracking-widest px-3.5 py-1.5 rounded-full border ${
                row.status === 'normal'      ? 'border-emerald-500/40 dark:border-emerald-500/50 text-emerald-950 dark:text-emerald-200 bg-emerald-100/90 dark:bg-emerald-950/60' :
                row.status === 'underweight' ? 'border-sky-500/40 dark:border-sky-500/50 text-sky-950 dark:text-sky-200 bg-sky-100/90 dark:bg-sky-950/60' :
                row.status === 'overweight'  ? 'border-amber-500/40 dark:border-amber-500/50 text-amber-950 dark:text-amber-200 bg-amber-100/90 dark:bg-amber-950/60' :
                                               'border-rose-500/40 dark:border-rose-500/50 text-rose-950 dark:text-rose-200 bg-rose-100/90 dark:bg-rose-950/60'
              }`}>{row.risk}</span>
            </div>
            <div class="flex justify-between items-center text-xs border-t border-[var(--border)] pt-2">
              <span class="text-[var(--muted-foreground)]">{t.colRange}</span>
              <span class="font-sans font-bold text-[var(--foreground)]">{row.range}</span>
            </div>
          </div>
        ))}
      </div>

      <!-- Desktop Table Version -->
      <div class="hidden sm:block rounded-2xl border-[1.5px] border-[var(--border)] bg-[var(--card)] shadow-[var(--shadow-soft)] overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-left min-w-[500px] border-collapse">
            <thead>
              <tr class="bg-[var(--muted)] border-b border-[var(--border)]">
                <th class="px-6 py-5 text-xs font-display font-semibold uppercase tracking-widest text-[var(--muted-foreground)]">{t.colCategory}</th>
                <th class="px-6 py-5 text-xs font-display font-semibold uppercase tracking-widest text-[var(--muted-foreground)]">{t.colRange}</th>
                <th class="px-6 py-5 text-xs font-display font-semibold uppercase tracking-widest text-[var(--muted-foreground)]">{t.colRisk}</th>
              </tr>
            </thead>
            <tbody>
              {t.whoTable.map((row: any, i: number) => (
                <tr class={`border-b border-[var(--border)] last:border-0 transition-colors hover:bg-[var(--muted)]/50 ${i % 2 === 1 ? 'bg-[var(--muted)]/20' : ''}`}>
                  <td class="px-6 py-5 font-display font-bold text-[var(--foreground)] uppercase text-sm">{row.category}</td>
                  <td class="px-6 py-5 font-sans text-[var(--foreground)] text-sm font-semibold">{row.range}</td>
                  <td class="px-6 py-5">
                    <span class={`text-[10px] font-display font-extrabold uppercase tracking-widest px-4 py-1.5 rounded-full border ${
                      row.status === 'normal'      ? 'border-emerald-500/40 dark:border-emerald-500/50 text-emerald-950 dark:text-emerald-200 bg-emerald-100/90 dark:bg-emerald-950/60' :
                      row.status === 'underweight' ? 'border-sky-500/40 dark:border-sky-500/50 text-sky-950 dark:text-sky-200 bg-sky-100/90 dark:bg-sky-950/60' :
                      row.status === 'overweight'  ? 'border-amber-500/40 dark:border-amber-500/50 text-amber-950 dark:text-amber-200 bg-amber-100/90 dark:bg-amber-950/60' :
                                                     'border-rose-500/40 dark:border-rose-500/50 text-rose-950 dark:text-rose-200 bg-rose-100/90 dark:bg-rose-950/60'
                    }`}>{row.risk}</span>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      <!-- Sources & References Box -->
      <div class="rounded-xl border border-[var(--border)] bg-[var(--card)]/80 p-5 md:p-6 shadow-[var(--shadow-soft)] flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
          <p class="text-xs font-display font-bold uppercase tracking-[0.25em] text-[var(--accent)]">{t.sourcesTitle}</p>
          <p class="text-xs text-[var(--muted-foreground)] mt-1 font-medium">{t.sourcesSubtitle}</p>
        </div>
        <div class="flex flex-wrap gap-2.5">
          <a href="https://www.who.int/news-room/fact-sheets/detail/obesity-and-overweight" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 rounded-full border border-[var(--border)] px-4 py-1.5 text-xs font-semibold text-[var(--foreground)] hover:border-[var(--accent)] hover:text-[var(--accent)] transition-colors bg-[var(--muted)]/30">
            <span>{t.whoLink}</span>
            <svg class="w-3.5 h-3.5 opacity-60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
          </a>
          <a href="https://www.cdc.gov/healthyweight/assessing/bmi/adult_bmi/index.html" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 rounded-full border border-[var(--border)] px-4 py-1.5 text-xs font-semibold text-[var(--foreground)] hover:border-[var(--accent)] hover:text-[var(--accent)] transition-colors bg-[var(--muted)]/30">
            <span>{t.cdcLink}</span>
            <svg class="w-3.5 h-3.5 opacity-60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
          </a>
        </div>
      </div>
    </div>
  )}

  <!-- ═══════════════════  FAQ ACCORDION  ═══════════════════ -->
  <div id="faq" class="space-y-12 pt-12 scroll-mt-28">
    <div class="space-y-3 text-center">
      <p class="text-xs font-display font-semibold uppercase tracking-[0.3em] text-[var(--accent)]">{t.helpCenter}</p>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-display font-bold uppercase text-[var(--foreground)]">{t.faqTitle}</h2>
      <p class="text-base text-[var(--muted-foreground)] max-w-xl mx-auto font-medium">
        {t.faqSubtitle}
      </p>
    </div>

    <div class="space-y-4 max-w-7xl mx-auto">
      {t.faq.map((item: { q: string; a: string }) => (
        <details class="group rounded-xl border-[1.5px] border-[var(--border)] bg-[var(--card)] overflow-hidden cursor-pointer hover:border-[var(--accent)] transition-all duration-200 shadow-[var(--shadow-soft)]">
          <summary class="flex justify-between items-center font-display font-semibold text-base py-5 px-6 select-none list-none uppercase tracking-tight text-[var(--foreground)] hover:text-[var(--accent)] transition-colors">
            <span class="pr-8">{item.q}</span>
            <span class="text-[var(--muted-foreground)] group-open:rotate-180 transition-transform duration-200 flex-shrink-0">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
              </svg>
            </span>
          </summary>
          <div class="px-6 pb-6 text-sm md:text-base text-[var(--muted-foreground)] leading-relaxed font-medium border-t border-[var(--border)]/60 pt-4 bg-[var(--muted)]/10">
            {item.a}
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  summary::-webkit-details-marker { display: none; }
</style>
