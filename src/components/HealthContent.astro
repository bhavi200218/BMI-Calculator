---
const { currentLocale } = Astro;
const lang = currentLocale || 'en';

const content: Record<string, any> = {
  en: {
    faqTitle: 'Frequently Asked Questions',
    faq: [
      { q: 'How is BMI calculated?', a: 'BMI is your weight in kilograms divided by the square of your height in meters. For imperial units, the formula is (weight in pounds ÷ height in inches²) × 703. Our calculator processes both instantly for maximum comfort.' },
      { q: 'What is a healthy BMI for a woman?', a: 'For adult women, a healthy BMI range is between 18.5 and 24.9. However, please note that BMI does not differentiate between muscle mass and body fat. A very fit athlete might register a high BMI despite having low body fat.' },
      { q: 'Is BMI accurate for muscular people or athletes?', a: 'No, it is not fully accurate for this demographic. BMI cannot distinguish weight from muscle versus weight from fat. As a result, bodybuilders, weightlifters, and athletes often display an "overweight" or "obese" BMI score while maintaining excellent health and minimal fat. In such cases, measuring waist circumference or body-fat percentage is recommended.' },
      { q: 'What does a BMI of 25 mean?', a: 'A BMI of exactly 25.0 marks the dividing line between a healthy weight and the overweight classification. It is a signal to review other metrics like cardiovascular fitness, activity levels, and waist-to-hip ratio to get a realistic view of health risks.' },
      { q: 'What is BMR and why does it matter?', a: 'Basal Metabolic Rate (BMR) represents the total number of calories your body needs to perform basic, life-sustaining functions (such as breathing, circulation, and cell production) while at complete rest. Knowing your BMR helps you determine the baseline calorie intake required to maintain, lose, or gain weight.' },
      { q: 'What is TDEE and how is it active?', a: 'Total Daily Energy Expenditure (TDEE) is an estimation of how many calories you burn per day once exercise, sport, and daily activity are factored in. It is derived by multiplying your BMR by your physical activity multiplier.' },
    ],
    sections: [
      { title: 'Understanding Your Body Mass Index', text: 'Body Mass Index (BMI) is a valuable, internationally recognized screening standard used by healthcare professionals worldwide. It groups your weight category relative to your height, giving you a quick reference point for metabolic and cardiovascular disease risks. Real BMI Calculator pairs this score with the standard classifications from the World Health Organization (WHO) and Centers for Disease Control (CDC) to offer you direct, clinical context.' },
      { title: 'How BMI, BMR & TDEE Connect Together', text: 'Your BMI indicates if your weight falls within a balanced window. Your BMR reveals the baseline metabolic energy your organs require at absolute rest. Finally, your TDEE integrates daily physical activities, showing you the exact calories required to maintain your current weight. Combining these three pillars gives you a comprehensive, customized map of your energy balance and weight-management path.' },
    ],
    whoTableTitle: 'WHO BMI Classification Standards',
    whoTable: [
      { category: 'Underweight', range: '< 18.5', risk: 'Low (Increased Nutri. Risk)', status: 'underweight' },
      { category: 'Normal Weight', range: '18.5 – 24.9', risk: 'Minimal (Optimal Health)', status: 'normal' },
      { category: 'Overweight', range: '25.0 – 29.9', risk: 'Increased (Caution Recommended)', status: 'overweight' },
      { category: 'Obesity Class I', range: '30.0 – 34.9', risk: 'High (Moderate Risk)', status: 'obesity-1' },
      { category: 'Obesity Class II', range: '35.0 – 39.9', risk: 'Very High (Severe Risk)', status: 'obesity-2' },
      { category: 'Obesity Class III', range: '≥ 40.0', risk: 'Extremely High (Acute Risk)', status: 'obesity-3' },
    ]
  },
  es: {
    faqTitle: 'Preguntas Frecuentes',
    faq: [
      { q: '¿Cómo se calcula el IMC?', a: 'El IMC se calcula dividiendo el peso en kilogramos por el cuadrado de la altura en metros. Nuestra herramienta realiza este cálculo automáticamente para los sistemas métrico e imperial.' },
      { q: '¿Es el IMC adecuado para atletas y personas musculosas?', a: 'No del todo. El IMC no mide la grasa corporal de forma directa y no diferencia entre masa muscular y tejido graso. Los deportistas con mucha masa muscular pueden dar resultados de "sobrepeso" sin tener exceso de grasa.' },
      { q: '¿Qué es el metabolismo basal (BMR) Y el TDEE?', a: 'El BMR es el gasto calórico de tu cuerpo en descanso absoluto. El TDEE es la energía diaria consumida incluyendo tus niveles de actividad física diaria.' },
    ],
    sections: [
      { title: 'Entendiendo Tu Índice de Masa Corporal', text: 'El Índice de Masa Corporal (IMC) es un estándar clínico simplificado pero de gran utilidad médica para estimar si tu peso se encuentra dentro de niveles saludables. Real BMI Calculator utiliza escalas oficiales de la OMS para guiarte en tu estado nutricional.' },
      { title: 'La Sinergia de IMC, BMR y TDEE', text: 'El IMC te indica tu categoría general de peso, el BMR describe los requerimientos de tu metabolismo celular en reposo, y el TDEE te indica el consumo calórico diario para planificar objetivos de déficit, mantenimiento o superávit.' }
    ]
  },
  hi: {
    faqTitle: 'अक्सर पूछे जाने वाले प्रश्न',
    faq: [
      { q: 'बीएमआई (BMI) की गणना कैसे की जाती है?', a: 'बीएमआई = वजन (किलोग्राम) ÷ ऊंचाई² (मीटर)। हमारे कैलकुलेटर में आप मेट्रिक और इंपीरियल दोनों प्रणालियों का तुरंत उपयोग कर सकते हैं।' },
      { q: 'क्या धावकों और बॉडीबिल्डर्स के लिए बीएमआई सही उत्तर देता है?', a: 'नहीं, बीएमआई शरीर में मांसपेशियों (मसल मास) और वसा के बीच का अंतर नहीं बता सकता। इसलिए भारी फिटनेस वाले एथलीटों का बीएमआई स्कोर सामान्य से अधिक दिख सकता है।' },
    ],
    sections: [
      { title: 'बॉडी मास इंडेक्स को गहराई से समझें', text: 'बॉडी मास इंडेक्स (बीएमआई) वजन और ऊंचाई का एक अनुपात है जो स्वास्थ्य विशेषज्ञों को शारीरिक संरचना का आकलन करने में मदद करता है। चिकित्सक इसका उपयोग हृदय और पोषण संबंधी बुनियादी जांच के लिए करते हैं।' }
    ]
  },
};

// Elegant fallback to English for translations or sub-keys
const activeContent = content[lang] || content.en;
const t = {
  ...content.en,
  ...activeContent,
  // Merge lists to preserve English if translated sub-lists are incomplete
  faq: activeContent.faq && activeContent.faq.length >= 3 ? activeContent.faq : content.en.faq,
  sections: activeContent.sections && activeContent.sections.length >= 2 ? activeContent.sections : content.en.sections,
  whoTable: activeContent.whoTable || content.en.whoTable,
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": t.faq.map((item: { q: string; a: string }) => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a }
  }))
};
---

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

<section id="insights" class="max-w-7xl mx-auto space-y-24 md:space-y-32 py-16 md:py-24 scroll-mt-28">

  <!-- ═══════════════════  HEALTH INSIGHTS  ═══════════════════ -->
  <div class="grid md:grid-cols-2 gap-8 md:gap-10">
    {t.sections.map((section: { title: string; text: string }, idx: number) => (
      <div class="p-8 md:p-10 rounded-[var(--radius)] border-[1.5px] border-[var(--border)] bg-[var(--card)] hover:border-[var(--accent)] hover:shadow-[var(--shadow-card)] transition-all duration-300 space-y-6 flex flex-col justify-between group relative overflow-hidden">
        
        <div class="space-y-4">
          <div class="flex items-center justify-between">
            <p class="text-xs font-display font-semibold uppercase tracking-[0.3em] text-[var(--accent)]">Insight 0{idx + 1}</p>
            <div class="w-8 h-8 rounded-full border border-[var(--border)] flex items-center justify-center text-[var(--muted-foreground)] group-hover:bg-[var(--accent)] group-hover:border-[var(--accent)] group-hover:text-white transition-all duration-300">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
            </div>
          </div>
          <h2 class="text-2xl md:text-3xl font-display font-bold uppercase leading-tight text-[var(--foreground)]">
            {section.title}
          </h2>
          <div class="h-1 w-12 bg-[var(--accent)] rounded-full group-hover:w-20 transition-all duration-300"></div>
        </div>
        <p class="text-base text-[var(--muted-foreground)] leading-relaxed font-medium pt-4 border-t border-[var(--border)]/40">
          {section.text}
        </p>
      </div>
    ))}
  </div>

  <!-- ═══════════════════  WHO TABLE  ═══════════════════ -->
  {t.whoTable && (
    <div class="space-y-10 border-t border-[var(--border)] pt-20">
      <div class="space-y-3">
        <p class="text-xs font-display font-semibold uppercase tracking-[0.3em] text-[var(--accent)]">WHO Standards</p>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-display font-bold uppercase tracking-tight text-[var(--foreground)]">
          {t.whoTableTitle}
        </h2>
        <p class="text-base text-[var(--muted-foreground)] max-w-2xl font-medium">
          The World Health Organization (WHO) breaks BMI scores down into categorized target ranges to mark health and nutritional indicators.
        </p>
      </div>

      <div class="rounded-2xl border-[1.5px] border-[var(--border)] bg-[var(--card)] shadow-[var(--shadow-soft)] overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-left min-w-[500px] border-collapse">
            <thead>
              <tr class="bg-[var(--muted)] border-b border-[var(--border)]">
                <th class="px-6 py-5 text-xs font-display font-semibold uppercase tracking-widest text-[var(--muted-foreground)]">Classification Category</th>
                <th class="px-6 py-5 text-xs font-display font-semibold uppercase tracking-widest text-[var(--muted-foreground)]">BMI Range Box</th>
                <th class="px-6 py-5 text-xs font-display font-semibold uppercase tracking-widest text-[var(--muted-foreground)]">Est. Health Risk Level</th>
              </tr>
            </thead>
            <tbody>
              {t.whoTable.map((row: any, i: number) => (
                <tr class={`border-b border-[var(--border)] last:border-0 transition-colors hover:bg-[var(--muted)]/50 ${i % 2 === 1 ? 'bg-[var(--muted)]/20' : ''}`}>
                  <td class="px-6 py-5 font-display font-bold text-[var(--foreground)] uppercase text-sm">{row.category}</td>
                  <td class="px-6 py-5 font-sans text-[var(--foreground)] text-sm font-semibold">{row.range}</td>
                  <td class="px-6 py-5">
                    <span class={`text-[10px] font-display font-bold uppercase tracking-widest px-4 py-1.5 rounded-full border ${
                      row.status === 'normal'      ? 'border-emerald-500/30 text-emerald-500 bg-emerald-500/5' :
                      row.status === 'underweight' ? 'border-sky-500/30 text-sky-500 bg-sky-500/5' :
                      row.status === 'overweight'  ? 'border-amber-500/30 text-amber-500 bg-amber-500/5' :
                                                     'border-rose-500/30 text-rose-500 bg-rose-500/5'
                    }`}>{row.risk}</span>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  )}

  <!-- ═══════════════════  FAQ ACCORDION  ═══════════════════ -->
  <div id="faq" class="space-y-12 border-t border-[var(--border)] pt-20 scroll-mt-28">
    <div class="space-y-3 text-center">
      <p class="text-xs font-display font-semibold uppercase tracking-[0.3em] text-[var(--accent)]">Help Center</p>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-display font-bold uppercase text-[var(--foreground)]">{t.faqTitle}</h2>
      <p class="text-base text-[var(--muted-foreground)] max-w-xl mx-auto font-medium">
        Everything you need to know about BMI calculations, metabolic ratios, accuracy, and athletic measurements.
      </p>
    </div>

    <div class="space-y-4 max-w-7xl mx-auto">
      {t.faq.map((item: { q: string; a: string }) => (
        <details class="group rounded-xl border-[1.5px] border-[var(--border)] bg-[var(--card)] overflow-hidden cursor-pointer hover:border-[var(--accent)] transition-all duration-200 shadow-[var(--shadow-soft)]">
          <summary class="flex justify-between items-center font-display font-semibold text-base py-5 px-6 select-none list-none uppercase tracking-tight text-[var(--foreground)] hover:text-[var(--accent)] transition-colors">
            <span class="pr-8">{item.q}</span>
            <span class="text-[var(--muted-foreground)] group-open:rotate-180 transition-transform duration-200 flex-shrink-0">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
              </svg>
            </span>
          </summary>
          <div class="px-6 pb-6 text-sm md:text-base text-[var(--muted-foreground)] leading-relaxed font-medium border-t border-[var(--border)]/60 pt-4 bg-[var(--muted)]/10">
            {item.a}
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  summary::-webkit-details-marker { display: none; }
</style>
