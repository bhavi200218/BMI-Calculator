const t = labels[lang] || labels.en;
const articles = articlesData[lang] || articlesData.en;
---

<section class="space-y-6 py-6">
  <!-- Section Header -->
  <div class="flex items-center justify-between gap-4 flex-wrap pb-2 border-b border-[var(--border)]/60">
    <div class="space-y-1">
      <p class="text-xs font-display font-semibold uppercase tracking-[0.3em] text-[var(--accent)]">
        {t.library}
      </p>
      <h2 class="text-3xl md:text-4xl font-display font-bold tracking-tight uppercase text-[var(--foreground)] leading-tight">
        {t.latest}
      </h2>
    </div>
    <div class="flex items-center gap-2 px-3 py-1.5 rounded-full border border-[var(--accent)]/30 bg-[var(--accent)]/5 text-[11px] font-display font-semibold text-[var(--muted-foreground)]">
      <span class="w-2 h-2 rounded-full bg-[var(--accent)]"></span>
      {t.reviewed}
    </div>
  </div>

  <!-- Article Cards -->
  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
    {
      articles.map((article) => (
        <a href={`/${lang}/blog/${article.slug}`} class="group block h-full">
          <div class="h-full p-6 rounded-[var(--radius)] border-[1.5px] border-[var(--border)] bg-[var(--card)] flex flex-col justify-between space-y-4 hover:border-[var(--accent)] hover:-translate-y-1 hover:shadow-[var(--shadow-accent)] transition-all duration-300 cursor-pointer">
            <div class="space-y-3">
              <div class="flex items-center justify-between">
                <span class="text-[10px] font-display font-semibold uppercase tracking-[0.2em] px-2.5 py-1 rounded-full border border-[var(--accent)]/40 text-[var(--accent)] bg-[var(--accent)]/5">
                  {article.category}
                </span>
                <span class="text-[11px] font-sans font-medium text-[var(--muted-foreground)]">
                  {article.readTime}
                </span>
              </div>

              <div class="text-[10px] font-display font-semibold uppercase tracking-[0.15em] text-[var(--muted-foreground)]/80">
                {article.updated}
              </div>

              <h3 class="text-lg md:text-xl font-display font-bold leading-snug text-[var(--foreground)] group-hover:text-[var(--accent)] transition-colors duration-200 uppercase">
                {article.title}
              </h3>

              <p class="text-sm text-[var(--muted-foreground)] leading-relaxed font-medium opacity-80 line-clamp-3">
                {article.text}
              </p>
            </div>

            <div class="flex items-center gap-2 text-xs font-display font-semibold uppercase tracking-wider text-[var(--accent)] group-hover:gap-3 transition-all duration-200 pt-3 border-t border-[var(--border)]/40">
              <span>{t.readArticle}</span>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
              </svg>
            </div>
          </div>
        </a>
      ))
    }
  </div>
</section>
