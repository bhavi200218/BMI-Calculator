---
const { currentLocale } = Astro;
const lang = currentLocale || 'en';

const translations: Record<string, any> = {
  en: {
    title: 'BMI Calculator',
    subtitle: 'Precision Health Tool',
    weight_kg: 'Weight',
    weight_lb: 'Weight',
    height_cm: 'Height',
    height_ft: 'Height',
    height_in: 'Height',
    age: 'Age',
    gender: 'Biological Sex',
    metric: 'Metric',
    imperial: 'Imperial',
    calculate: 'Calculate My BMI',
    male: 'Male',
    female: 'Female',
    history: 'Recent Sessions',
    error: 'Please fill all fields.',
    weight_unit_kg: 'kg',
    weight_unit_lb: 'lbs',
    height_unit_cm: 'cm',
  },
  es: {
    title: 'Calculadora IMC',
    subtitle: 'Herramienta de Salud',
    weight_kg: 'Peso',
    weight_lb: 'Peso',
    height_cm: 'Altura',
    height_ft: 'Altura',
    height_in: 'Altura',
    age: 'Edad',
    gender: 'Sexo',
    metric: 'Métrico',
    imperial: 'Imperial',
    calculate: 'Calcular IMC',
    male: 'Masculino',
    female: 'Femenino',
    history: 'Sesiones Recientes',
    error: 'Por favor complete todos los campos.',
    weight_unit_kg: 'kg',
    weight_unit_lb: 'lbs',
    height_unit_cm: 'cm',
  },
  hi: {
    title: 'बीएमआई कैलकुलेटर',
    subtitle: 'स्वास्थ्य उपकरण',
    weight_kg: 'वजन',
    weight_lb: 'वजन',
    height_cm: 'ऊंचाई',
    height_ft: 'ऊंचाई',
    height_in: 'ऊंचाई',
    age: 'आयु',
    gender: 'लिंग',
    metric: 'मीट्रिक',
    imperial: 'इंपीरियल',
    calculate: 'बीएमआई गणना करें',
    male: 'पुरुष',
    female: 'महिला',
    history: 'हाल के सत्र',
    error: 'कृपया सभी फ़ील्ड भरें।',
    weight_unit_kg: 'किग्रा',
    weight_unit_lb: 'पाउंड',
    height_unit_cm: 'सेमी',
  },
  fr: {
    title: 'Calculateur d\'IMC',
    subtitle: 'Outil Santé Précis',
    weight_kg: 'Poids',
    weight_lb: 'Poids',
    height_cm: 'Taille',
    height_ft: 'Taille',
    height_in: 'Taille',
    age: 'Âge',
    gender: 'Sexe',
    metric: 'Métrique',
    imperial: 'Impérial',
    calculate: 'Calculer Mon IMC',
    male: 'Homme',
    female: 'Femme',
    history: 'Sessions Récentes',
    error: 'Veuillez remplir tous les champs.',
    weight_unit_kg: 'kg',
    weight_unit_lb: 'lbs',
    height_unit_cm: 'cm',
  },
  de: {
    title: 'BMI-Rechner',
    subtitle: 'Präzises Gesundheitstool',
    weight_kg: 'Gewicht',
    weight_lb: 'Gewicht',
    height_cm: 'Größe',
    height_ft: 'Größe',
    height_in: 'Größe',
    age: 'Alter',
    gender: 'Geschlecht',
    metric: 'Metrisch',
    imperial: 'Imperialis',
    calculate: 'BMI Berechnen',
    male: 'Männlich',
    female: 'Weiblich',
    history: 'Letzte Sitzungen',
    error: 'Bitte füllen Sie alle Felder aus.',
    weight_unit_kg: 'kg',
    weight_unit_lb: 'lbs',
    height_unit_cm: 'cm',
  },
  ko: {
    title: 'BMI 계산기',
    subtitle: '정밀 건강 도구',
    weight_kg: '체중',
    weight_lb: '체중',
    height_cm: '신장',
    height_ft: '신장',
    height_in: '신장',
    age: '연령',
    gender: '성별',
    metric: '미터법',
    imperial: '야드파운드법',
    calculate: '내 BMI 계산하기',
    male: '남성',
    female: '여성',
    history: '최근 세션',
    error: '모든 필드를 입력해 주세요.',
    weight_unit_kg: 'kg',
    weight_unit_lb: 'lbs',
    height_unit_cm: 'cm',
  }
};

const t = translations[lang] || translations.en;
---

<div id="calculator" class="melove-card p-7 md:p-10 space-y-8 h-full scroll-mt-28">
  
  <!-- Header -->
  <div class="space-y-2">
    <p class="text-xs font-display font-semibold uppercase tracking-[0.3em] text-[var(--accent)]">{t.subtitle}</p>
    <div class="flex items-center justify-between gap-4">
      <h2 class="text-2xl md:text-3xl font-display font-bold uppercase tracking-tight text-[var(--foreground)]">{t.title}</h2>
      <!-- Unit Toggle -->
      <div class="p-1 bg-[var(--muted)] rounded-xl border border-[var(--border)] flex">
        <button data-unit="metric" class="unit-btn active px-4 py-2 rounded-lg text-xs font-display font-semibold uppercase tracking-widest transition-all duration-200 cursor-pointer">
          {t.metric}
        </button>
        <button data-unit="imperial" class="unit-btn px-4 py-2 rounded-lg text-xs font-display font-semibold uppercase tracking-widest transition-all duration-200 cursor-pointer text-[var(--muted-foreground)]">
          {t.imperial}
        </button>
      </div>
    </div>
  </div>

  <div class="space-y-6">
    <!-- Weight & Height -->
    <div class="grid grid-cols-2 gap-4">
      <!-- Weight -->
      <div class="space-y-2">
        <label id="weightLabel" class="text-xs font-display font-bold uppercase tracking-[0.2em] text-[var(--foreground)] flex items-center justify-between">
          <span>{t.weight_kg}</span>
          <span id="weightUnit" class="text-[var(--accent)] font-bold">{t.weight_unit_kg}</span>
        </label>
        <input type="number" id="weight" placeholder="70" required
          class="matte-input w-full px-4 py-3.5 text-2xl font-bold rounded-[var(--radius-sm)]"
          inputmode="decimal" />
      </div>

      <!-- Height (Metric) -->
      <div id="metricHeightWrapper" class="space-y-2">
        <label id="heightLabel" class="text-xs font-display font-bold uppercase tracking-[0.2em] text-[var(--foreground)] flex items-center justify-between">
          <span>{t.height_cm}</span>
          <span id="heightUnit" class="text-[var(--accent)] font-bold">{t.height_unit_cm}</span>
        </label>
        <div id="metricHeightGroup" class="relative">
          <input type="number" id="height" placeholder="175" required
            class="matte-input w-full px-4 py-3.5 text-2xl font-bold rounded-[var(--radius-sm)]"
            inputmode="decimal" />
        </div>
      </div>

      <!-- Height (Imperial) -->
      <div id="imperialHeightWrapper" class="hidden col-span-2 space-y-2">
        <label class="text-xs font-display font-bold uppercase tracking-[0.2em] text-[var(--foreground)]">{t.height_ft}</label>
        <div id="imperialHeightGroup" class="grid grid-cols-2 gap-3">
          <div class="relative">
            <input type="number" id="heightFt" placeholder="5"
              class="matte-input w-full px-4 py-3.5 text-2xl font-bold rounded-[var(--radius-sm)]"
              inputmode="decimal" />
            <span class="absolute right-4 top-1/2 -translate-y-1/2 text-[10px] font-display font-bold text-[var(--accent)]">FT</span>
          </div>
          <div class="relative">
            <input type="number" id="heightIn" placeholder="9"
              class="matte-input w-full px-4 py-3.5 text-2xl font-bold rounded-[var(--radius-sm)]"
              inputmode="decimal" />
            <span class="absolute right-4 top-1/2 -translate-y-1/2 text-[10px] font-display font-bold text-[var(--accent)]">IN</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Age & Gender -->
    <div class="grid grid-cols-2 gap-4">
      <!-- Age -->
      <div class="space-y-2">
        <label class="text-xs font-display font-bold uppercase tracking-[0.2em] text-[var(--foreground)]">{t.age}</label>
        <input type="number" id="age" placeholder="25" required
          class="matte-input w-full px-4 py-3.5 text-2xl font-bold rounded-[var(--radius-sm)]"
          inputmode="numeric" />
      </div>
      <!-- Gender -->
      <div class="space-y-2">
        <label class="text-xs font-display font-bold uppercase tracking-[0.2em] text-[var(--foreground)]">{t.gender}</label>
        <div class="grid grid-cols-2 gap-2 h-[56px]">
          <button data-gender="male" class="gender-btn active h-full rounded-[var(--radius-sm)] border-[1.5px] border-[var(--border)] text-xs font-display font-semibold uppercase tracking-wider transition-all duration-200 cursor-pointer">
            {t.male}
          </button>
          <button data-gender="female" class="gender-btn h-full rounded-[var(--radius-sm)] border-[1.5px] border-[var(--border)] text-xs font-display font-semibold uppercase tracking-wider transition-all duration-200 cursor-pointer text-[var(--muted-foreground)]">
            {t.female}
          </button>
        </div>
      </div>
    </div>

    <!-- Calculate Button -->
    <button id="calcBtn" class="w-full py-5 rounded-[var(--radius)] calc-btn-gradient font-display font-bold uppercase text-base tracking-[0.25em] cursor-pointer">
      {t.calculate}
    </button>
  </div>

  <!-- Session History -->
  <div id="history" class="pt-6 border-t border-[var(--border)]">
    <p class="text-xs font-display font-semibold uppercase tracking-[0.3em] text-[var(--muted-foreground)] mb-4">{t.history}</p>
    <div id="historyList" class="space-y-2"></div>
  </div>
</div>

<style>
  .melove-card {
    background: var(--card);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border: 1.5px solid var(--border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-soft);
    transition: box-shadow 0.2s ease;
  }

  .unit-btn.active {
    background: var(--accent);
    color: var(--accent-foreground);
    box-shadow: 0 2px 10px rgba(232, 103, 74, 0.3);
  }

  .unit-btn:not(.active):hover {
    color: var(--foreground);
    background: var(--border);
  }

  .gender-btn.active {
    background: var(--accent);
    color: var(--accent-foreground);
    border-color: var(--accent);
    box-shadow: 0 4px 16px -4px rgba(232, 103, 74, 0.4);
  }

  .gender-btn:not(.active):hover {
    border-color: var(--muted-foreground);
    color: var(--foreground);
  }
</style>

<script is:inline>
(function() {
  let currentUnit = 'metric';
  let currentGender = 'male';
  let sessionHistory = [];

  const unitLabels = {
    en: { kg: 'kg', lbs: 'lbs', cm: 'cm', ft: 'ft', inch: 'in' },
    hi: { kg: 'किग्रा', lbs: 'पाउंड', cm: 'सेमी', ft: 'फुट', inch: 'इंच' },
    es: { kg: 'kg', lbs: 'lbs', cm: 'cm', ft: 'ft', inch: 'in' }
  };
  const getLang = () => document.documentElement.lang || 'en';
  const getUL = () => unitLabels[getLang()] || unitLabels.en;

  function setUnit(unit) {
    currentUnit = unit;
    
    document.querySelectorAll('.unit-btn').forEach(btn => {
      if (btn.dataset.unit === currentUnit) {
        btn.classList.add('active');
        btn.classList.remove('text-[var(--muted-foreground)]');
      } else {
        btn.classList.remove('active');
        btn.classList.add('text-[var(--muted-foreground)]');
      }
    });

    const ul = getUL();
    const metricWrapper = document.getElementById('metricHeightWrapper');
    const imperialWrapper = document.getElementById('imperialHeightWrapper');
    const weightUnit = document.getElementById('weightUnit');
    const heightUnit = document.getElementById('heightUnit');

    if (metricWrapper && imperialWrapper) {
      if (currentUnit === 'metric') {
        metricWrapper.classList.remove('hidden');
        imperialWrapper.classList.add('hidden');
        imperialWrapper.classList.remove('col-span-2');
        if (weightUnit) weightUnit.textContent = ul.kg;
        if (heightUnit) heightUnit.textContent = ul.cm;
      } else {
        metricWrapper.classList.add('hidden');
        imperialWrapper.classList.remove('hidden');
        imperialWrapper.classList.add('col-span-2');
        if (weightUnit) weightUnit.textContent = ul.lbs;
        if (heightUnit) heightUnit.textContent = '';
      }
    }
    localStorage.setItem('bmiUnit', currentUnit);
    window.dispatchEvent(new CustomEvent('bmiUnitChanged', { detail: { unit: currentUnit } }));
  }

  function runBmiCalculation() {
    const wEl = document.getElementById('weight');
    const aEl = document.getElementById('age');
    let weightVal = wEl ? wEl.value.trim() : '';
    let ageVal = aEl ? aEl.value.trim() : '';

    let weight = weightVal ? parseFloat(weightVal) : 70;
    let age = ageVal ? parseInt(ageVal) : 25;
    if (isNaN(weight) || weight <= 0) weight = 70;
    if (isNaN(age) || age <= 0) age = 25;

    let bmi, heightM;

    if (currentUnit === 'metric') {
      const hEl = document.getElementById('height');
      let heightVal = hEl ? hEl.value.trim() : '';
      let heightCm = heightVal ? parseFloat(heightVal) : 175;
      if (isNaN(heightCm) || heightCm <= 0) heightCm = 175;
      heightM = heightCm / 100;
      bmi = weight / (heightM * heightM);
    } else {
      const ftEl = document.getElementById('heightFt');
      const inEl = document.getElementById('heightIn');
      let ftVal = ftEl ? ftEl.value.trim() : '';
      let inVal = inEl ? inEl.value.trim() : '';
      let ft = ftVal ? parseFloat(ftVal) : 5;
      let inch = inVal ? parseFloat(inVal) : 9;
      let weightKg = weight * 0.453592;
      let totalInches = (ft * 12) + inch;
      heightM = totalInches * 0.0254;
      bmi = weightKg / (heightM * heightM);
      weight = weightKg;
    }

    const bmr = currentGender === 'male'
      ? 10 * weight + 6.25 * (heightM * 100) - 5 * age + 5
      : 10 * weight + 6.25 * (heightM * 100) - 5 * age - 161;

    const tdee = bmr * 1.2;
    const idealWeight = 22 * (heightM * heightM);
    const bodyFat = (1.20 * bmi) + (0.23 * age) - (currentGender === 'male' ? 16.2 : 5.4);

    const result = {
      bmi: bmi.toFixed(1),
      bmr: Math.round(bmr),
      tdee: Math.round(tdee),
      idealWeight: idealWeight.toFixed(1),
      bodyFat: bodyFat.toFixed(1)
    };

    const catStr = parseFloat(result.bmi) < 18.5 ? 'Underweight' : parseFloat(result.bmi) < 25 ? 'Healthy' : parseFloat(result.bmi) < 30 ? 'Overweight' : 'Obese';
    window.dispatchEvent(new CustomEvent('bmiCalculated', { detail: result }));
    window.dispatchEvent(new CustomEvent('calculationCompleted', {
      detail: {
        primary: { value: result.bmi, label: { en: 'BMI Score', es: 'Puntaje de IMC', fr: 'Score d\'IMC', de: 'BMI-Wert', ko: 'BMI 점수', hi: 'बीएमआई स्कोर' } },
        secondary: [
          { label: { en: 'Classification', es: 'Clasificación', fr: 'Classification', de: 'Klassifizierung', ko: '분류', hi: 'वर्गीकरण' }, value: catStr },
          { label: { en: 'Resting Metabolism (BMR)', es: 'Metabolismo Basal', fr: 'Métabolisme de Base', de: 'Grundumsatz BMR', ko: '기초대사량', hi: 'बेसल मेटाबॉलिज्म' }, value: result.bmr, unit: 'kcal' },
          { label: { en: 'Daily Energy (TDEE)', es: 'Energía Diaria', fr: 'Énergie Quotidienne', de: 'Tagesbedarf TDEE', ko: '일일 목표', hi: 'दैनिक ऊर्जा' }, value: result.tdee, unit: 'kcal' },
          { label: { en: 'Est. Body Fat', es: 'Grasa Estimada', fr: 'Graisse Corp. Est.', de: 'Körperfett', ko: '체지방률', hi: 'अनुमानित वसा' }, value: result.bodyFat, unit: '%' },
          { label: { en: 'Ideal Weight', es: 'Peso Ideal', fr: 'Poids Idéal', de: 'Idealgewicht', ko: '이상적인 체중', hi: 'आदर्श वजन' }, value: result.idealWeight, unit: currentUnit === 'imperial' ? 'lbs' : 'kg' }
        ]
      }
    }));

    if (window.innerWidth < 1024) {
      setTimeout(() => {
        const el = document.getElementById('bmiDisplay') || document.getElementById('resultStudio');
        if (el) el.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }, 100);
    }

    sessionHistory.unshift({ bmi: result.bmi, date: new Date().toLocaleTimeString() });
    sessionHistory = sessionHistory.slice(0, 3);
    updateHistory();
  }

  function updateHistory() {
    const list = document.getElementById('historyList');
    if (!list) return;
    list.innerHTML = sessionHistory.map(item => `
      <div class="flex justify-between items-center px-4 py-3 rounded-[var(--radius-sm)] bg-[var(--muted)] border border-[var(--border)]">
        <span class="text-[10px] font-display font-semibold uppercase tracking-widest text-[var(--accent)]">BMI ${item.bmi}</span>
        <span class="text-[10px] font-sans text-[var(--muted-foreground)] opacity-60">${item.date}</span>
      </div>
    `).join('');
  }

  // Global event delegation for clicks
  document.addEventListener('click', (e) => {
    const calcBtn = e.target.closest('#calcBtn');
    if (calcBtn) {
      e.preventDefault();
      runBmiCalculation();
      return;
    }

    const unitBtn = e.target.closest('.unit-btn');
    if (unitBtn && unitBtn.dataset.unit) {
      setUnit(unitBtn.dataset.unit);
      return;
    }

    const genderBtn = e.target.closest('.gender-btn');
    if (genderBtn && genderBtn.dataset.gender) {
      document.querySelectorAll('.gender-btn').forEach(b => {
        b.classList.remove('active');
        b.classList.add('text-[var(--muted-foreground)]');
      });
      genderBtn.classList.add('active');
      genderBtn.classList.remove('text-[var(--muted-foreground)]');
      currentGender = genderBtn.dataset.gender;
      return;
    }
  });

  // Init unit on load
  const storedUnit = localStorage.getItem('bmiUnit') || 'metric';
  setUnit(storedUnit);
  document.addEventListener('astro:after-swap', () => setUnit(localStorage.getItem('bmiUnit') || 'metric'));
})();
</script>
