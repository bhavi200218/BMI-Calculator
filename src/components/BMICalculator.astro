---
const { currentLocale } = Astro;
const lang = currentLocale || 'en';

const translations: Record<string, any> = {
  en: {
    title: 'Precision Calculator',
    weight_kg: 'Weight (kg)',
    weight_lb: 'Weight (lbs)',
    height_cm: 'Height (cm)',
    height_ft: 'Height (ft)',
    height_in: 'Height (in)',
    age: 'Age (Years)',
    gender: 'Gender',
    metric: 'Metric',
    imperial: 'Imperial',
    calculate: 'Calculate BMI',
    male: 'Male',
    female: 'Female',
    history: 'Recent Sessions',
    error: 'Please fill all fields.'
  },
  es: {
    title: 'Calculadora de Precisión',
    weight_kg: 'Peso (kg)',
    weight_lb: 'Peso (lbs)',
    height_cm: 'Altura (cm)',
    height_ft: 'Altura (ft)',
    height_in: 'Altura (in)',
    age: 'Edad (Años)',
    gender: 'Género',
    metric: 'Métrico',
    imperial: 'Imperial',
    calculate: 'Calcular IMC',
    male: 'Masculino',
    female: 'Femenino',
    history: 'Sesiones Recientes',
    error: 'Por favor complete todos los campos.'
  },
  hi: {
    title: 'सटीक कैलकुलेटर',
    weight_kg: 'वजन (किग्रा)',
    weight_lb: 'वजन (पाउंड)',
    height_cm: 'लंबाई (सेमी)',
    height_ft: 'लंबाई (फुट)',
    height_in: 'लंबाई (इंच)',
    age: 'उम्र (वर्ष)',
    gender: 'लिंग',
    metric: 'मीट्रिक',
    imperial: 'इंपीरियल',
    calculate: 'बीएमआई गणना करें',
    male: 'पुरुष',
    female: 'महिला',
    history: 'हाल के सत्र',
    error: 'कृपया सभी फ़ील्ड भरें।'
  }
};

const t = translations[lang] || translations.en;
---

<div id="calculator" class="glass-card p-6 md:p-10 space-y-10 h-full scroll-mt-24 border-2 border-[var(--border)] shadow-sm">
  <div class="flex items-center justify-between gap-4">
    <h2 class="text-xs font-black uppercase tracking-[0.2em] text-[var(--foreground)]">{t.title}</h2>
    <div class="inline-flex p-1 bg-[var(--muted)] rounded-xl border border-[var(--border)]">
      <button data-unit="metric" class="unit-btn active px-4 py-2 rounded-lg text-[10px] font-black uppercase tracking-widest transition-all">
        {t.metric}
      </button>
      <button data-unit="imperial" class="unit-btn px-4 py-2 rounded-lg text-[10px] font-black uppercase tracking-widest transition-all">
        {t.imperial}
      </button>
    </div>
  </div>

  <div class="space-y-8">
    <div class="grid md:grid-cols-2 gap-8">
      <!-- Weight Group -->
      <div class="space-y-4">
        <label id="weightLabel" class="text-[11px] font-black uppercase tracking-widest text-[var(--foreground)]">{t.weight_kg}</label>
        <div class="relative">
          <input type="number" id="weight" placeholder="70" required class="matte-input w-full px-6 py-4 placeholder:opacity-20 font-black text-lg rounded-[1.5rem]" />
        </div>
      </div>

      <!-- Height Group -->
      <div class="space-y-4">
        <label id="heightLabel" class="text-[11px] font-black uppercase tracking-widest text-[var(--foreground)]">{t.height_cm}</label>
        
        <!-- Metric Height -->
        <div id="metricHeightGroup" class="relative">
          <input type="number" id="height" placeholder="175" required class="matte-input w-full px-6 py-4 placeholder:opacity-20 font-black text-lg rounded-[1.5rem]" />
        </div>

        <!-- Imperial Height (Hidden by default) -->
        <div id="imperialHeightGroup" class="hidden grid grid-cols-2 gap-4">
          <div class="relative">
             <input type="number" id="heightFt" placeholder="5" class="matte-input w-full pl-6 pr-10 py-4 placeholder:opacity-20 font-black text-lg rounded-[1.5rem]" />
             <span class="absolute right-4 top-1/2 -translate-y-1/2 text-[10px] font-black opacity-30">FT</span>
          </div>
          <div class="relative">
             <input type="number" id="heightIn" placeholder="9" class="matte-input w-full pl-6 pr-10 py-4 placeholder:opacity-20 font-black text-lg rounded-[1.5rem]" />
             <span class="absolute right-4 top-1/2 -translate-y-1/2 text-[10px] font-black opacity-30">IN</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Age & Gender -->
    <div class="grid md:grid-cols-2 gap-8">
      <div class="space-y-4">
        <label class="text-[11px] font-black uppercase tracking-widest text-[var(--foreground)]">{t.age}</label>
        <div class="relative">
          <input type="number" id="age" placeholder="25" required class="matte-input w-full px-6 py-4 placeholder:opacity-20 font-black text-lg rounded-[1.5rem]" />
        </div>
      </div>
      <div class="space-y-4">
        <label class="text-[11px] font-black uppercase tracking-widest text-[var(--foreground)]">{t.gender}</label>
        <div class="grid grid-cols-2 gap-3">
          <button data-gender="male" class="gender-btn active py-4 px-6 rounded-[1.5rem] border-2 border-[var(--border)] text-[10px] font-black uppercase tracking-widest transition-all">
            {t.male}
          </button>
          <button data-gender="female" class="gender-btn py-4 px-6 rounded-[1.5rem] border-2 border-[var(--border)] bg-transparent text-[10px] font-black uppercase tracking-widest transition-all">
            {t.female}
          </button>
        </div>
      </div>
    </div>

    <button id="calcBtn" class="w-full py-6 rounded-[2rem] calc-btn-gradient font-black uppercase text-sm tracking-[0.3em] transition-all mt-4">
      {t.calculate}
    </button>
  </div>

  <div id="history" class="pt-10 border-t-2 border-[var(--border)]">
     <h3 class="text-[9px] font-black uppercase tracking-[0.3em] text-[var(--foreground)] mb-6 uppercase">{t.history}</h3>
     <div id="historyList" class="space-y-3"></div>
  </div>
</div>

<style>
  .unit-btn.active {
    background: linear-gradient(135deg, #007a7a, #c9a44c);
    color: white;
    box-shadow: 0 4px 12px rgba(0, 122, 122, 0.2);
  }
  
  .dark .unit-btn.active {
    background: linear-gradient(135deg, #064e3b, #1e3a8a, #3b82f6);
  }

  .gender-btn.active {
    background: linear-gradient(135deg, #007a7a, #c9a44c);
    color: white;
    box-shadow: 0 10px 30px -10px rgba(0, 122, 122, 0.5);
    border: none;
  }

  .dark .gender-btn.active {
    background: linear-gradient(135deg, #064e3b, #1e3a8a, #3b82f6);
    box-shadow: 0 10px 30px -10px rgba(59, 130, 246, 0.5);
  }
</style>

<script is:inline>
  let currentUnit = 'metric';
  let currentGender = 'male';
  let sessionHistory = [];

  const translations = {
    en: { weight: 'Current Weight', height: 'Current Height', kg: '(kg)', lbs: '(lbs)', cm: '(cm)', ftin: '(ft/in)' },
    hi: { weight: 'वर्तमान वजन', height: 'वर्तमान ऊंचाई', kg: '(किग्रा)', lbs: '(पाउंड)', cm: '(सेमी)', ftin: '(फुट/इंच)' },
    es: { weight: 'Peso Actual', height: 'Altura Actual', kg: '(kg)', lbs: '(lbs)', cm: '(cm)', ftin: '(ft/in)' }
  };

  const getT = () => translations[document.documentElement.lang || 'en'] || translations.en;

  // Toggle Units
  document.querySelectorAll('.unit-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.unit-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      currentUnit = btn.dataset.unit;

      const t = getT();
      const weightLabel = document.getElementById('weightLabel');
      const heightLabel = document.getElementById('heightLabel');
      const metricHeight = document.getElementById('metricHeightGroup');
      const imperialHeight = document.getElementById('imperialHeightGroup');

      if (currentUnit === 'metric') {
        weightLabel.innerText = `${t.weight} ${t.kg}`;
        heightLabel.innerText = `${t.height} ${t.cm}`;
        metricHeight.classList.remove('hidden');
        imperialHeight.classList.add('hidden');
      } else {
        weightLabel.innerText = `${t.weight} ${t.lbs}`;
        heightLabel.innerText = `${t.height} ${t.ftin}`;
        metricHeight.classList.add('hidden');
        imperialHeight.classList.remove('hidden');
      }
      window.localStorage.setItem('bmiUnit', currentUnit);
    });
  });

  // Toggle Gender
  document.querySelectorAll('.gender-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.gender-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      currentGender = btn.dataset.gender;
    });
  });

  // Calculation Logic
  document.getElementById('calcBtn').addEventListener('click', () => {
    let weight = parseFloat(document.getElementById('weight').value);
    let age = parseInt(document.getElementById('age').value);
    let bmi, heightM;

    if (currentUnit === 'metric') {
      let heightCm = parseFloat(document.getElementById('height').value);
      if (!weight || !heightCm || !age) { alert('Please fill all fields'); return; }
      heightM = heightCm / 100;
      bmi = weight / (heightM * heightM);
    } else {
      let ft = parseFloat(document.getElementById('heightFt').value) || 0;
      let inch = parseFloat(document.getElementById('heightIn').value) || 0;
      if (!weight || (!ft && !inch) || !age) { alert('Please fill all fields'); return; }
      // lbs to kg
      let weightKg = weight * 0.453592;
      // ft/in to meters
      let totalInches = (ft * 12) + inch;
      heightM = totalInches * 0.0254;
      bmi = weightKg / (heightM * heightM);
      weight = weightKg; // For other formula calculations
    }

    // Formulas
    const bmr = currentGender === 'male' 
      ? 10 * weight + 6.25 * (heightM * 100) - 5 * age + 5
      : 10 * weight + 6.25 * (heightM * 100) - 5 * age - 161;
    
    const tdee = bmr * 1.2;
    const idealWeight = 22 * (heightM * heightM);
    const bodyFat = (1.20 * bmi) + (0.23 * age) - (currentGender === 'male' ? 16.2 : 5.4);

    const result = {
      bmi: bmi.toFixed(1),
      bmr: Math.round(bmr),
      tdee: Math.round(tdee),
      idealWeight: idealWeight.toFixed(1),
      bodyFat: bodyFat.toFixed(1)
    };

    window.dispatchEvent(new CustomEvent('bmiCalculated', { detail: result }));

    // Scroll to Result on Mobile - Fixed with Timeout and Target
    if (window.innerWidth < 1024) {
      setTimeout(() => {
        const resultSection = document.getElementById('bmiDisplay');
        if (resultSection) {
          resultSection.scrollIntoView({ 
            behavior: 'smooth', 
            block: 'center' 
          });
        }
      }, 100);
    }

    // Add to History
    sessionHistory.unshift({ bmi: result.bmi, date: new Date().toLocaleTimeString() });
    sessionHistory = sessionHistory.slice(0, 3);
    updateHistoryUI();
  });

  function updateHistoryUI() {
    const list = document.getElementById('historyList');
    list.innerHTML = sessionHistory.map(item => `
      <div class="flex justify-between items-center p-4 rounded-2xl bg-[var(--muted)]/50 border border-[var(--border)] text-[10px] font-black uppercase tracking-widest">
        <span class="text-[var(--accent)]">BMI: ${item.bmi}</span>
        <span class="opacity-30">${item.date}</span>
      </div>
    `).join('');
  }
</script>
