---
const { currentLocale } = Astro;
const lang = currentLocale || 'en';

const translations: Record<string, any> = {
  en: {
    title: 'Precision Calculator',
    weight: 'Current Weight (kg)',
    height: 'Current Height (cm)',
    age: 'Current Age (yrs)',
    gender: 'Biological Gender',
    calculate: 'Calculate BMI',
    male: 'Male',
    female: 'Female',
    history: 'Recent Sessions',
    error: 'Please fill out all fields.'
  },
  es: {
    title: 'Calculadora de Precisión',
    weight: 'Peso Actual (kg)',
    height: 'Altura Actual (cm)',
    age: 'Edad Actual (años)',
    gender: 'Género Biológico',
    calculate: 'Calcular IMC',
    male: 'Masculino',
    female: 'Femenino',
    history: 'Sesiones Recientes',
    error: 'Por favor complete todos los campos.'
  },
  fr: {
    title: 'Calculateur de Précision',
    weight: 'Poids Actuel (kg)',
    height: 'Taille Actuelle (cm)',
    age: 'Âge Actuel (ans)',
    gender: 'Genre Biologique',
    calculate: 'Calculer l\'IMC',
    male: 'Homme',
    female: 'Femme',
    history: 'Sessions Récentes',
    error: 'Veuillez remplir tous les champs.'
  },
  de: {
    title: 'Präzisionsrechner',
    weight: 'Aktuelles Gewicht (kg)',
    height: 'Aktuelle Größe (cm)',
    age: 'Aktuelles Alter (Jahre)',
    gender: 'Biologisches Geschlecht',
    calculate: 'BMI Berechnen',
    male: 'Männlich',
    female: 'Weiblich',
    history: 'Letzte Sitzungen',
    error: 'Bitte füllen Sie alle Felder aus.'
  },
  ko: {
    title: '정밀 계산기',
    weight: '현재 체중 (kg)',
    height: '현재 키 (cm)',
    age: '현재 나이 (세)',
    gender: '생물학적 성별',
    calculate: 'BMI 계산',
    male: '남성',
    female: '여성',
    history: '최근 기록',
    error: '모든 필드를 입력해 주세요.'
  },
  hi: {
    title: 'सटीक कैलकुलेटर',
    weight: 'आपका वजन (kg)',
    height: 'आपकी ऊंचाई (cm)',
    age: 'आपकी उम्र (वर्ष)',
    gender: 'लिंग',
    calculate: 'बीएमआई गणना करें',
    male: 'पुरुष',
    female: 'महिला',
    history: 'हाल के सत्र',
    error: 'कृपया सभी फ़ील्ड भरें।'
  }
};

const t = translations[lang] || translations.en;
---

<div id="calculator" class="glass-card p-6 md:p-10 space-y-10 h-full scroll-mt-24 border-2 border-[var(--border)] shadow-sm">
  <div class="flex items-center justify-between">
    <h2 class="text-xs font-black uppercase tracking-[0.2em] text-[var(--foreground)]">{t.title}</h2>
    <div class="flex gap-2">
    </div>
  </div>

  <div class="space-y-8">
    <div class="grid md:grid-cols-2 gap-8">
      <div class="space-y-4">
        <label class="text-[11px] font-black uppercase tracking-widest text-[var(--foreground)]">{t.weight}</label>
        <div class="relative">
          <input type="number" id="weight" placeholder="70" required class="matte-input px-6 py-4 placeholder:opacity-20 font-black text-lg" />
        </div>
      </div>
      <div class="space-y-4">
        <label class="text-[11px] font-black uppercase tracking-widest text-[var(--foreground)]">{t.height}</label>
        <div class="relative">
          <input type="number" id="height" placeholder="175" required class="matte-input px-6 py-4 placeholder:opacity-20 font-black text-lg" />
        </div>
      </div>
    </div>

    <div class="grid md:grid-cols-2 gap-8">
      <div class="space-y-4">
        <label class="text-[11px] font-black uppercase tracking-widest text-[var(--foreground)]">{t.age}</label>
        <div class="relative">
          <input type="number" id="age" placeholder="25" required class="matte-input px-6 py-4 placeholder:opacity-20 font-black text-lg" />
        </div>
      </div>
      <div class="space-y-4">
        <label class="text-[11px] font-black uppercase tracking-widest text-[var(--foreground)]">{t.gender}</label>
        <div class="grid grid-cols-2 gap-3">
          <button data-gender="male" class="gender-btn active py-4 px-6 rounded-xl border-2 border-[var(--border)] bg-[var(--muted)] text-[10px] font-black uppercase tracking-widest transition-all">
            {t.male}
          </button>
          <button data-gender="female" class="gender-btn py-4 px-6 rounded-xl border-2 border-[var(--border)] bg-transparent text-[10px] font-black uppercase tracking-widest transition-all">
            {t.female}
          </button>
        </div>
      </div>
    </div>

    <button id="calcBtn" class="w-full py-6 rounded-2xl bg-[var(--muted)] border-2 border-[var(--border)] text-[var(--foreground)] font-black uppercase text-sm tracking-[0.3em] hover:brightness-95 active:scale-[0.98] transition-all mt-4">
      {t.calculate}
    </button>
  </div>

  <div id="history" class="pt-10 border-t-2 border-[var(--border)]">
     <h3 class="text-[9px] font-black uppercase tracking-[0.3em] text-[var(--foreground)] mb-6 uppercase">{t.history}</h3>
     <div id="historyList" class="space-y-3">
        <!-- History items -->
     </div>
  </div>
</div>

<style>
  .gender-btn.active {
    background-color: var(--accent) !important;
    color: #121212 !important;
    border-color: var(--border) !important;
  }
  
  .dark .gender-btn.active {
    background-color: var(--accent) !important;
    color: var(--foreground) !important;
  }
</style>

<script is:inline>
  let currentGender = 'male';
  let sessionHistory = [];

  document.querySelectorAll('.gender-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.gender-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      currentGender = btn.dataset.gender;
    });
  });

  const calculate = () => {
    const weightVal = document.getElementById('weight').value;
    const heightVal = document.getElementById('height').value;
    const ageVal = document.getElementById('age').value;

    // Validation logic for mandatory fields
    if (!weightVal || !heightVal || !ageVal) {
      const errorMsg = document.documentElement.lang === 'hi' ? 'कृपया सभी फ़ील्ड भरें।' : 
                       document.documentElement.lang === 'es' ? 'Por favor complete todos los campos.' : 
                       'Please fill out all fields.';
      alert(errorMsg);
      return;
    }

    const weight = parseFloat(weightVal);
    const height = parseFloat(heightVal);
    const age = parseInt(ageVal);

    if (isNaN(weight) || isNaN(height) || isNaN(age)) return;

    const bmi = (weight / ((height / 100) ** 2)).toFixed(1);
    let bmr = (10 * weight) + (6.25 * height) - (5 * age);
    bmr = currentGender === 'male' ? bmr + 5 : bmr - 161;
    bmr = Math.round(bmr);

    const tdee = Math.round(bmr * 1.2);
    let ideal = currentGender === 'male' ? 52 + 1.9 * (((height / 2.54) - 60)) : 49 + 1.7 * (((height / 2.54) - 60));
    ideal = ideal.toFixed(1);

    const fat = (1.20 * bmi + 0.23 * age - 10.8 * (currentGender === 'male' ? 1 : 0) - 5.4).toFixed(1);
    const result = { bmi, bmr, tdee, idealWeight: ideal, bodyFat: fat };
    
    window.dispatchEvent(new CustomEvent('bmiCalculated', { detail: result }));

    sessionHistory.unshift({ ...result, date: new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }) });
    renderHistory();
  };

  const renderHistory = () => {
    const list = document.getElementById('historyList');
    const label = document.documentElement.lang === 'hi' ? 'बीएमआई' : 'BMI';
    list.innerHTML = sessionHistory.slice(0, 5).map(item => `
      <div class="flex justify-between items-center p-4 bg-[var(--muted)] rounded-xl text-[11px] border-2 border-[var(--border)] font-black">
        <span>${label}: ${item.bmi}</span>
        <span class="opacity-40 uppercase tracking-widest text-[9px]">${item.date}</span>
      </div>
    `).join('');
  };

  document.getElementById('calcBtn').addEventListener('click', calculate);
</script>
