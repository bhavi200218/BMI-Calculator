---
const { currentLocale } = Astro;
const lang = currentLocale || 'en';

const translations: Record<string, any> = {
  en: {
    eyebrow: 'Your Results',
    title: 'Health Profile',
    waiting: 'Enter your details and hit Calculate',
    bmi: 'BMI Score',
    bmr: 'Resting Metabolism',
    tdee: 'Daily Target',
    ideal: 'Ideal Weight',
    fat: 'Est. Body Fat',
    copy: 'Copy Report',
    share: 'Share',
    under: 'Underweight',
    normal: 'Healthy',
    over: 'Overweight',
    obese: 'Obese',
  },
  es: {
    eyebrow: 'Tus Resultados',
    title: 'Perfil de Salud',
    waiting: 'Ingresa tus datos y presiona Calcular',
    bmi: 'IMC',
    bmr: 'Metabolismo Basal',
    tdee: 'Objetivo Diario',
    ideal: 'Peso Ideal',
    fat: 'Grasa Corp.',
    copy: 'Copiar',
    share: 'Compartir',
    under: 'Bajo Peso',
    normal: 'Saludable',
    over: 'Sobrepeso',
    obese: 'Obesidad',
  },
  fr: {
    eyebrow: 'Vos Résultats',
    title: 'Profil de Santé',
    waiting: 'Entrez vos données et calculez',
    bmi: 'IMC',
    bmr: 'Métabolisme de Base',
    tdee: 'Objectif Quotidien',
    ideal: 'Poids Idéal',
    fat: 'Graisse Corp.',
    copy: 'Copier',
    share: 'Partager',
    under: 'Sous-poids',
    normal: 'Sain',
    over: 'Surpoids',
    obese: 'Obésité',
  },
  de: {
    eyebrow: 'Ihre Ergebnisse',
    title: 'Gesundheitsprofil',
    waiting: 'Geben Sie Ihre Daten ein und klicken Sie auf Berechnen',
    bmi: 'BMI-Wert',
    bmr: 'Grundumsatz',
    tdee: 'Tagesbedarf',
    ideal: 'Idealgewicht',
    fat: 'Körperfett',
    copy: 'Kopieren',
    share: 'Teilen',
    under: 'Untergewicht',
    normal: 'Normal',
    over: 'Übergewicht',
    obese: 'Adipositas',
  },
  ko: {
    eyebrow: '결과',
    title: '건강 프로필',
    waiting: '정보를 입력하고 계산하세요',
    bmi: 'BMI',
    bmr: '기초대사량',
    tdee: '일일 목표',
    ideal: '이상 체중',
    fat: '체지방',
    copy: '복사',
    share: '공유',
    under: '저체중',
    normal: '정상',
    over: '과체중',
    obese: '비만',
  },
  hi: {
    eyebrow: 'आपके परिणाम',
    title: 'स्वास्थ्य प्रोफ़ाइल',
    waiting: 'जानकारी भरें और गणना करें',
    bmi: 'बीएमआई',
    bmr: 'बेसल मेटाबॉलिज्म',
    tdee: 'दैनिक लक्ष्य',
    ideal: 'आदर्श वजन',
    fat: 'शरीर वसा',
    copy: 'कॉपी करें',
    share: 'साझा करें',
    under: 'कम वजन',
    normal: 'स्वस्थ',
    over: 'अधिक वजन',
    obese: 'मोटापा',
  },
};

const t = (translations as any)[lang] || translations.en;
---

<div id="resultStudio" class="melove-result-card flex flex-col h-full overflow-hidden">

  <!-- ── INITIAL STATE ─────────────────────────── -->
  <div id="initialState" class="flex-1 flex flex-col items-center justify-center gap-6 p-10 text-center min-h-[300px]">
    <div class="w-20 h-20 rounded-full border-2 border-dashed border-[var(--border)] flex items-center justify-center">
      <svg class="w-8 h-8 text-[var(--muted-foreground)] opacity-30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" />
      </svg>
    </div>
    <div class="space-y-3">
      <p class="text-xs font-display font-semibold uppercase tracking-[0.3em] text-[var(--accent)]">{t.eyebrow}</p>
      <p class="text-base text-[var(--muted-foreground)] font-semibold">{t.waiting}</p>
    </div>
  </div>

  <!-- ── RESULT STATE ──────────────────────────── -->
  <div id="resultContent" class="hidden flex-1 flex flex-col">

    <!-- Top Bar -->
    <div class="flex items-center justify-between gap-4 p-8 md:px-10 md:pt-10 pb-5 border-b border-[var(--border)]">
      <div>
        <p class="text-xs font-display font-semibold uppercase tracking-[0.3em] text-[var(--accent)]">{t.eyebrow}</p>
        <h3 class="text-2xl font-display font-bold uppercase text-[var(--foreground)]">{t.title}</h3>
      </div>
      <span id="categoryLabel" class="px-5 py-2 rounded-full bg-[var(--accent)] text-[var(--accent-foreground)] text-xs font-display font-semibold uppercase tracking-widest whitespace-nowrap shadow-[var(--shadow-accent)]">
        --
      </span>
    </div>

    <!-- BMI Big Number -->
    <div class="flex-1 flex flex-col justify-between p-7 md:px-10 md:pb-10 space-y-8">

      <div class="text-center py-4">
        <div id="bmiDisplay" class="text-[6.5rem] md:text-[8rem] font-display font-bold tracking-tighter leading-none text-[var(--foreground)]">
          --.-
        </div>
        <p class="text-xs font-display font-semibold uppercase tracking-[0.3em] text-[var(--muted-foreground)] mt-4">{t.bmi}</p>
      </div>

      <!-- BMI scale bar -->
      <div class="space-y-3">
        <div class="relative h-2.5 bg-[var(--muted)] rounded-full overflow-hidden border border-[var(--border)]">
          <!-- colour zones -->
          <div class="absolute inset-0 flex rounded-full overflow-hidden">
            <div class="flex-1 bg-sky-400/40"></div>
            <div class="flex-[1.5] bg-emerald-400/40"></div>
            <div class="flex-[1] bg-amber-400/40"></div>
            <div class="flex-[1.5] bg-rose-400/40"></div>
          </div>
          <div id="scaleMarker" class="absolute top-0 bottom-0 w-1.5 bg-[var(--accent)] rounded-full shadow-[0_0_8px_var(--accent)] transition-all duration-1000 ease-out" style="left: 0%"></div>
        </div>
        <div class="flex justify-between text-[11px] font-display font-semibold uppercase tracking-wide text-[var(--muted-foreground)]">
          <span>{t.under}</span>
          <span class="text-emerald-700 dark:text-emerald-400 font-bold">{t.normal}</span>
          <span>{t.over}</span>
          <span>{t.obese}</span>
        </div>
      </div>

      <!-- Stats Grid -->
      <div class="grid grid-cols-2 gap-4">
        {[
          { id: 'bmrDisplay', label: t.bmr, unit: 'kcal', defaultVal: '----' },
          { id: 'tdeeDisplay', label: t.tdee, unit: 'kcal', defaultVal: '----' },
          { id: 'idealDisplay', label: t.ideal, unit: 'kg', defaultVal: '--.-' },
          { id: 'fatDisplay', label: t.fat, unit: '%', defaultVal: '--.-' },
        ].map(s => (
          <div class="p-5 rounded-[var(--radius-sm)] bg-[var(--muted)] border border-[var(--border)] space-y-2 hover:border-[var(--accent)] transition-colors duration-200">
            <p class="text-xs font-display font-semibold uppercase tracking-widest text-[var(--muted-foreground)]">{s.label}</p>
            <p id={s.id} class="text-2xl font-display font-bold text-[var(--foreground)]">
              {s.defaultVal} <span class="text-sm font-sans font-medium opacity-40">{s.unit}</span>
            </p>
          </div>
        ))}
      </div>

      <!-- Action Buttons -->
      <div class="grid grid-cols-2 gap-4 pt-2">
        <button id="copyBtn" class="py-5 rounded-[var(--radius-sm)] bg-[var(--muted)] border-[1.5px] border-[var(--border)] text-xs font-display font-bold uppercase tracking-widest hover:border-[var(--accent)] hover:bg-[var(--card-hover)] transition-all duration-200 flex items-center justify-center gap-2 cursor-pointer text-[var(--foreground)]">
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>
          {t.copy}
        </button>
        <button id="shareBtn" class="py-5 rounded-[var(--radius-sm)] bg-[var(--foreground)] text-[var(--background)] text-xs font-display font-bold uppercase tracking-widest hover:opacity-85 transition-all duration-200 flex items-center justify-center gap-2 cursor-pointer shadow-[var(--shadow-card)]">
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" /></svg>
          {t.share}
        </button>
      </div>

    </div>
  </div>
</div>

<style>
  .melove-result-card {
    background: var(--card);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border: 1.5px solid var(--border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-soft);
    transition: box-shadow 0.2s ease;
    min-height: 480px;
  }
</style>

<script is:inline>
  let lastResult = null;

  window.addEventListener('bmiCalculated', (e) => {
    if (e.detail) {
      lastResult = e.detail;
      renderResults();
    }
  });

  window.addEventListener('calculationCompleted', (e) => {
    if (e.detail && e.detail.primary && e.detail.primary.value) {
      const primaryVal = e.detail.primary.value;
      const secondary = e.detail.secondary || [];
      const getVal = (name) => {
        const item = secondary.find(s => {
          const lStr = (typeof s.label === 'string') ? s.label : (s.label.en || Object.values(s.label)[0] || '');
          return lStr.toLowerCase().includes(name.toLowerCase());
        });
        return item ? item.value : '--';
      };
      lastResult = {
        bmi: primaryVal,
        bmr: getVal('bmr') !== '--' ? getVal('bmr') : (getVal('metabolism') !== '--' ? getVal('metabolism') : '1650'),
        tdee: getVal('tdee') !== '--' ? getVal('tdee') : (getVal('energy') !== '--' ? getVal('energy') : '1980'),
        idealWeight: getVal('ideal'),
        bodyFat: getVal('fat') !== '--' ? getVal('fat') : '18.0'
      };
      renderResults();
    }
  });

  window.addEventListener('bmiUnitChanged', () => {
    if (lastResult) {
      renderResults();
    }
  });

  function renderResults() {
    if (!lastResult) return;
    const { bmi, bmr, tdee, idealWeight, bodyFat } = lastResult;

    document.getElementById('initialState').classList.add('hidden');
    const rc = document.getElementById('resultContent');
    rc.classList.remove('hidden');
    rc.classList.add('animate-in');

    const bmiNum = parseFloat(bmi);
    const isImperial = (localStorage.getItem('bmiUnit') || 'metric') === 'imperial';

    document.getElementById('bmiDisplay').textContent = bmi;
    document.getElementById('bmrDisplay').innerHTML = `${bmr} <span class="text-xs font-sans font-medium opacity-40">kcal</span>`;
    document.getElementById('tdeeDisplay').innerHTML = `${tdee} <span class="text-xs font-sans font-medium opacity-40">kcal</span>`;

    const displayIdeal = isImperial
      ? (parseFloat(idealWeight) * 2.20462).toFixed(1)
      : idealWeight;
    const idealUnit = isImperial ? 'lbs' : 'kg';
    document.getElementById('idealDisplay').innerHTML = `${displayIdeal} <span class="text-xs font-sans font-medium opacity-40">${idealUnit}</span>`;
    document.getElementById('fatDisplay').innerHTML = `${bodyFat} <span class="text-xs font-sans font-medium opacity-40">%</span>`;

    // Scale
    let pct = ((bmiNum - 15) / (40 - 15)) * 100;
    pct = Math.min(Math.max(pct, 1), 97);
    document.getElementById('scaleMarker').style.left = `${pct}%`;

    // Category
    const categories = {
      en: { under: 'Underweight', normal: 'Healthy', over: 'Overweight', obese: 'Obese' },
      hi: { under: 'कम वजन', normal: 'स्वस्थ', over: 'अधिक वजन', obese: 'मोटापा' },
      es: { under: 'Bajo Peso', normal: 'Saludable', over: 'Sobrepeso', obese: 'Obesidad' },
      fr: { under: 'Sous-poids', normal: 'Sain', over: 'Surpoids', obese: 'Obésité' },
      de: { under: 'Untergewicht', normal: 'Normal', over: 'Übergewicht', obese: 'Adipositas' },
      ko: { under: '저체중', normal: '정상', over: '과체중', obese: '비만' }
    };
    const lang = document.documentElement.lang || 'en';
    const cat = categories[lang] || categories.en;
    let category = bmiNum < 18.5 ? cat.under : bmiNum < 25 ? cat.normal : bmiNum < 30 ? cat.over : cat.obese;

    document.getElementById('categoryLabel').textContent = category;

    // Share
    document.getElementById('shareBtn').onclick = async () => {
      try { await navigator.share({ title: 'Real BMI Result', text: `BMI: ${bmi} (${category}). BMR: ${bmr} kcal.`, url: location.href }); } catch {}
    };

    // Copy
    document.getElementById('copyBtn').onclick = () => {
      const report = `BMI: ${bmi} (${category})\nBMR: ${bmr} kcal\nTDEE: ${tdee} kcal\nIdeal Weight: ${displayIdeal} ${idealUnit}\nBody Fat: ${bodyFat}%`;
      navigator.clipboard.writeText(report).then(() => {
        const btn = document.getElementById('copyBtn');
        const orig = btn.innerHTML;
        btn.innerHTML = `<svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> ✓ Copied!`;
        setTimeout(() => btn.innerHTML = orig, 2000);
      });
    };
  }
</script>
