---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import UniversalCalculator from '../../components/UniversalCalculator.astro';
import CalculatorResult from '../../components/CalculatorResult.astro';
import { calculators, locales, type Locale, type CalculatorConfig } from '../../utils/calculators';

// Define static paths for all 15 calculators across 6 languages
export function getStaticPaths() {
  const paths: any[] = [];
  for (const lang of locales) {
    for (const calc of calculators) {
      paths.push({
        params: { lang, calculator: calc.slug },
        props: { calc, lang }
      });
    }
  }
  return paths;
}

interface Props {
  calc: CalculatorConfig;
  lang: Locale;
}

const { calc, lang } = Astro.props;

const pageTitle = calc.title[lang] || calc.title['en'];
const pageDesc = calc.description[lang] || calc.description['en'];
const canonicalUrl = `https://realbmicalculator.com/${lang}/${calc.slug}`;

const localizedIntro = {
  en: 'Built for quick health analytics and compliance. Real-time computations.',
  es: 'Diseñado para análisis rápidos de salud y cumplimiento. Cálculos en tiempo real.',
  fr: 'Conçu pour des analyses de santé rapides et conformes. Calculs en temps réel.',
  de: 'Entwickelt für schnelle Gesundheitsanalysen und Compliance. Echtzeitberechnungen.',
  ko: '빠른 건강 분석과 규정 준수를 위해 설계되었습니다. 실시간 계산 제공.',
  hi: 'तेज़ स्वास्थ्य विश्लेषण और अनुपालन के लिए बनाया गया। वास्तविक समय में गणना।'
};

// WebApplication Schema for SEO
const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": calc.name[lang] || calc.name['en'],
  "url": canonicalUrl,
  "description": pageDesc,
  "applicationCategory": "HealthApplication",
  "browserRequirements": "Requires JavaScript. Requires HTML5.",
  "operatingSystem": "All"
};
---

<Layout 
  title={pageTitle}
  description={pageDesc}
  canonicalURL={canonicalUrl}
>
  <!-- Inject WebApplication JSON-LD dynamically inside Layout context -->
  <script type="application/ld+json" set:html={JSON.stringify(webAppSchema)} slot="json-ld"></script>
  
  <Navbar />
  
  <main class="pt-26 md:pt-30 pb-20 px-4 md:px-6 relative overflow-x-hidden">
    <div class="max-w-7xl mx-auto space-y-12">
      
      <!-- Top Header text -->
      <div class="text-center space-y-4 max-w-3xl mx-auto">
        <h1 class="text-4xl md:text-5xl font-display font-bold uppercase tracking-tight text-[var(--foreground)] animate-in" style="animation-delay:0ms">
          {calc.name[lang] || calc.name['en']}
        </h1>
        <p class="text-sm md:text-base text-[var(--muted-foreground)] leading-relaxed font-sans font-medium animate-in max-w-2xl mx-auto" style="animation-delay:50ms">
          {pageDesc} {localizedIntro[lang] || localizedIntro.en}
        </p>
      </div>

      <!-- Main Calculator Layout -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 items-stretch animate-in" style="animation-delay:100ms">
        <UniversalCalculator calculator={calc} lang={lang} />
        <CalculatorResult lang={lang} />
      </div>

    </div>
  </main>
</Layout>
