---
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar.astro';
import PageShell from '../../../components/PageShell.astro';
import HubGrid from '../../../components/HubGrid.astro';
import { blogArticles } from '../../../utils/blogArticles';
import { type Locale } from '../../../utils/calculators';

export function getStaticPaths() {
  const supportedLocales = ['en', 'es', 'fr', 'de', 'ko', 'hi'];

  return supportedLocales.flatMap((locale) =>
    Object.keys(blogArticles).map((slug) => ({
      params: { lang: locale, slug }
    }))
  );
}

const { params } = Astro;
const lang = (params.lang || 'en') as Locale;
const { slug } = params;
const article = blogArticles[slug] || blogArticles['bmi-chart-for-men-women'];
const articleTitle = article.title[lang] || article.title.en;
const articleCategory = article.category[lang] || article.category.en;
const articleDescription = article.description[lang] || article.description.en;
const articleBody = article.body[lang] || article.body.en;

const canonicalUrl = `https://realbmicalculator.com/${lang}/blog/${slug}`;

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": articleTitle,
  "description": articleDescription,
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": canonicalUrl
  },
  "author": {
    "@type": "Organization",
    "name": "Real BMI Health Editorial Team",
    "url": `https://realbmicalculator.com/${lang}/about`
  },
  "publisher": {
    "@type": "Organization",
    "name": "Real BMI",
    "logo": {
      "@type": "ImageObject",
      "url": "https://realbmicalculator.com/favicon.svg"
    }
  },
  "datePublished": "2026-01-01",
  "dateModified": new Date().toISOString().split('T')[0]
};

const homeLabels = {
  en: 'Home',
  es: 'Inicio',
  fr: 'Accueil',
  de: 'Startseite',
  ko: '홈',
  hi: 'होम'
};

const backToCalculatorLabels = {
  en: 'Back to Calculator',
  es: 'Volver al calculador',
  fr: 'Retour au calculateur',
  de: 'Zurück zum Rechner',
  ko: '계산기로 돌아가기',
  hi: 'कैलकुलेटर पर वापस जाएं'
};
---

<Layout 
    title={`${articleTitle} | Real BMI`}
    description={articleDescription}
    canonicalURL={canonicalUrl}
>
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} slot="json-ld"></script>
    <Navbar />
    <PageShell
      title={articleTitle}
      eyebrow={articleCategory}
      description={articleDescription}
      returnUrl={`/${lang}`}
      returnLabel={homeLabels[lang] || homeLabels.en}
    >
      <div class="space-y-10 prose prose-zinc dark:prose-invert max-w-none text-[var(--muted-foreground)] leading-relaxed text-lg font-medium opacity-90">
        {articleBody.map((paragraph: string) => (
          <p>{paragraph}</p>
        ))}

        <div class="pt-8 border-t border-[var(--border)] flex flex-wrap items-center justify-between gap-4">
          <a href={`/${lang}#calculator`} class="calc-btn-gradient px-8 py-4 rounded-xl font-black uppercase text-[10px] tracking-widest inline-block transition-all hover:scale-105 active:scale-95">
            {backToCalculatorLabels[lang] || backToCalculatorLabels.en}
          </a>
        </div>

        <div class="pt-12 border-t border-[var(--border)]">
          <HubGrid lang={lang} />
        </div>
      </div>
    </PageShell>
</Layout>
