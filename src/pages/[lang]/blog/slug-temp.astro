---
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar.astro';
import PageShell from '../../../components/PageShell.astro';
import { blogArticles } from '../../../utils/blogArticles';

export function getStaticPaths() {
  const supportedLocales = ['en', 'es', 'fr', 'de', 'ko', 'hi'];

  return supportedLocales.flatMap((locale) =>
    Object.keys(blogArticles).map((slug) => ({
      params: { lang: locale, slug },
      props: { slug }
    }))
  );
}

const { currentLocale, params } = Astro;
const lang = params.lang || currentLocale || 'en';
const { slug } = params;
const article = blogArticles[slug] || blogArticles['bmi-chart-for-men-women'];
const articleTitle = article.title[lang] || article.title.en;
const articleCategory = article.category[lang] || article.category.en;
const articleDescription = article.description[lang] || article.description.en;
const articleBody = article.body[lang] || article.body.en;

const homeLabels = {
  en: 'Home',
  es: 'Inicio',
  fr: 'Accueil',
  de: 'Startseite',
  ko: '홈',
  hi: 'होम'
};

const backToCalculatorLabels = {
  en: 'Back to Calculator',
  es: 'Volver al calculador',
  fr: 'Retour au calculateur',
  de: 'Zurück zum Rechner',
  ko: '계산기로 돌아가기',
  hi: 'कैलकुलेटर पर वापस जाएं'
};
---

<Layout
  title={`${articleTitle} | Real BMI`}
  description={articleDescription}
>
  <Navbar />
  <PageShell
    title={articleTitle}
    eyebrow={articleCategory}
    description={articleDescription}
    returnUrl={`/${lang}`}
    returnLabel={homeLabels[lang] || homeLabels.en}
  >
    <div class="space-y-10 prose prose-zinc dark:prose-invert max-w-none text-[var(--muted-foreground)] leading-relaxed text-lg font-medium opacity-90">
      {articleBody.map((paragraph) => (
        <p>{paragraph}</p>
      ))}

      <div class="pt-8 border-t border-[var(--border)]">
        <a href={`/${lang}#calculator`} class="calc-btn-gradient px-8 py-4 rounded-xl font-black uppercase text-[10px] tracking-widest inline-block transition-all hover:scale-105 active:scale-95">
          {backToCalculatorLabels[lang] || backToCalculatorLabels.en}
        </a>
      </div>
    </div>
  </PageShell>
</Layout>
