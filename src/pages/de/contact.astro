---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
---

<Layout title="Kontakt | Real BMI Calculator">
    <Navbar />
    <main class="pt-40 pb-20 px-6">
        <div class="max-w-7xl mx-auto">
          <div class="space-y-6 mb-12">
            <a href="/de" class="inline-flex items-center gap-2 text-[10px] font-black uppercase tracking-[0.28em] text-[var(--accent)] hover:text-[var(--foreground)] transition-colors">
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
              Home
            </a>
            <p class="text-xs font-semibold uppercase tracking-[0.32em] text-[var(--accent)]">Kontakt</p>
            <h1 class="text-4xl sm:text-5xl md:text-6xl font-display font-black uppercase tracking-tight leading-tight text-[var(--foreground)]">Kontakt</h1>
            <p class="max-w-3xl text-base md:text-lg leading-relaxed text-[var(--muted-foreground)]">Bei Fragen zu den Rechnern oder der Methodik erreichen Sie uns per E-Mail. Klicken Sie auf die Schaltfläche, um Ihr E-Mail-Programm zu öffnen.</p>
          </div>

          <div class="grid gap-10 lg:grid-cols-[1.45fr_0.85fr] items-start">
            <div class="space-y-8">
              <div class="prose prose-zinc dark:prose-invert max-w-none text-[var(--muted-foreground)] leading-relaxed text-lg md:text-xl font-medium opacity-90">
                <p><strong>Bhawanshi Dosi</strong> — Full Stack Developer. Ich unterstütze bei Fragen zur Genauigkeit der Rechner und Methodik.</p>
                <p>Für Support oder Feedback klicken Sie bitte auf die Schaltfläche, um eine E-Mail zu senden.</p>
              </div>

              <div class="grid gap-4 sm:grid-cols-2">
                <div class="rounded-[var(--radius)] border border-[var(--border)] bg-[var(--card)] p-6">
                  <p class="text-sm uppercase tracking-[0.3em] font-bold text-[var(--accent)]">E-Mail</p>
                  <p class="mt-3 text-base font-semibold text-[var(--foreground)]">Klicken zum Senden</p>
                </div>
                <div class="rounded-[var(--radius)] border border-[var(--border)] bg-[var(--card)] p-6">
                  <p class="text-sm uppercase tracking-[0.3em] font-bold text-[var(--accent)]">Antwortzeit</p>
                  <p class="mt-3 text-base font-semibold text-[var(--foreground)]">In der Regel innerhalb von 24 Stunden an Werktagen</p>
                </div>
              </div>
            </div>

            <aside class="rounded-[var(--radius)] border border-[var(--border)] bg-[var(--card)] p-8 shadow-[var(--shadow-soft)]">
              <p class="text-xs uppercase tracking-[0.32em] font-semibold text-[var(--accent)]">Kontakt</p>
              <h2 class="mt-4 text-3xl font-black text-[var(--foreground)]">E-Mail Support</h2>
              <p class="mt-4 text-sm leading-relaxed text-[var(--muted-foreground)]">Klicken Sie unten, um Ihr Standard-E-Mail-Programm mit vorausgefüllter Empfängeradresse zu öffnen.</p>
              <a href="mailto:vecna312002@gmail.com" class="mt-8 inline-flex w-full items-center justify-center rounded-full border border-[var(--accent)] bg-[var(--accent)]/10 px-5 py-3 text-sm font-semibold uppercase tracking-[0.2em] text-[var(--accent)] transition hover:bg-[var(--accent)]/15">E-Mail senden</a>
            </aside>
          </div>
        </div>
    </main>
</Layout>
