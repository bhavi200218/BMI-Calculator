---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
---

<Layout title="404 - Page Not Found | BMI Calculator Pro">
    <Navbar />
    <main class="h-screen flex flex-col items-center justify-center space-y-6">
        <h1 class="text-9xl font-black tracking-tighter opacity-10">404</h1>
        <p class="text-xl font-bold uppercase tracking-widest text-[var(--muted-foreground)]">Page Not Found</p>
        <a href="/" class="btn-primary max-w-xs px-10">Go Home</a>
    </main>
</Layout>
