---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import PageShell from '../../components/PageShell.astro';
---

<Layout 
    title="About Real BMI - Precision Health Calculator Mission"
    description="Discover the mission behind Real BMI Calculator. Built by Bhawanshi Dosi to provide clinical-grade health metrics, accurate BMI calculations, and data-driven wellness insights using WHO standards."
>
    <Navbar />
    <PageShell
      title="About Real BMI"
      eyebrow="Precision Health Analytics Platform"
      description="Real BMI enables trusted BMI, BMR, TDEE and body composition tracking with clinical standards and global health guidance."
      returnUrl="/en"
      returnLabel="Home"
    >
      <div class="grid gap-10 lg:grid-cols-[1.4fr_0.85fr] items-start">
        <div class="space-y-10">
          <div class="space-y-6 prose prose-zinc dark:prose-invert max-w-none text-[var(--muted-foreground)] leading-relaxed text-lg md:text-xl font-medium opacity-90">
            <p><strong>Real BMI Calculator</strong> was developed by <strong>Bhawanshi Dosi</strong> to provide precision health tools that empower people to understand their body and make informed wellness decisions.</p>
            <p>We build clinically-informed calculators using global health standards from the <strong>WHO</strong> and <strong>CDC</strong>, so users can trust the results without sacrificing privacy.</p>
            <p>Real BMI offers a complete suite of health analysis: Body Mass Index, Basal Metabolic Rate, Total Daily Energy Expenditure, and body composition guidance designed for modern wellness planning.</p>
            <p>All calculations are performed instantly in the browser. We do not store your personal health data on our servers, so your results remain private and secure.</p>
          </div>

          <div class="grid gap-6 sm:grid-cols-2">
            <div class="rounded-[var(--radius)] border border-[var(--border)] bg-[var(--card)] p-6">
              <p class="text-sm uppercase tracking-[0.3em] font-bold text-[var(--accent)]">Clinical accuracy</p>
              <p class="mt-4 text-base text-[var(--foreground)] font-semibold">Built on evidence-based formulas and global benchmarks.</p>
            </div>
            <div class="rounded-[var(--radius)] border border-[var(--border)] bg-[var(--card)] p-6">
              <p class="text-sm uppercase tracking-[0.3em] font-bold text-[var(--accent)]">Privacy-first</p>
              <p class="mt-4 text-base text-[var(--foreground)] font-semibold">Calculator inputs stay on your device, never on our servers.</p>
            </div>
            <div class="rounded-[var(--radius)] border border-[var(--border)] bg-[var(--card)] p-6">
              <p class="text-sm uppercase tracking-[0.3em] font-bold text-[var(--accent)]">Global by design</p>
              <p class="mt-4 text-base text-[var(--foreground)] font-semibold">Designed for international users and multiple measurement systems.</p>
            </div>
            <div class="rounded-[var(--radius)] border border-[var(--border)] bg-[var(--card)] p-6">
              <p class="text-sm uppercase tracking-[0.3em] font-bold text-[var(--accent)]">Actionable insight</p>
              <p class="mt-4 text-base text-[var(--foreground)] font-semibold">Practical BMI and metabolic analysis for healthier choices.</p>
            </div>
          </div>
        </div>

        <aside class="rounded-[var(--radius)] border border-[var(--border)] bg-[var(--card)] p-8 shadow-[var(--shadow-soft)]">
          <p class="text-xs uppercase tracking-[0.32em] font-semibold text-[var(--accent)]">What we offer</p>
          <h2 class="mt-4 text-3xl font-black text-[var(--foreground)]">Trusted health metrics</h2>
          <p class="mt-4 text-base leading-relaxed text-[var(--muted-foreground)]">Real BMI is built to help people compare their health numbers against accepted medical standards and understand what the numbers mean.</p>

          <div class="mt-8 space-y-4 text-sm text-[var(--muted-foreground)] leading-relaxed">
            <p><strong>Accurate results:</strong> Reliable BMI, BMR, TDEE and body fat insights.</p>
            <p><strong>Immediate privacy:</strong> No personal inputs are stored or shared.</p>
            <p><strong>Clear guidance:</strong> Designed for people looking for practical health tools, not vague buzzwords.</p>
          </div>

          <a href="/en/contact" class="mt-8 inline-flex items-center justify-center w-full rounded-full border border-[var(--accent)] bg-[var(--accent)]/10 px-5 py-3 text-sm font-semibold uppercase tracking-[0.2em] text-[var(--accent)] transition hover:bg-[var(--accent)]/15">Contact support</a>
        </aside>
      </div>
    </PageShell>
</Layout>
