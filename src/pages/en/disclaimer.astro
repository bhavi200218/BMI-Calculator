---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
---

<Layout title="Medical Disclaimer | BMI PRO">
    <Navbar />
    <main class="pt-40 pb-20 px-6 max-w-4xl mx-auto space-y-12 text-center">
        <a href="/en" class="text-[10px] font-black uppercase tracking-widest text-[var(--foreground)] flex items-center gap-2 hover:translate-x-[-4px] transition-transform w-fit mx-auto">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
            Return Home
        </a>
        <h1 class="text-5xl font-black tracking-tighter uppercase">Medical Disclaimer</h1>
        <div class="glass-card bg-[var(--muted)] border-[var(--border)] p-12 space-y-8">
            <p class="text-2xl font-black text-[var(--foreground)] uppercase tracking-widest">Legal Health Notice</p>
            <p class="text-[var(--muted-foreground)] leading-relaxed max-w-2xl mx-auto text-lg font-bold opacity-80">
                The content on BMI PRO is for informational purposes only.
            </p>
        </div>
    </main>
</Layout>
