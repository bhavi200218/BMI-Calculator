---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import PageShell from '../../components/PageShell.astro';
---

<Layout 
    title="Medical Disclaimer | Real BMI"
    description="Important medical disclaimer for Real BMI users. Our results are informational and not a substitute for professional medical advice."
>
    <Navbar />
    <PageShell
      title="Medical Disclaimer"
      eyebrow="Important health notice"
      description="Understand how Real BMI provides educational health estimates and why you should consult a qualified professional for medical decisions."
      returnUrl="/en"
      returnLabel="Home"
    >
      <div class="space-y-8 prose prose-zinc dark:prose-invert max-w-none text-[var(--muted-foreground)] leading-relaxed text-lg md:text-xl font-medium opacity-90">
        <p>The information provided by <strong>Real BMI</strong> is intended for general health awareness and informational use only. It does not replace personalized medical advice.</p>
        <h2>Not medical advice</h2>
        <p>Our BMI, BMR, and TDEE estimates are educational tools. They are not diagnostic and should not be used to make health decisions without consulting a qualified healthcare professional.</p>
        <h2>Consult your provider</h2>
        <p>If you have any health concerns or questions about your results, please speak with a physician or registered dietitian. Your individual health circumstances are unique.</p>
        <h2>Limitation of liability</h2>
        <p>Real BMI is not responsible for decisions made based on calculator results. Use the site as a resource to support your wellness goals, not as a medical treatment plan.</p>
      </div>
    </PageShell>
</Layout>
