---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
---

<Layout 
    title="Contact Real BMI Calculator | Support & Feedback"
    description="Contact the Real BMI Calculator team for support, feedback, or questions about our precision health tools. Get help with BMI, BMR, TDEE calculations."
>
    <Navbar />
    <main class="pt-32 pb-20 px-6 max-w-4xl mx-auto space-y-12">
        <div class="space-y-4">
            <a href="/en" class="text-[10px] font-black uppercase tracking-widest text-[var(--accent)] flex items-center gap-2 hover:translate-x-[-4px] transition-transform">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
                Return Home
            </a>
            <h1 class="text-5xl md:text-7xl font-black tracking-tighter uppercase text-[var(--foreground)]">Contact Us</h1>
            <p class="text-xs font-black uppercase tracking-[0.3em] text-[var(--accent)]">Get In Touch</p>
        </div>
        
        <div class="glass-card p-10 space-y-8 border-2 border-[var(--border)]">
            <div class="space-y-4">
                <h2 class="text-3xl font-black tracking-tighter uppercase">Contact & Support</h2>
                <p class="text-xl font-black tracking-tight text-[var(--foreground)]">Real BMI Calculator</p>
                <p class="text-sm font-black uppercase tracking-widest opacity-40">Precision health tools support</p>
            </div>

            <p class="text-lg text-[var(--muted-foreground)] leading-relaxed font-medium opacity-80">
                Have questions about BMI, BMR, TDEE, body fat, or our nutrition calculators? Our team is here to help you understand the results, improve your health tracking, and use Real BMI with confidence.
            </p>

            <div class="space-y-4">
                <p class="text-lg text-[var(--muted-foreground)] leading-relaxed font-medium opacity-80">
                    For support, feedback, or product inquiries, please contact us at:
                </p>
                <a href="mailto:vecna312002@gmail.com" class="inline-flex items-center gap-3 text-lg font-black text-[var(--foreground)] hover:opacity-70 transition-opacity group">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                    vecna312002@gmail.com
                    <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
                </a>
                <p class="text-sm text-[var(--muted-foreground)] opacity-70">
                    Please include the calculator name and your question to help us respond faster.
                </p>
            </div>

            <div class="pt-6 border-t border-[var(--border)]">
                <p class="text-sm text-[var(--muted-foreground)] opacity-70">
                    Real BMI delivers evidence-based health tracking and educational insights. This site is not a substitute for medical advice.
                </p>
            </div>
        </div>
    </main>
</Layout>
