---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import PageShell from '../../components/PageShell.astro';
---

<Layout 
    title="Contact Real BMI Calculator | Support & Feedback"
    description="Contact the Real BMI Calculator team for support, feedback, or questions about our precision health tools. Get help with BMI, BMR, TDEE calculations."
>
    <Navbar />
    <PageShell
      title="Contact Us"
      eyebrow="Support for Real BMI"
      description="Reach out for help with calculators, accuracy questions, and health insight requests."
      returnUrl="/en"
      returnLabel="Home"
    >
      <div class="grid gap-10 lg:grid-cols-[1.45fr_0.85fr] items-start">
        <div class="space-y-8">
          <div class="space-y-5 prose prose-zinc dark:prose-invert max-w-none text-[var(--muted-foreground)] leading-relaxed text-lg md:text-xl font-medium opacity-90">
            <p>Need help understanding your BMI, BMR, TDEE, body fat, or nutrition estimates? Our team is ready to support your wellness journey with clear answers and fast guidance.</p>
            <p>For questions about calculator accuracy, methodology, or how to interpret your results, send a message with the tool name and your goal.</p>
          </div>

          <div class="grid gap-4 sm:grid-cols-2">
            <div class="rounded-[var(--radius)] border border-[var(--border)] bg-[var(--card)] p-6">
              <p class="text-xs uppercase tracking-[0.28em] font-semibold text-[var(--accent)]">Response time</p>
              <p class="mt-3 text-base font-semibold text-[var(--foreground)]">Typically within 24 hours on business days</p>
            </div>
            <div class="rounded-[var(--radius)] border border-[var(--border)] bg-[var(--card)] p-6">
              <p class="text-xs uppercase tracking-[0.28em] font-semibold text-[var(--accent)]">Message</p>
              <p class="mt-3 text-base text-[var(--muted-foreground)] leading-relaxed">For professional inquiries, please connect with me on <a href="https://www.linkedin.com/in/bhawanshi-dosi" target="_blank" class="text-[var(--accent)] hover:underline">LinkedIn</a>.</p>
            </div>
          </div>

          <div class="rounded-[var(--radius)] border border-[var(--border)] bg-[var(--card)] p-6">
            <h2 class="text-2xl font-black text-[var(--foreground)]">What to include</h2>
            <p class="mt-3 text-base text-[var(--muted-foreground)] leading-relaxed">Please include the calculator name, your current goal, and any specific question so we can respond with the most useful advice.</p>
          </div>
        </div>

        <aside class="rounded-[var(--radius)] border border-[var(--border)] bg-[var(--card)] p-8 shadow-[var(--shadow-soft)]">
          <p class="text-xs uppercase tracking-[0.32em] font-semibold text-[var(--accent)]">Contact details</p>
          <h2 class="mt-4 text-3xl font-black text-[var(--foreground)]">Email support</h2>
          <p class="mt-4 text-sm leading-relaxed text-[var(--muted-foreground)]">For professional inquiries, please connect with me on <a href="https://www.linkedin.com/in/bhawanshi-dosi" target="_blank" class="text-[var(--accent)] hover:underline">LinkedIn</a>.</p>
          <a href="mailto:vecna312002@gmail.com" class="mt-8 inline-flex w-full items-center justify-center rounded-full border border-[var(--accent)] bg-[var(--accent)]/10 px-5 py-3 text-sm font-semibold uppercase tracking-[0.2em] text-[var(--accent)] transition hover:bg-[var(--accent)]/15">Email support</a>
          <div class="mt-8 space-y-3 text-sm text-[var(--muted-foreground)] leading-relaxed">
            <p><strong>Note:</strong> This is the best way to receive calculator support and product feedback.</p>
            <p>All inquiries are reviewed by our team to improve accuracy and usability across the site.</p>
          </div>
        </aside>
      </div>
    </PageShell>
</Layout>
