---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
---

<Layout title="Avertissement Médical | BMI PRO">
    <Navbar />
    <main class="pt-40 pb-20 px-6 max-w-4xl mx-auto space-y-12 text-center">
        <a href="/fr" class="text-[10px] font-black uppercase tracking-widest text-[var(--foreground)] flex items-center gap-2 hover:translate-x-[-4px] transition-transform w-fit mx-auto">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
            Retour à l'accueil
        </a>
        <h1 class="text-5xl font-black tracking-tighter uppercase">Avertissement Médical</h1>
        <div class="glass-card bg-red-50 dark:bg-red-950/20 border-red-100 dark:border-red-900/50 p-12 space-y-8">
            <p class="text-2xl font-black text-red-600 dark:text-red-400 uppercase tracking-widest">Avis de Santé Légal</p>
            <p class="text-[var(--muted-foreground)] leading-relaxed max-w-2xl mx-auto text-lg font-bold opacity-80">
                Le contenu de BMI PRO est fourni à titre informatif uniquement.
            </p>
        </div>
    </main>
</Layout>
