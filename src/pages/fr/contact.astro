---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
---

<Layout title="Contactez-nous | Real BMI Calculator">
    <Navbar />
    <main class="pt-40 pb-20 px-6">
        <div class="max-w-7xl mx-auto">
          <div class="space-y-6 mb-12">
            <a href="/fr" class="inline-flex items-center gap-2 text-[10px] font-black uppercase tracking-[0.28em] text-[var(--accent)] hover:text-[var(--foreground)] transition-colors">
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
              Home
            </a>
            <p class="text-xs font-semibold uppercase tracking-[0.32em] text-[var(--accent)]">Contactez-nous</p>
            <h1 class="text-4xl sm:text-5xl md:text-6xl font-display font-black uppercase tracking-tight leading-tight text-[var(--foreground)]">Contactez-nous</h1>
            <p class="max-w-3xl text-base md:text-lg leading-relaxed text-[var(--muted-foreground)]">Pour des questions concernant les calculateurs ou la méthodologie, contactez-nous par e-mail. Cliquez sur le bouton pour ouvrir votre application mail.</p>
          </div>

          <div class="grid gap-10 lg:grid-cols-[1.45fr_0.85fr] items-start">
            <div class="space-y-8">
              <div class="prose prose-zinc dark:prose-invert max-w-none text-[var(--muted-foreground)] leading-relaxed text-lg md:text-xl font-medium opacity-90">
                <p><strong>Bhawanshi Dosi</strong> — Full Stack Developer. Je peux aider pour des questions sur la précision et la méthodologie des calculateurs.</p>
                <p>Pour le support ou les retours, cliquez sur le bouton pour envoyer un e-mail.</p>
              </div>

              <div class="grid gap-4 sm:grid-cols-2">
                <div class="rounded-[var(--radius)] border border-[var(--border)] bg-[var(--card)] p-6">
                  <p class="text-sm uppercase tracking-[0.3em] font-bold text-[var(--accent)]">E-mail</p>
                  <p class="mt-3 text-base font-semibold text-[var(--foreground)]">Cliquez pour envoyer</p>
                </div>
                <div class="rounded-[var(--radius)] border border-[var(--border)] bg-[var(--card)] p-6">
                  <p class="text-sm uppercase tracking-[0.3em] font-bold text-[var(--accent)]">Délai de réponse</p>
                  <p class="mt-3 text-base font-semibold text-[var(--foreground)]">En général sous 24 heures les jours ouvrables</p>
                </div>
              </div>
            </div>

            <aside class="rounded-[var(--radius)] border border-[var(--border)] bg-[var(--card)] p-8 shadow-[var(--shadow-soft)]">
              <p class="text-xs uppercase tracking-[0.32em] font-semibold text-[var(--accent)]">Contact</p>
              <h2 class="mt-4 text-3xl font-black text-[var(--foreground)]">Support par e-mail</h2>
              <p class="mt-4 text-sm leading-relaxed text-[var(--muted-foreground)]">Cliquez ci-dessous pour ouvrir votre client mail avec l'adresse préremplie.</p>
              <a href="mailto:vecna312002@gmail.com" class="mt-8 inline-flex w-full items-center justify-center rounded-full border border-[var(--accent)] bg-[var(--accent)]/10 px-5 py-3 text-sm font-semibold uppercase tracking-[0.2em] text-[var(--accent)] transition hover:bg-[var(--accent)]/15">Envoyer un e-mail</a>
            </aside>
          </div>
        </div>
    </main>
</Layout>
