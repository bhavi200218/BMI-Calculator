---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import BMICalculator from '../../components/BMICalculator.astro';
import ResultStudio from '../../components/ResultStudio.astro';
import HealthContent from '../../components/HealthContent.astro';
---

<Layout 
	title="Calculateur d'IMC | Calculez votre indice de masse corporelle en ligne"
	description="Calculez votre IMC avec précision grâce à notre calculateur d'indice de masse corporelle premium. Idéal pour les hommes, les femmes et les adultes."
>
	<Navbar />
	<main class="pt-32 pb-20 px-6">
		<div class="max-w-4xl mx-auto text-center space-y-4 mb-16 animate-in">
			<div class="inline-flex items-center gap-2 px-3 py-1 rounded-lg bg-[var(--muted)] border border-[var(--border)] text-[10px] font-black uppercase tracking-[0.2em] text-[var(--muted-foreground)]">
				Analyse de Santé Premium
			</div>
			<h1 class="text-4xl md:text-5xl font-black tracking-tighter text-[var(--foreground)] uppercase">
				Précision dans chaque mesure.
			</h1>
			<p class="text-sm md:text-base text-[var(--muted-foreground)] leading-relaxed max-w-2xl mx-auto font-bold opacity-60">
				Des métriques précises pour l'amateur de santé moderne. Calculées à l'aide de formules cliniquement validées.
			</p>
		</div>

		<div class="max-w-7xl mx-auto grid lg:grid-cols-2 gap-8 items-stretch mb-32 relative z-10">
			<BMICalculator />
			<ResultStudio />
		</div>

		<HealthContent />
	</main>
</Layout>

<style is:global>
	@keyframes fadeIn {
		from { opacity: 0; transform: translateY(10px); }
		to { opacity: 1; transform: translateY(0); }
	}
	.animate-in {
		animation: fadeIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
	}
</style>
