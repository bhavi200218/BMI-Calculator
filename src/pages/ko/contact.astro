---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
---

<Layout title="문의하기 | Real BMI Calculator">
    <Navbar />
    <main class="pt-32 pb-20 px-6 max-w-4xl mx-auto space-y-12">
        <h1 class="text-5xl font-black tracking-tighter uppercase">문의하기</h1>
        
        <div class="glass-card p-10 space-y-8 border-2 border-[var(--border)]">
            <div class="space-y-4">
                <h2 class="text-3xl font-black tracking-tighter uppercase">개발자 프로필</h2>
                <p class="text-xl font-black tracking-tight text-[var(--foreground)]">Bhawanshi Dosi</p>
                <p class="text-sm font-black uppercase tracking-widest opacity-40">Full Stack Developer</p>
            </div>
            
            <p class="text-lg text-[var(--muted-foreground)] leading-relaxed font-bold opacity-70">
                안녕하세요, 풀스택 개발자 Bhawanshi Dosi입니다. 이 애플리케이션에 대해 궁금한 점이 있으시면 언제든지 LinkedIn으로 문의해 주세요. 최대한 빨리 답변해 드리도록 하겠습니다. 이메일 문의는 <a href="mailto:vecna312002@gmail.com" class="text-[var(--foreground)] border-b-2 border-[var(--border)] hover:opacity-70 transition-opacity">vecna312002@gmail.com</a>으로 보내주세요.
            </p>

            <div class="pt-6">
                <a href="https://www.linkedin.com/in/bhawanshi-dosi" target="_blank" class="inline-flex items-center gap-3 px-8 py-4 rounded-xl bg-[var(--muted)] border-2 border-[var(--border)] text-sm font-black uppercase tracking-widest hover:bg-[var(--border)] transition-all">
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
                    LinkedIn에서 연결
                </a>
            </div>
        </div>
    </main>
</Layout>
