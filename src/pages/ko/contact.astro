---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
---

<Layout title="문의하기 | Real BMI Calculator">
    <Navbar />
    <main class="pt-40 pb-20 px-6">
        <div class="max-w-7xl mx-auto">
          <div class="space-y-6 mb-12">
            <a href="/ko" class="inline-flex items-center gap-2 text-[10px] font-black uppercase tracking-[0.28em] text-[var(--accent)] hover:text-[var(--foreground)] transition-colors">
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
              Home
            </a>
            <p class="text-xs font-semibold uppercase tracking-[0.32em] text-[var(--accent)]">문의하기</p>
            <h1 class="text-4xl sm:text-5xl md:text-6xl font-display font-black uppercase tracking-tight leading-tight text-[var(--foreground)]">문의하기</h1>
            <p class="max-w-3xl text-base md:text-lg leading-relaxed text-[var(--muted-foreground)]">계산기 또는 방법론에 대한 질문이 있으시면 이메일로 연락해 주세요. 이메일 프로그램을 열려면 버튼을 클릭하세요.</p>
          </div>

          <div class="grid gap-10 lg:grid-cols-[1.45fr_0.85fr] items-start">
            <div class="space-y-8">
              <div class="prose prose-zinc dark:prose-invert max-w-none text-[var(--muted-foreground)] leading-relaxed text-lg md:text-xl font-medium opacity-90">
                <p><strong>Bhawanshi Dosi</strong> — Full Stack Developer. 계산기의 정확성과 방법론에 대한 질문을 도와드립니다.</p>
                <p>지원이나 피드백의 경우 이메일을 보내려면 버튼을 클릭하세요.</p>
              </div>

              <div class="grid gap-4 sm:grid-cols-2">
                <div class="rounded-[var(--radius)] border border-[var(--border)] bg-[var(--card)] p-6">
                  <p class="text-sm uppercase tracking-[0.3em] font-bold text-[var(--accent)]">이메일</p>
                  <p class="mt-3 text-base font-semibold text-[var(--foreground)]">전송하려면 클릭</p>
                </div>
                <div class="rounded-[var(--radius)] border border-[var(--border)] bg-[var(--card)] p-6">
                  <p class="text-sm uppercase tracking-[0.3em] font-bold text-[var(--accent)]">응답 시간</p>
                  <p class="mt-3 text-base font-semibold text-[var(--foreground)]">영업일 기준 보통 24시간 이내</p>
                </div>
              </div>
            </div>

            <aside class="rounded-[var(--radius)] border border-[var(--border)] bg-[var(--card)] p-8 shadow-[var(--shadow-soft)]">
              <p class="text-xs uppercase tracking-[0.32em] font-semibold text-[var(--accent)]">문의</p>
              <h2 class="mt-4 text-3xl font-black text-[var(--foreground)]">이메일 지원</h2>
              <p class="mt-4 text-sm leading-relaxed text-[var(--muted-foreground)]">아래를 클릭하면 미리 채워진 수신자 주소로 기본 메일 클라이언트가 열립니다.</p>
              <a href="mailto:vecna312002@gmail.com" class="mt-8 inline-flex w-full items-center justify-center rounded-full border border-[var(--accent)] bg-[var(--accent)]/10 px-5 py-3 text-sm font-semibold uppercase tracking-[0.2em] text-[var(--accent)] transition hover:bg-[var(--accent)]/15">이메일 보내기</a>
            </aside>
          </div>
        </div>
    </main>
</Layout>
