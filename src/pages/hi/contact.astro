---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
---

<Layout title="संपर्क करें | Real BMI Calculator">
    <Navbar />
    <main class="pt-40 pb-20 px-6">
        <div class="max-w-7xl mx-auto">
          <div class="space-y-6 mb-12">
            <a href="/hi" class="inline-flex items-center gap-2 text-[10px] font-black uppercase tracking-[0.28em] text-[var(--accent)] hover:text-[var(--foreground)] transition-colors">
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
              Home
            </a>
            <p class="text-xs font-semibold uppercase tracking-[0.32em] text-[var(--accent)]">संपर्क करें</p>
            <h1 class="text-4xl sm:text-5xl md:text-6xl font-display font-black uppercase tracking-tight leading-tight text-[var(--foreground)]">संपर्क करें</h1>
            <p class="max-w-3xl text-base md:text-lg leading-relaxed text-[var(--muted-foreground)]">यदि आप गणनाओं या पद्धति के बारे में प्रश्न रखते हैं, तो हमें ईमेल करें। अपना ईमेल प्रोग्राम खोलने के लिए बटन पर क्लिक करें।</p>
          </div>

          <div class="grid gap-10 lg:grid-cols-[1.45fr_0.85fr] items-start">
            <div class="space-y-8">
              <div class="prose prose-zinc dark:prose-invert max-w-none text-[var(--muted-foreground)] leading-relaxed text-lg md:text-xl font-medium opacity-90">
                <p><strong>भवांशी दोसी</strong> — Full Stack Developer. मैं गणनाओं की सटीकता और पद्धति के बारे में प्रश्नों में सहायता कर सकती हूँ।</p>
                <p>सपोर्ट या फीडबैक के लिए, कृपया ईमेल भेजने के लिए बटन पर क्लिक करें।</p>
              </div>

              <div class="grid gap-4 sm:grid-cols-2">
                <div class="rounded-[var(--radius)] border border-[var(--border)] bg-[var(--card)] p-6">
                  <p class="text-sm uppercase tracking-[0.3em] font-bold text-[var(--accent)]">ईमेल</p>
                  <p class="mt-3 text-base font-semibold text-[var(--foreground)]">भेजने के लिए क्लिक करें</p>
                </div>
                <div class="rounded-[var(--radius)] border border-[var(--border)] bg-[var(--card)] p-6">
                  <p class="text-sm uppercase tracking-[0.3em] font-bold text-[var(--accent)]">प्रतिसाद समय</p>
                  <p class="mt-3 text-base font-semibold text-[var(--foreground)]">कार्यदिवसों में सामान्यतः 24 घंटे के भीतर</p>
                </div>
              </div>
            </div>

            <aside class="rounded-[var(--radius)] border border-[var(--border)] bg-[var(--card)] p-8 shadow-[var(--shadow-soft)]">
              <p class="text-xs uppercase tracking-[0.32em] font-semibold text-[var(--accent)]">संपर्क</p>
              <h2 class="mt-4 text-3xl font-black text-[var(--foreground)]">ईमेल सपोर्ट</h2>
              <p class="mt-4 text-sm leading-relaxed text-[var(--muted-foreground)]">नीचे क्लिक करें, यह आपके डिफ़ॉल्ट ईमेल क्लाइंट को पूर्व-भरे गए रिसीवर के साथ खोलेगा।</p>
              <a href="mailto:vecna312002@gmail.com" class="mt-8 inline-flex w-full items-center justify-center rounded-full border border-[var(--accent)] bg-[var(--accent)]/10 px-5 py-3 text-sm font-semibold uppercase tracking-[0.2em] text-[var(--accent)] transition hover:bg-[var(--accent)]/15">ईमेल भेजें</a>
            </aside>
          </div>
        </div>
    </main>
</Layout>
