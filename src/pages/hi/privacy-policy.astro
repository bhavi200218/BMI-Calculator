---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
---

<Layout title="गोपनीयता नीति | BMI PRO">
    <Navbar />
    <main class="pt-40 pb-20 px-6 max-w-4xl mx-auto space-y-12">
        <a href="/hi" class="text-[10px) font-black uppercase tracking-widest text-[var(--foreground)] flex items-center gap-2 hover:translate-x-[-4px] transition-transform">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
            होम पर वापस जाएं
        </a>
        <h1 class="text-5xl font-black tracking-tighter uppercase">गोपनीयता नीति</h1>
        <div class="prose prose-zinc dark:prose-invert max-w-none text-[var(--muted-foreground)] leading-relaxed space-y-8 text-xl font-bold">
            <p>
                <span class="text-[var(--foreground)]">BMI PRO</span> में, हम समझते हैं कि आपका स्वास्थ्य डेटा गहराई से व्यक्तिगत है। यह केवल संख्याएँ नहीं हैं; यह आपकी मेहनत, आपके लक्ष्यों और आपके जीवन का प्रतिबिंब है।
            </p>
            <p>
                मेरा आपसे वादा है: <span class="text-[var(--foreground)] tracking-tight">आपका डेटा आपके पास ही रहता है।</span> हम आपकी ऊंचाई, वजन या उम्र को अपने सर्वर पर स्टोर नहीं करते हैं। गणना आपके डिवाइस पर तुरंत होती है, जिससे आपकी गोपनीयता कभी भी खतरे में नहीं पड़ती।
            </p>
            <p>
                हम केवल गुमनाम विश्लेषण का उपयोग यह समझने के लिए करते हैं कि हम अपने उपकरण को सभी के लिए बेहतर कैसे बना सकते हैं। जब आप "गणना करें" बटन दबाते हैं, तो हम उस भरोसे का कभी गलत उपयोग नहीं करेंगे।
            </p>
            <div class="pt-8 border-t border-[var(--border)] italic opacity-60 text-lg leading-relaxed">
                "भरोसा किसी भी स्वास्थ्य यात्रा की नींव है। मैंने इसे आपके भरोसे की रक्षा के लिए बनाया है।" — भवांशी दोसी
            </div>
        </div>
    </main>
</Layout>
