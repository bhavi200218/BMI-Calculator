---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
---

<Layout title="हमारे बारे में | BMI PRO">
    <Navbar />
    <main class="pt-40 pb-20 px-6 max-w-4xl mx-auto space-y-16">
        <div class="space-y-4">
            <a href="/hi" class="text-[10px] font-black uppercase tracking-widest text-[var(--foreground)] flex items-center gap-2 hover:translate-x-[-4px] transition-transform">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
                होम पर वापस जाएं
            </a>
            <h1 class="text-6xl font-black tracking-tighter uppercase">हमारे बारे में</h1>
        </div>

        <div class="prose prose-zinc dark:prose-invert max-w-none text-[var(--muted-foreground)] leading-relaxed space-y-10 text-xl font-bold">
            <div class="space-y-6">
                <p>
                    नमस्ते, मैं <span class="text-[var(--foreground)]">भवांशी दोसी</span> हूँ।
                </p>
                <p>
                    मैंने BMI PRO को केवल इंटरनेट पर एक और कैलकुलेटर होने के लिए नहीं बनाया है। मैंने इसे इसलिए बनाया है क्योंकि मेरा मानना है कि स्वास्थ्य हर किसी की सबसे व्यक्तिगत यात्रा है, और उस यात्रा के लिए "अनुमानित" नंबरों से बेहतर कुछ होना चाहिए।
                </p>
                <p>
                    मेरा मिशन एक ऐसा सटीक उपकरण बनाना था जो उपयोगकर्ताओं को यथासंभव सटीक भविष्यवाणियां प्रदान करे। मैं कुछ ऐसा बनाना चाहता था जो एक पेशेवर चिकित्सा उपकरण जैसा महसूस हो लेकिन हर किसी के लिए, हर जगह सुलभ रहे।
                </p>
                <p>
                    चाहे आप किसी लक्ष्य तक पहुँचने की कोशिश कर रहे हों या बस अपने स्वास्थ्य की जाँच कर रहे हों, मैं चाहता हूँ कि BMI PRO वह साथी बने जिस पर आप भरोसा कर सकें। कोड की हर लाइन आपके स्वास्थ्य और सटीकता को ध्यान में रखकर लिखी गई है।
                </p>
            </div>

            <div class="pt-8 space-y-4 text-[var(--foreground)] border-t border-[var(--border)]">
                <p class="text-3xl font-black tracking-tighter">
                    जुड़ें
                </p>
                <p class="text-lg opacity-60">
                    यदि आपके कोई प्रश्न हैं या आप अपनी स्वास्थ्य यात्रा साझा करना चाहते हैं, तो बेझिझक संपर्क करें।
                </p>
                <div class="pt-2">
                    <a href="https://www.linkedin.com/in/bhawanshi-dosi" target="_blank" class="inline-flex items-center text-sm font-black hover:opacity-70 transition-opacity uppercase tracking-widest no-underline group">
                        लिंक्डइन प्रोफाइल
                        <svg class="w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
                    </a>
                </div>
            </div>
        </div>
    </main>
</Layout>
