---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
---

<Layout title="Contáctanos | Real BMI Calculator">
    <Navbar />
    <main class="pt-40 pb-20 px-6">
        <div class="max-w-7xl mx-auto">
          <div class="space-y-6 mb-12">
            <a href="/es" class="inline-flex items-center gap-2 text-[10px] font-black uppercase tracking-[0.28em] text-[var(--accent)] hover:text-[var(--foreground)] transition-colors">
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
              Home
            </a>
            <p class="text-xs font-semibold uppercase tracking-[0.32em] text-[var(--accent)]">Contáctanos</p>
            <h1 class="text-4xl sm:text-5xl md:text-6xl font-display font-black uppercase tracking-tight leading-tight text-[var(--foreground)]">Contáctanos</h1>
            <p class="max-w-3xl text-base md:text-lg leading-relaxed text-[var(--muted-foreground)]">Si tienes preguntas sobre las calculadoras o la metodología, contáctanos por correo. Haz clic en el botón para abrir tu aplicación de correo.</p>
          </div>

          <div class="grid gap-10 lg:grid-cols-[1.45fr_0.85fr] items-start">
            <div class="space-y-8">
              <div class="prose prose-zinc dark:prose-invert max-w-none text-[var(--muted-foreground)] leading-relaxed text-lg md:text-xl font-medium opacity-90">
                <p><strong>Bhawanshi Dosi</strong> — Full Stack Developer. Estoy disponible para preguntas sobre la precisión y el método de las calculadoras.</p>
                <p>Para soporte o comentarios, haz clic en el botón para enviar un correo electrónico.</p>
              </div>

              <div class="grid gap-4 sm:grid-cols-2">
                <div class="rounded-[var(--radius)] border border-[var(--border)] bg-[var(--card)] p-6">
                  <p class="text-sm uppercase tracking-[0.3em] font-bold text-[var(--accent)]">Correo</p>
                  <p class="mt-3 text-base font-semibold text-[var(--foreground)]">Haz clic para enviar</p>
                </div>
                <div class="rounded-[var(--radius)] border border-[var(--border)] bg-[var(--card)] p-6">
                  <p class="text-sm uppercase tracking-[0.3em] font-bold text-[var(--accent)]">Tiempo de respuesta</p>
                  <p class="mt-3 text-base font-semibold text-[var(--foreground)]">Por lo general dentro de 24 horas en días laborables</p>
                </div>
              </div>
            </div>

            <aside class="rounded-[var(--radius)] border border-[var(--border)] bg-[var(--card)] p-8 shadow-[var(--shadow-soft)]">
              <p class="text-xs uppercase tracking-[0.32em] font-semibold text-[var(--accent)]">Contacto</p>
              <h2 class="mt-4 text-3xl font-black text-[var(--foreground)]">Soporte por correo</h2>
              <p class="mt-4 text-sm leading-relaxed text-[var(--muted-foreground)]">Haz clic abajo para abrir tu cliente de correo con la dirección predefinida.</p>
              <a href="mailto:vecna312002@gmail.com" class="mt-8 inline-flex w-full items-center justify-center rounded-full border border-[var(--accent)] bg-[var(--accent)]/10 px-5 py-3 text-sm font-semibold uppercase tracking-[0.2em] text-[var(--accent)] transition hover:bg-[var(--accent)]/15">Enviar correo</a>
            </aside>
          </div>
        </div>
    </main>
</Layout>
